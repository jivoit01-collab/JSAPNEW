@{
    ViewData["Title"] = "Owner Task Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var employeeName = ViewBag.EmployeeName?.ToString() ?? "Owner";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/task.css?v=20260421a" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    html, body { width:100%; max-width:100%; overflow-x:hidden; }
    .od-root, .od-root * { font-family:'Inter',system-ui,sans-serif; box-sizing:border-box; }
    .od-root { background:#f8fafc; min-height:100vh; }

    /* ── Header ── */
    .od-header {
        display:grid; grid-template-columns:minmax(260px,1fr) auto; align-items:center; gap:22px;
        padding:18px 24px; background:#fff; border-bottom:1px solid #dbe3ef;
        position:sticky; top:0; z-index:100; box-shadow:0 10px 24px rgba(15,23,42,.08);
    }
    .od-hd-left { display:flex; align-items:center; gap:14px; min-width:0; }
    .od-logo {
        width:46px; height:46px; border-radius:8px;
        background:#0b2c4d; color:#fff; flex-shrink:0;
        display:flex; align-items:center; justify-content:center;
        box-shadow:0 8px 18px rgba(11,44,77,.22);
    }
    .od-logo svg { width:22px; height:22px; }
    .od-hd-kicker {
        font-size:10px; font-weight:800; letter-spacing:.7px; text-transform:uppercase;
        color:#0d9488; margin-bottom:3px;
    }
    .od-hd-title { font-size:1.18rem; font-weight:850; color:#0f172a; line-height:1.2; }
    .od-hd-sub { font-size:12px; color:#64748b; font-weight:600; margin-top:3px; }
    .od-hd-user { color:#123f6d; font-weight:800; }
    .od-hd-right {
        display:flex; align-items:end; gap:12px; flex-wrap:wrap; justify-content:flex-end;
        padding:10px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px;
    }
    .od-filter-block { display:flex; flex-direction:column; gap:6px; }
    .od-filter-label {
        font-size:10px; font-weight:800; letter-spacing:.5px; text-transform:uppercase; color:#64748b;
    }
    .od-period-group {
        display:grid; grid-template-columns:repeat(4,auto); gap:4px; padding:4px;
        background:#e8eef6; border-radius:8px;
    }
    .od-period-btn {
        min-height:32px; padding:0 12px; border-radius:6px; border:0;
        font-size:12px; font-weight:800; cursor:pointer; background:transparent; color:#475569;
        transition:background .15s, color .15s, box-shadow .15s;
    }
    .od-period-btn.active,.od-period-btn:hover {
        background:#fff; color:#123f6d; box-shadow:0 1px 4px rgba(15,23,42,.12);
    }
    .od-date-range { display:flex; align-items:center; gap:8px; }
    .od-date-sep { font-size:11px; color:#94a3b8; font-weight:800; text-transform:uppercase; }
    .od-date-input {
        height:40px; padding:0 11px; border:1px solid #cbd5e1; border-radius:7px;
        font-size:12px; font-family:inherit; font-weight:700; color:#334155; background:#fff; width:136px;
        outline:none; transition:border-color .15s, box-shadow .15s;
    }
    .od-date-input:focus { border-color:#0d9488; box-shadow:0 0 0 3px rgba(13,148,136,.12); }
    .od-btn {
        display:inline-flex; align-items:center; justify-content:center; gap:8px; height:40px; padding:0 16px;
        border-radius:7px; font-size:13px; font-weight:800; cursor:pointer; border:none; transition:all .15s;
    }
    .od-btn-primary { background:#123f6d; color:#fff; box-shadow:0 8px 18px rgba(18,63,109,.22); }
    .od-btn-primary:hover { background:#0b2c4d; transform:translateY(-1px); }

    /* ── Body ── */
    .od-body { padding:0; max-width:100%; margin:0; }
    .od-section-label {
        font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.6px;
        color:#64748b; margin-bottom:14px; display:flex; align-items:center; gap:8px;
    }
    .od-section-label::after { content:''; flex:1; height:1px; background:#e2e8f0; }

    /* ── Stat cards ── */
    .od-stat-row { display:grid; grid-template-columns:repeat(7,1fr); gap:12px; margin-bottom:24px; }
    .od-stat {
        background:#fff; border-radius:14px; padding:18px 14px 14px;
        border-top:4px solid #123f6d; box-shadow:0 1px 4px rgba(0,0,0,.06);
        text-align:center; transition:transform .15s;
    }
    .od-stat:hover { transform:translateY(-2px); }
    .od-stat.green{border-top-color:#10b981} .od-stat.blue{border-top-color:#3b82f6}
    .od-stat.amber{border-top-color:#f59e0b} .od-stat.red{border-top-color:#ef4444}
    .od-stat.purple{border-top-color:#8b5cf6} .od-stat.teal{border-top-color:#0d9488}
    .od-stat-icon{font-size:20px;display:block;margin-bottom:4px}
    .od-stat-val{font-size:28px;font-weight:800;color:#0f172a;line-height:1}
    .od-stat-lbl{font-size:11px;color:#64748b;font-weight:600;margin-top:4px}

    /* ── Hierarchy layout ── */
    .od-hier { display:grid; grid-template-columns:minmax(0,1fr) 380px; gap:20px; align-items:start; }

    /* ── Dept list panel ── */
    .od-dept-panel, .od-hod-panel {
        background:#fff; border-radius:16px; box-shadow:0 1px 4px rgba(0,0,0,.06);
        position:sticky; top:80px; max-height:calc(100vh - 100px); overflow-y:auto;
    }
    .od-dept-panel-hd, .od-hod-panel-hd {
        padding:18px 20px 14px; border-bottom:1.5px solid #e2e8f0;
        font-size:14px; font-weight:800; color:#123f6d;
        display:flex; align-items:center; justify-content:space-between;
        position:sticky; top:0; background:#fff; z-index:2;
    }
    .od-dept-count { font-size:11px; font-weight:700; background:#f1f5f9; color:#64748b; padding:3px 9px; border-radius:20px; }

    .od-dept-item {
        padding:14px 20px; border-bottom:1px solid #f1f5f9; cursor:pointer;
        transition:background .12s; display:flex; align-items:center; gap:10px;
    }
    .od-dept-item:hover { background:#f8fafc; }
    .od-dept-item.active { background:#eff6ff; border-left:3px solid #2563eb; }
    .od-dept-item.active .od-di-name { color:#1d4ed8; }
    .od-hod-item {
        padding:14px 16px; border-bottom:1px solid #f1f5f9; cursor:pointer;
        transition:background .12s; display:flex; align-items:center; gap:10px;
    }
    .od-hod-item:hover { background:#f8fafc; }
    .od-hod-item.active { background:#eff6ff; border-left:3px solid #2563eb; }
    .od-hod-avatar {
        width:36px; height:36px; border-radius:10px; background:#123f6d; color:#fff;
        display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:800;
        flex-shrink:0;
    }
    .od-hod-block { border-bottom:1px solid #f1f5f9; }
    .od-hod-block .od-hod-item { border-bottom:0; }
    .od-hod-toggle {
        margin-left:auto; width:30px; height:30px; border:1px solid #dbeafe; border-radius:8px;
        background:#fff; color:#2563eb; display:flex; align-items:center; justify-content:center;
        cursor:pointer; transition:all .12s; flex-shrink:0;
    }
    .od-hod-toggle:hover { background:#eff6ff; border-color:#93c5fd; }
    .od-hod-toggle i { font-size:12px; transition:transform .12s; }
    .od-hod-toggle.collapsed i { transform:rotate(-90deg); }
    .od-hod-depts { padding:0 10px 12px 58px; display:flex; flex-direction:column; gap:8px; }
    .od-hod-dept {
        width:100%; border:1px solid #e2e8f0; border-radius:8px; background:#fff;
        padding:10px; text-align:left; cursor:pointer; transition:all .12s;
    }
    .od-hod-dept:hover { background:#f8fafc; border-color:#bfdbfe; }
    .od-hod-dept.active { background:#eff6ff; border-color:#2563eb; box-shadow:inset 3px 0 0 #2563eb; }
    .od-hod-dept-name { font-size:12px; font-weight:800; color:#0f172a; }
    .od-hod-dept-meta { margin-top:3px; font-size:10px; font-weight:700; color:#64748b; }
    .od-employee-picker {
        display:flex; align-items:end; gap:12px; flex-wrap:wrap; margin-bottom:16px;
        padding:14px; border:1px solid #e2e8f0; border-radius:8px; background:#f8fafc;
    }
    .od-employee-picker label {
        display:flex; flex-direction:column; gap:6px; font-size:11px; font-weight:800;
        color:#64748b; text-transform:uppercase; letter-spacing:.4px; flex:1; min-width:240px;
    }
    .od-employee-picker select {
        height:40px; border:1.5px solid #cbd5e1; border-radius:8px; padding:0 12px;
        font-size:13px; font-weight:700; color:#0f172a; background:#fff;
    }
    .od-inline-task-list { display:flex; flex-direction:column; gap:12px; }

    .od-di-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
    .od-di-body { flex:1; min-width:0; }
    .od-di-name { font-size:13px; font-weight:700; color:#0f172a; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .od-di-stats { font-size:11px; color:#94a3b8; font-weight:600; margin-top:2px; }
    .od-di-badge {
        font-size:10px; font-weight:700; padding:2px 7px; border-radius:20px; white-space:nowrap;
    }
    .od-di-badge.has-tasks { background:#d1fae5; color:#059669; }
    .od-di-badge.no-tasks  { background:#f1f5f9; color:#94a3b8; }

    /* ── Detail panel ── */
    .od-detail { display:flex; flex-direction:column; gap:20px; }

    .od-panel { background:#fff; border-radius:16px; padding:22px; box-shadow:0 1px 4px rgba(0,0,0,.06); }
    .od-panel-title {
        font-size:15px; font-weight:800; color:#123f6d;
        margin-bottom:18px; padding-bottom:12px; border-bottom:1.5px solid #e2e8f0;
        display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px;
    }

    /* ── Dept summary card ── */
    .od-dept-summary {
        display:grid; grid-template-columns:repeat(6,1fr); gap:12px; margin-bottom:20px;
    }
    .od-sum-cell { text-align:center; padding:14px 10px; border-radius:12px; background:#f8fafc; }
    .od-sum-val { font-size:24px; font-weight:800; color:#0f172a; display:block; }
    .od-sum-lbl { font-size:10px; color:#94a3b8; font-weight:700; text-transform:uppercase; margin-top:3px; display:block; }

    /* ── Progress bar ── */
    .od-prog-row { display:flex; align-items:center; gap:10px; margin-bottom:16px; }
    .od-prog-track { flex:1; height:10px; background:#e2e8f0; border-radius:6px; overflow:hidden; }
    .od-prog-fill { height:100%; border-radius:6px; transition:width .5s ease; }
    .od-prog-label { font-size:13px; font-weight:800; min-width:48px; text-align:right; }

    /* ── Employee cards ── */
    .od-emp-sort { display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:16px; }
    .od-sort-lbl { font-size:12px; color:#64748b; font-weight:600; }
    .od-sort-select {
        padding:6px 10px; border:1.5px solid #e2e8f0; border-radius:8px;
        font-size:12px; font-family:inherit; background:#fff; cursor:pointer;
    }

    .od-emp-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px; }

    .od-emp-card {
        border-radius:14px; padding:16px; border-left:4px solid #e2e8f0;
        box-shadow:0 1px 4px rgba(0,0,0,.06); background:#fff;
        transition:transform .15s, box-shadow .15s;
    }
    .od-emp-card:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(0,0,0,.1); }
    .od-emp-card.perf-top  { border-left-color:#10b981; }
    .od-emp-card.perf-good { border-left-color:#3b82f6; }
    .od-emp-card.perf-avg  { border-left-color:#f59e0b; }
    .od-emp-card.perf-risk { border-left-color:#ef4444; }
    .od-emp-card.perf-none { border-left-color:#cbd5e1; background:#fafafa; }
    .od-emp-card.hod-card { border-left-width:6px; background:#f8fbff; }
    .od-emp-card.subhod-card { background:#fffaf5; }

    .od-tree-stack { display:flex; flex-direction:column; gap:18px; }
    .od-hod-section { border:1.5px solid #dbeafe; border-radius:14px; background:#f8fafc; padding:14px; }
    .od-hod-section + .od-hod-section { margin-top:4px; }
    .od-subhod-list { display:flex; flex-direction:column; gap:14px; margin-top:14px; padding-left:16px; border-left:2px solid #dbeafe; }
    .od-subhod-section { background:#fff; border:1px solid #e2e8f0; border-radius:12px; padding:12px; }
    .od-subhod-title { font-size:11px; font-weight:800; color:#64748b; text-transform:uppercase; letter-spacing:.4px; margin-bottom:10px; }
    .od-exec-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:12px; margin-top:12px; padding-left:14px; border-left:2px dashed #e2e8f0; }

    .od-emp-head { display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; }
    .od-emp-avatar {
        width:40px; height:40px; border-radius:10px; flex-shrink:0;
        display:flex; align-items:center; justify-content:center;
        font-size:14px; font-weight:800; color:#fff;
    }
    .od-emp-name { font-size:13px; font-weight:800; color:#0f172a; }
    .od-emp-role { font-size:11px; color:#64748b; font-weight:600; margin-top:1px; }
    .od-emp-perf {
        margin-left:auto; padding:3px 9px; border-radius:20px;
        font-size:10px; font-weight:800; white-space:nowrap;
    }
    .od-emp-perf.top  {background:#d1fae5;color:#059669}
    .od-emp-perf.good {background:#dbeafe;color:#2563eb}
    .od-emp-perf.avg  {background:#fef3c7;color:#d97706}
    .od-emp-perf.risk {background:#fee2e2;color:#dc2626}
    .od-emp-perf.none {background:#f1f5f9;color:#94a3b8}

    .od-emp-nums { display:grid; grid-template-columns:repeat(5,1fr); gap:4px; margin-bottom:10px; }
    .od-num-cell { text-align:center; }
    .od-num-val { font-size:16px; font-weight:800; display:block; color:#0f172a; }
    .od-num-lbl { font-size:9px; color:#94a3b8; font-weight:700; text-transform:uppercase; }

    .od-emp-prog { display:flex; align-items:center; gap:8px; }
    .od-emp-prog-track { flex:1; height:6px; background:#e2e8f0; border-radius:4px; overflow:hidden; }
    .od-emp-prog-fill  { height:100%; border-radius:4px; }
    .od-emp-prog-pct   { font-size:12px; font-weight:800; min-width:36px; text-align:right; }

    /* Placeholder */
    .od-placeholder {
        display:flex; flex-direction:column; align-items:center; justify-content:center;
        padding:60px; color:#94a3b8; text-align:center; gap:12px;
    }
    .od-placeholder-icon { font-size:48px; opacity:.4; }
    .od-placeholder-txt  { font-size:14px; font-weight:600; }
    .od-placeholder-sub  { font-size:12px; opacity:.7; }

    /* Spinner */
    .od-spin-wrap { display:flex; align-items:center; justify-content:center; padding:40px; }
    .od-spinner {
        width:32px; height:32px; border:3px solid #e2e8f0; border-top-color:#123f6d;
        border-radius:50%; animation:odspin .8s linear infinite;
    }
    @@keyframes odspin { to { transform:rotate(360deg); } }
    .od-empty { text-align:center; padding:40px; color:#94a3b8; font-size:13px; }

    /* Performance legend */
    .od-legend { display:flex; gap:10px; flex-wrap:wrap; padding:10px 14px; background:#f8fafc; border-radius:10px; margin-bottom:16px; }
    .od-legend-item { font-size:11px; font-weight:700; padding:3px 10px; border-radius:20px; }

    /* No-tasks dept indicator */
    .od-notask-badge { display:inline-flex; align-items:center; gap:4px; font-size:11px; color:#94a3b8; font-weight:600; }

    /* ── Breadcrumb ── */
    .od-breadcrumb { display:flex; align-items:center; gap:4px; flex-wrap:wrap; margin-bottom:14px; padding:8px 12px; background:#f8fafc; border-radius:10px; }
    .od-bc-link { font-size:12px; font-weight:700; color:#2563eb; cursor:pointer; padding:3px 8px; border-radius:6px; background:#eff6ff; transition:background .12s; }
    .od-bc-link:hover { background:#dbeafe; }
    .od-bc-sep { font-size:14px; color:#94a3b8; }
    .od-bc-current { font-size:12px; font-weight:700; color:#0f172a; padding:3px 8px; }

    /* ── Role-level chips ── */
    .od-role-chip { font-size:10px; font-weight:700; padding:2px 8px; border-radius:20px; white-space:nowrap; }

    /* ── Drill button ── */
    .od-drill-btn {
        width:100%; margin-top:10px; padding:7px 14px;
        border-radius:8px; font-size:12px; font-weight:700; cursor:pointer;
        display:flex; align-items:center; justify-content:center; gap:6px;
        transition:all .15s; border:1.5px solid;
    }
    .od-drill-btn:hover { opacity:.85; }

    /* ── SubHOD tab layout ── */
    .od-hod-bar { display:flex; align-items:center; gap:8px; flex-wrap:wrap; padding:10px 14px; background:#eff6ff; border-radius:10px; margin-bottom:16px; }
    .od-hod-bar-label { font-size:11px; font-weight:800; color:#64748b; text-transform:uppercase; letter-spacing:.5px; margin-right:4px; flex-shrink:0; }
    .od-hod-chip { font-size:12px; font-weight:700; color:#1d4ed8; background:#dbeafe; padding:4px 10px; border-radius:20px; }
    .od-subhod-tabs { display:flex; flex-wrap:nowrap; gap:8px; overflow-x:auto; padding-bottom:14px; margin-bottom:14px; border-bottom:1.5px solid #e2e8f0; scrollbar-width:thin; }
    .od-shod-tab { flex-shrink:0; padding:10px 14px; border-radius:10px; border:1.5px solid #e2e8f0; background:#fff; cursor:pointer; text-align:left; min-width:130px; transition:all .15s; }
    .od-shod-tab:hover { border-color:#7c3aed; background:#faf5ff; }
    .od-shod-tab.active { border-color:#7c3aed; background:#ede9fe; }
    .od-shod-tab-name { font-size:12px; font-weight:700; color:#0f172a; }
    .od-shod-tab.active .od-shod-tab-name { color:#7c3aed; }
    .od-shod-tab-sub { font-size:10px; color:#64748b; font-weight:600; margin-top:2px; }
    .od-shod-tab.active .od-shod-tab-sub { color:#7c3aed; }
    .od-shod-tab-stats { font-size:10px; color:#94a3b8; font-weight:600; margin-top:4px; }

    /* Executive management layout */
    .od-root {
        background:#f4f7fb;
        color:#111827;
    }
    .od-header {
        position:sticky; top:0; z-index:100;
        grid-template-columns:minmax(340px,1fr) auto;
        padding:16px 28px;
        background:rgba(255,255,255,.96);
        border-bottom:1px solid #d9e2ef;
        box-shadow:0 8px 22px rgba(17,24,39,.07);
        backdrop-filter:blur(10px);
    }
    .od-logo { width:44px; height:44px; border-radius:6px; background:#102a43; box-shadow:none; }
    .od-hd-kicker { color:#0f766e; letter-spacing:.9px; }
    .od-hd-title { font-size:20px; color:#111827; letter-spacing:0; }
    .od-hd-sub { color:#667085; }
    .od-hd-right {
        background:#f8fafc; border:1px solid #d9e2ef; border-radius:8px; padding:8px;
        align-items:end;
    }
    .od-filter-label { color:#667085; letter-spacing:.55px; }
    .od-period-group { background:#edf2f7; border-radius:7px; }
    .od-period-btn { border-radius:5px; min-height:34px; color:#475467; }
    .od-period-btn.active,.od-period-btn:hover { background:#fff; color:#102a43; box-shadow:0 1px 4px rgba(17,24,39,.12); }
    .od-date-input { border-radius:6px; border-color:#cbd5e1; height:38px; }
    .od-btn { height:38px; border-radius:6px; }
    .od-btn-primary { background:#102a43; box-shadow:none; }
    .od-btn-primary:hover { background:#173b5c; transform:none; }

    .od-body { padding:24px 28px 32px; max-width:1600px; }
    .od-exec-band {
        display:grid; grid-template-columns:minmax(280px,1fr) minmax(360px,.9fr);
        gap:20px; align-items:stretch; margin-bottom:18px;
    }
    .od-exec-intro,
    .od-exec-snapshot {
        background:#fff; border:1px solid #d9e2ef; border-radius:8px;
        box-shadow:0 10px 24px rgba(17,24,39,.06);
    }
    .od-exec-intro { padding:20px 22px; display:flex; flex-direction:column; justify-content:center; }
    .od-exec-eyebrow { font-size:10px; font-weight:850; letter-spacing:.8px; text-transform:uppercase; color:#0f766e; }
    .od-exec-title { margin-top:6px; font-size:24px; font-weight:850; color:#111827; line-height:1.2; }
    .od-exec-copy { margin-top:6px; font-size:12px; line-height:1.55; color:#667085; font-weight:600; max-width:760px; }
    .od-exec-snapshot { display:grid; grid-template-columns:repeat(3,1fr); overflow:hidden; }
    .od-snapshot-cell { padding:18px; border-left:1px solid #edf2f7; }
    .od-snapshot-cell:first-child { border-left:0; }
    .od-snapshot-label { display:block; font-size:10px; font-weight:850; text-transform:uppercase; color:#667085; letter-spacing:.45px; }
