        .od-owner-filters,
        .od-owner-filter-group { align-items:stretch; }
        .od-filter-block,
        .od-btn-primary { width:100%; }
        .od-date-range { display:grid; grid-template-columns:1fr auto 1fr; }
        .od-hier { grid-template-columns:1fr; }
        .od-dept-panel,
        .od-hod-panel { position:static; max-height:none; }
    }
</style>

