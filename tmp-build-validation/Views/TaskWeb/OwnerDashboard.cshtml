<script>
    const _apiTask      = '/api/task/GetOwnerDashboard';
    const _apiHierarchy = '/api/task/GetDeptHierarchy';
    const _apiDepts     = '/api/Hierarchy/GetDepartments';
    const _apiHodTree   = '/api/Hierarchy/GetHierarchyTree';
    const _apiAllTasks  = '/api/task/GetAllTasks';
    const DOT_COLORS    = ['#123f6d','#2563eb','#0d9488','#7c3aed','#db2777','#d97706','#059669','#dc2626','#0891b2','#65a30d','#b45309','#be185d'];
    const AV_COLORS     = ['#123f6d','#2563eb','#0d9488','#7c3aed','#db2777','#d97706','#059669','#dc2626'];

    let _fromDate = null, _toDate = null;
    let _allDepts = [];
    let _allHods = [];
    let _taskByDept = {};
    let _teamStats = null;
    let _selectedHodId = null;
    let _selectedDeptId = null;
    let _subHodGroups      = [];   // [{ hod, subHod, executives, hodName, subDeptName }]
    let _selectedSubHodIdx = -1;  // -1 = All, 0+ = specific group index
    let _hodNames          = [];  // HOD display names for info bar
    let _memberById        = new Map();
    let _drawerTasks       = [];
    let _inlineTasks       = [];
    let _collapsedHods     = new Set();
    let _collapsedSubHods  = new Set();

    document.addEventListener('DOMContentLoaded', () => {
        renderOwnerStatCards();
        setOwnerBannerDate();
        setPeriod('month');
    });

    function renderOwnerStatCards() {
        const row = document.querySelector('.od-stat-row');
        if (!row) return;
        row.insertAdjacentHTML('beforebegin', `
            <div class="od-simple-summary" id="briefText">Loading task summary...</div>`);
        row.className = 'od-stat-row td-stats-row';
        row.innerHTML = `
            <div class="td-stat-card td-stat-total od-simple-stat">
                <div class="td-stat-icon"><i class="fas fa-tasks"></i></div>
                <div class="td-stat-info">
                    <div class="td-stat-num" id="s-total">0</div>
                    <div class="td-stat-label">Total</div>
                    <div class="od-stat-help">All tasks</div>
                </div>
            </div>
            <div class="td-stat-card td-stat-pending od-simple-stat">
                <div class="td-stat-icon"><i class="fas fa-clock"></i></div>
                <div class="td-stat-info">
                    <div class="td-stat-num" id="s-pending">0</div>
                    <div class="td-stat-label">Pending</div>
                    <div class="od-stat-help">Not started</div>
                </div>
            </div>
            <div class="td-stat-card td-stat-progress od-simple-stat">
                <div class="td-stat-icon"><i class="fas fa-spinner"></i></div>
                <div class="td-stat-info">
                    <div class="td-stat-num" id="s-progress">0</div>
                    <div class="td-stat-label">Working</div>
                    <div class="od-stat-help">In progress</div>
                </div>
            </div>
            <div class="td-stat-card td-stat-completed od-simple-stat">
                <div class="td-stat-icon"><i class="fas fa-check-circle"></i></div>
                <div class="td-stat-info">
                    <div class="td-stat-num" id="s-done">0</div>
                    <div class="td-stat-label">Done</div>
                    <div class="od-stat-help">Completed</div>
                </div>
            </div>
            <div class="td-stat-card td-stat-overdue od-simple-stat">
                <div class="td-stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="td-stat-info">
                    <div class="td-stat-num" id="s-overdue">0</div>
                    <div class="td-stat-label">Overdue</div>
                    <div class="od-stat-help">Needs attention</div>
                </div>
            </div>`;

        const kpiCards = [
            { selector: '.td-stat-total', status: '', label: 'Total Tasks' },
            { selector: '.td-stat-pending', status: 'PENDING', label: 'Pending Tasks' },
            { selector: '.td-stat-progress', status: 'IN PROGRESS', label: 'In Progress Tasks' },
            { selector: '.td-stat-completed', status: 'COMPLETED', label: 'Completed Tasks' },
            { selector: '.td-stat-overdue', status: 'OVERDUE', label: 'Overdue Tasks' }
        ];

        kpiCards.forEach(card => {
            const el = row.querySelector(card.selector);
            if (!el) return;
            el.setAttribute('role', 'button');
            el.setAttribute('tabindex', '0');
            el.setAttribute('title', `View ${card.label}`);
            el.addEventListener('click', () => {
                if (card.status === 'DEPARTMENTS') openActiveDepartments();
                else openKpiTasks(card.status, card.label);
            });
            el.addEventListener('keydown', event => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    if (card.status === 'DEPARTMENTS') openActiveDepartments();
                    else openKpiTasks(card.status, card.label);
                }
            });
        });
    }

    function setOwnerBannerDate() {
        const el = document.getElementById('ownerBannerDate');
        if (!el) return;
        el.textContent = new Date().toLocaleDateString('en-IN', {
            day: '2-digit',
            month: 'short',
            year: 'numeric'
        });
    }

    // ── Period ──────────────────────────────────────────────────────
    function setPeriod(p) {
        document.querySelectorAll('.od-period-btn').forEach(b => b.classList.remove('active'));
        const btn = document.querySelector(`[data-p="${p}"]`);
        if (btn) btn.classList.add('active');
        const today = new Date(), fmt = d => d.toISOString().split('T')[0];
        if (p === 'today')  { _fromDate = _toDate = fmt(today); }
        else if (p === 'week')  { const m=new Date(today); m.setDate(today.getDate()-((today.getDay()+6)%7)); _fromDate=fmt(m);_toDate=fmt(today); }
        else if (p === 'month') { _fromDate=fmt(new Date(today.getFullYear(),today.getMonth(),1)); _toDate=fmt(today); }
        else if (p === 'all')   { _fromDate=null;_toDate=null; document.getElementById('odFrom').value=''; document.getElementById('odTo').value=''; }
        else if (p === 'custom'){ _fromDate=document.getElementById('odFrom').value||null; _toDate=document.getElementById('odTo').value||null; }
        if (p!=='custom'&&p!=='all') { document.getElementById('odFrom').value=_fromDate||''; document.getElementById('odTo').value=_toDate||''; }
        _selectedDeptId = null;
        loadAll();
    }

    // ── Load everything ─────────────────────────────────────────────
    async function loadAll() {
        document.getElementById('deptList').innerHTML = '<div class="od-empty">Select a HOD first.</div>';
        document.getElementById('hodList').innerHTML = '<div class="od-spin-wrap"><div class="od-spinner"></div></div>';
        resetDetail();

        try {
            const params = new URLSearchParams();
            if (_fromDate) params.set('fromDate', _fromDate);
            if (_toDate)   params.set('toDate',   _toDate);

            const [taskRes, deptRes] = await Promise.all([
                fetch(`${_apiTask}?${params}`).then(r => r.json()),
                fetch(_apiDepts).then(r => r.json())
            ]);

            // Parse task data
            const taskData = taskRes.data ?? taskRes.Data ?? taskRes;
            _teamStats = taskData || {};
            renderStats(_teamStats);

            // Build dept→task map from task response
            _taskByDept = {};
            const taskDepts = taskData.departments ?? taskData.Departments ?? [];
            taskDepts.forEach(d => {
                const id = d.deptId ?? d.DeptId ?? 0;
                _taskByDept[id] = d;
            });

            // Parse all departments from hierarchy
            const hierDepts = deptRes.data ?? deptRes.Data ?? [];

            // Merge: all hierarchy depts + any task-depts not in hierarchy
            const hierIds = new Set(hierDepts.map(d => d.departmentId ?? d.DepartmentId ?? 0));
            _allDepts = hierDepts.map(d => ({
                id:   d.departmentId ?? d.DepartmentId ?? 0,
                name: d.departmentName ?? d.DepartmentName ?? '—'
            }));

            // Add any task-dept not in hierarchy (e.g. "No Department" if tasks have no dept)
            taskDepts.forEach(td => {
                const id = td.deptId ?? td.DeptId ?? 0;
                if (!hierIds.has(id)) {
                    _allDepts.push({ id, name: td.deptName ?? td.DeptName ?? 'No Department' });
                }
            });

            // Sort: depts with tasks first, then alphabetical
            _allDepts.sort((a, b) => {
                const aHas = !!_taskByDept[a.id], bHas = !!_taskByDept[b.id];
                if (aHas !== bHas) return aHas ? -1 : 1;
                return a.name.localeCompare(b.name);
            });

            const allDeptHierarchies = await loadAllDeptHierarchies(_allDepts);
            buildHodListFromDeptHierarchies(allDeptHierarchies);
            renderHodList();
            document.getElementById('deptCount').textContent = '0 depts';

            if (_selectedHodId !== null && _allHods.some(h => h.id === _selectedHodId)) {
                setTimeout(() => selectHod(_selectedHodId), 50);
            }

        } catch(e) {
            console.error('Dashboard load error:', e);
            document.getElementById('deptList').innerHTML = '<div class="od-empty">Error loading data.</div>';
            document.getElementById('hodList').innerHTML = '<div class="od-empty">Error loading HODs.</div>';
        }
    }

    // ── Stat cards ──────────────────────────────────────────────────
    function renderStats(d) {
        const total = d.totalTasks ?? d.TotalTasks ?? 0;
        const pending = d.pendingCount ?? d.PendingCount ?? 0;
        const inProgress = d.inProgressCount ?? d.InProgressCount ?? 0;
        const done = d.completedCount ?? d.CompletedCount ?? 0;
        const overdue = d.overdueCount ?? d.OverdueCount ?? 0;
        const completionRate = total > 0 ? Math.round(done / total * 100) : 0;
        const riskRate = total > 0 ? Math.round(overdue / total * 100) : 0;

        setText('s-total', total);
        setText('s-pending', pending);
        setText('s-progress', inProgress);
        setText('s-done', done);
        setText('s-overdue', overdue);
        setText('briefText', getSimpleSummary(total, pending, inProgress, done, overdue));
    }

    function getSimpleSummary(total, pending, inProgress, done, overdue) {
        if (total === 0) {
            return 'No tasks found for this selected period.';
        }
        return `${total} total tasks: ${pending} pending, ${inProgress} working, ${done} done, ${overdue} overdue.`;
    }

    function getHodTeamStats(hod) {
        const departments = hod?.departments ?? [];
        if (!departments.length) return _teamStats || {};

        return departments.reduce((stats, dept) => {
            const summary = dept.teamStats || _taskByDept[dept.id] || dept || {};
            stats.totalTasks += summary.totalTasks ?? summary.TotalTasks ?? 0;
            stats.pendingCount += summary.pendingCount ?? summary.PendingCount ?? 0;
            stats.inProgressCount += summary.inProgressCount ?? summary.InProgressCount ?? 0;
            stats.completedCount += summary.completedCount ?? summary.CompletedCount ?? 0;
            stats.overdueCount += summary.overdueCount ?? summary.OverdueCount ?? 0;
            return stats;
        }, {
            totalTasks: 0,
            pendingCount: 0,
            inProgressCount: 0,
            completedCount: 0,
            overdueCount: 0
        });
    }

    // ── Dept list (left sidebar) ────────────────────────────────────
    function sumHierarchyNodeStats(node) {
        const stats = {
            totalTasks: node?.totalTasks ?? node?.TotalTasks ?? 0,
            pendingCount: node?.pendingCount ?? node?.PendingCount ?? 0,
            inProgressCount: node?.inProgressCount ?? node?.InProgressCount ?? 0,
            completedCount: node?.completedCount ?? node?.CompletedCount ?? 0,
            overdueCount: node?.overdueCount ?? node?.OverdueCount ?? 0
        };

        (node?.children ?? node?.Children ?? []).forEach(child => {
            const childStats = sumHierarchyNodeStats(child);
            stats.totalTasks += childStats.totalTasks;
            stats.pendingCount += childStats.pendingCount;
            stats.inProgressCount += childStats.inProgressCount;
            stats.completedCount += childStats.completedCount;
            stats.overdueCount += childStats.overdueCount;
        });

        return stats;
    }

    async function loadAllDeptHierarchies(depts) {
        const validDepts = (depts || []).filter(d => d.id > 0);
        const results = await Promise.all(validDepts.map(async dept => {
            try {
                const res = await fetch(_apiHierarchy, {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify({ deptId: dept.id, fromDate: _fromDate, toDate: _toDate })
                });
                const json = await res.json();
                return json.data ?? json.Data ?? null;
            } catch {
                return null;
            }
        }));
        return results.filter(Boolean);
    }

    function buildHodListFromDeptHierarchies(hierarchies) {
        const hodMap = new Map();

        (hierarchies || []).forEach(hierarchy => {
            const deptId = Number(hierarchy.deptId ?? hierarchy.DeptId ?? 0);
            const deptName = hierarchy.deptName ?? hierarchy.DeptName ?? 'Department';
            const hods = hierarchy.hods ?? hierarchy.Hods ?? [];

            hods.forEach(hod => {
                const id = Number(hod.employeeId ?? hod.EmployeeId ?? 0);
                const name = hod.employeeName ?? hod.EmployeeName ?? 'HOD';
                const key = id > 0 ? `id:${id}` : `name:${normalizeCompare(name)}`;
                if (!hodMap.has(key)) {
                    hodMap.set(key, {
                        id,
                        name,
                        code: hod.employeeCode ?? hod.EmployeeCode ?? '',
                        designation: hod.roleName ?? hod.RoleName ?? 'HOD',
                        departmentCount: 0,
                        subHodCount: 0,
                        executiveCount: 0,
                        departments: [],
                        color: DOT_COLORS[hodMap.size % DOT_COLORS.length]
                    });
                }

                const item = hodMap.get(key);
                if (!item.departments.some(d => d.id === deptId)) {
                    const subHods = (hod.children ?? hod.Children ?? []).filter(n => Number(n.roleTypeId ?? n.RoleTypeId ?? 0) === 2);
                    const directExecs = (hod.children ?? hod.Children ?? []).filter(n => Number(n.roleTypeId ?? n.RoleTypeId ?? 0) === 3);
                    const nestedExecs = subHods.reduce((sum, sub) => sum + ((sub.children ?? sub.Children ?? []).length), 0);
                    const summary = _taskByDept[deptId] || {};
                    const teamStats = sumHierarchyNodeStats(hod);
                    item.departments.push({
                        id: deptId,
                        name: deptName,
                        teamStats,
                        totalTasks: summary.totalTasks ?? summary.TotalTasks ?? hierarchy.totalTasks ?? hierarchy.TotalTasks ?? 0,
                        pendingCount: summary.pendingCount ?? summary.PendingCount ?? hierarchy.pendingCount ?? hierarchy.PendingCount ?? 0,
                        inProgressCount: summary.inProgressCount ?? summary.InProgressCount ?? hierarchy.inProgressCount ?? hierarchy.InProgressCount ?? 0,
                        completedCount: summary.completedCount ?? summary.CompletedCount ?? hierarchy.completedCount ?? hierarchy.CompletedCount ?? 0,
                        overdueCount: summary.overdueCount ?? summary.OverdueCount ?? hierarchy.overdueCount ?? hierarchy.OverdueCount ?? 0,
                        subHodCount: subHods.length,
                        executiveCount: directExecs.length + nestedExecs
                    });
                    item.subHodCount += subHods.length;
                    item.executiveCount += directExecs.length + nestedExecs;
                }
            });
        });

        _allHods = Array.from(hodMap.values())
            .map(h => ({ ...h, departmentCount: h.departments.length }))
            .sort((a, b) => a.name.localeCompare(b.name));

        const countEl = document.getElementById('hodCount');
        if (countEl) countEl.textContent = _allHods.length + ' HOD' + (_allHods.length !== 1 ? 's' : '');
    }

    function buildHodListFromHierarchyTree(hodTree) {
        const hods = hodTree || [];

        _allHods = hods.map((hod, idx) => {
            const departments = (hod.departments ?? hod.Departments ?? [])
                .map(dept => {
                    const id = Number(dept.departmentId ?? dept.DepartmentId ?? 0);
                    const summary = _taskByDept[id] || {};
                    return {
                        id,
                        name: dept.departmentName ?? dept.DepartmentName ?? 'Department',
                        totalTasks: summary.totalTasks ?? summary.TotalTasks ?? 0,
                        pendingCount: summary.pendingCount ?? summary.PendingCount ?? 0,
                        inProgressCount: summary.inProgressCount ?? summary.InProgressCount ?? 0,
                        completedCount: summary.completedCount ?? summary.CompletedCount ?? 0,
                        overdueCount: summary.overdueCount ?? summary.OverdueCount ?? 0,
                        subHodCount: 0,
                        executiveCount: 0
                    };
                })
                .filter(dept => dept.id > 0);

            const deptById = new Map(departments.map(dept => [dept.id, dept]));
            const subHods = hod.subHODs ?? hod.SubHODs ?? hod.subHods ?? hod.SubHods ?? [];
            let executiveCount = 0;

            subHods.forEach(subHod => {
                const deptId = Number(subHod.departmentId ?? subHod.DepartmentId ?? 0);
                const executives = subHod.executives ?? subHod.Executives ?? [];
                executiveCount += executives.length;

                if (!deptById.has(deptId) && deptId > 0) {
                    const summary = _taskByDept[deptId] || {};
                    const dept = {
                        id: deptId,
                        name: subHod.departmentName ?? subHod.DepartmentName ?? 'Department',
                        totalTasks: summary.totalTasks ?? summary.TotalTasks ?? 0,
                        pendingCount: summary.pendingCount ?? summary.PendingCount ?? 0,
                        inProgressCount: summary.inProgressCount ?? summary.InProgressCount ?? 0,
                        completedCount: summary.completedCount ?? summary.CompletedCount ?? 0,
                        overdueCount: summary.overdueCount ?? summary.OverdueCount ?? 0,
                        subHodCount: 0,
                        executiveCount: 0
                    };
                    departments.push(dept);
                    deptById.set(deptId, dept);
                }

                const dept = deptById.get(deptId);
                if (dept) {
                    dept.subHodCount += 1;
                    dept.executiveCount += executives.length;
                }
            });

            departments.sort((a, b) => {
                const taskDiff = (b.totalTasks || 0) - (a.totalTasks || 0);
                return taskDiff || a.name.localeCompare(b.name);
            });

            return {
                id: Number(hod.employeeId ?? hod.EmployeeId ?? 0),
                name: hod.employeeName ?? hod.EmployeeName ?? 'HOD',
                code: hod.employeeCode ?? hod.EmployeeCode ?? '',
                designation: hod.designation ?? hod.Designation ?? hod.roleName ?? hod.RoleName ?? 'HOD',
                departmentCount: departments.length,
                subHodCount: subHods.length,
                executiveCount,
                departments,
                color: DOT_COLORS[idx % DOT_COLORS.length]
            };
        }).sort((a, b) => a.name.localeCompare(b.name));

        const countEl = document.getElementById('hodCount');
        if (countEl) countEl.textContent = _allHods.length + ' HOD' + (_allHods.length !== 1 ? 's' : '');
    }

