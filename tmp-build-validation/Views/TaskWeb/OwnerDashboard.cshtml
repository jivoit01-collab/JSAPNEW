    // ── Load hierarchy: fetch tree → flatten to SubHOD groups ──────
    async function loadHierarchy(deptId) {
        try {
            const res  = await fetch(_apiHierarchy, {
                method: 'POST',
                headers: {'Content-Type':'application/json'},
                body: JSON.stringify({ deptId, fromDate: _fromDate, toDate: _toDate })
            });
            const json = await res.json();
            const hierarchy = json.data ?? json.Data;

            let hods = hierarchy?.hods ?? hierarchy?.Hods ?? [];
            if (_selectedHodId) {
                hods = hods.filter(h => Number(h.employeeId ?? h.EmployeeId ?? 0) === Number(_selectedHodId));
            }
            _hodNames  = hods.map(h => h.employeeName || h.EmployeeName || '').filter(Boolean);
            buildSubHodGroups(hods);
            _selectedSubHodIdx = -1;
            renderHierarchyPanel();
        } catch(e) {
            const g = document.getElementById('execGrid');
            if (g) g.innerHTML = '<div class="od-empty" style="grid-column:1/-1">Error loading hierarchy.</div>';
        }
    }

    // ── Flatten HOD tree into SubHOD groups ─────────────────────────
    async function syncHierarchyTaskCounts(hierarchy) {
        if (!hierarchy || !_selectedDeptId) return;

        try {
            const tasks = applyCurrentDateRange(await postTaskSearch({
                page: 1,
                limit: 99999,
                deptId: _selectedDeptId,
                viewMode: 'ALL',
                sortBy: 'expected_end_date',
                sortOrder: 'ASC'
            }));

            const byId = new Map();
            const byCode = new Map();
            const byName = new Map();
            tasks.forEach(task => {
                const id = Number(task.assignedToEmployeeId ?? task.AssignedToEmployeeId ?? 0);
                const code = normalizeCompare(task.assignedToCode ?? task.AssignedToCode);
                const name = normalizeCompare(task.assignedTo ?? task.AssignedTo);

                if (id > 0) {
                    if (!byId.has(id)) byId.set(id, []);
                    byId.get(id).push(task);
                }

                if (code) {
                    if (!byCode.has(code)) byCode.set(code, []);
                    byCode.get(code).push(task);
                }

                if (name) {
                    if (!byName.has(name)) byName.set(name, []);
                    byName.get(name).push(task);
                }
            });

            walkHierarchyNodes(hierarchy.hods ?? hierarchy.Hods ?? [], node => {
                const id = Number(node.employeeId ?? node.EmployeeId ?? 0);
                const code = normalizeCompare(node.employeeCode ?? node.EmployeeCode);
                const name = normalizeCompare(node.employeeName ?? node.EmployeeName);
                const nodeTasks = (id > 0 && byId.get(id)) || (code && byCode.get(code)) || (name && byName.get(name)) || [];
                applyTaskCountsToNode(node, nodeTasks);
            });
        } catch (e) {
            console.warn('Unable to sync hierarchy task counts:', e);
        }
    }

    function walkHierarchyNodes(nodes, visit) {
        (nodes || []).forEach(node => {
            visit(node);
            walkHierarchyNodes(node.children ?? node.Children ?? [], visit);
        });
    }

    function applyTaskCountsToNode(node, tasks) {
        const total = tasks.length;
        const pending = tasks.filter(t => isPendingLikeStatus(t.status ?? t.Status)).length;
        const inProgress = tasks.filter(t => normalizeStatus(t.status ?? t.Status) === 'IN PROGRESS').length;
        const completed = tasks.filter(t => {
            const status = normalizeStatus(t.status ?? t.Status);
            return status === 'COMPLETED' || status === 'COMPLETED AHEAD';
        }).length;
        const overdue = tasks.filter(t => normalizeStatus(t.status ?? t.Status) === 'OVERDUE').length;
        const avgProgress = total
            ? Math.round((tasks.reduce((sum, t) => sum + Number(t.percentComplete ?? t.PercentComplete ?? 0), 0) / total) * 10) / 10
            : 0;
        const completionRate = total ? Math.round(completed / total * 100) : 0;

        node.totalTasks = node.TotalTasks = total;
        node.pendingCount = node.PendingCount = pending;
        node.inProgressCount = node.InProgressCount = inProgress;
        node.completedCount = node.CompletedCount = completed;
        node.overdueCount = node.OverdueCount = overdue;
        node.avgProgress = node.AvgProgress = avgProgress;
        node.completionRate = node.CompletionRate = completionRate;
    }

    function nodeName(node) {
        return (node?.employeeName ?? node?.EmployeeName ?? '').trim();
    }

    function buildSubHodGroups(hods) {
        _subHodGroups = [];
        hods.forEach(hod => {
            const hodName = nodeName(hod);
            const children = hod.children || hod.Children || [];
            const subHods = children.filter(n => (n.roleTypeId ?? n.RoleTypeId) === 2);
            const directMembers = children.filter(n => (n.roleTypeId ?? n.RoleTypeId) !== 2);

            subHods.forEach(subHod => {
                const executives  = subHod.children || subHod.Children || [];
                const subDeptName = subHod.subDepartmentName || subHod.SubDepartmentName
                                    || subHod.employeeName   || subHod.EmployeeName || 'Sub-HOD';
                _subHodGroups.push({ hod, subHod, executives, hodName, subDeptName });
            });

            if (directMembers.length) {
                _subHodGroups.push({
                    hod,
                    subHod: null,
                    executives: directMembers,
                    hodName,
                    subDeptName: subHods.length ? 'Direct Reports' : 'HOD'
                });
            }

            if (!subHods.length && !directMembers.length) {
                _subHodGroups.push({
                    hod,
                    subHod: null,
                    executives: [],
                    hodName,
                    subDeptName: 'HOD'
                });
            }
        });
        // Fallback: no SubHODs found — surface HODs directly as employees
        if (_subHodGroups.length === 0 && hods.length > 0) {
            _subHodGroups.push({ hod: null, subHod: null, executives: hods, hodName: '', subDeptName: 'Direct' });
        }
    }

    // ── Render full hierarchy panel (HOD bar + tabs + exec cards) ──
    function renderHierarchyPanel() {
        const hodBar = document.getElementById('hodBar');
        if (hodBar) {
            hodBar.style.display = 'none';
        }

        const subHodTabs = document.getElementById('subHodTabs');
        if (subHodTabs) subHodTabs.style.display = 'none';

        const allMembers = getAllMembers();
        const cntEl = document.getElementById('empCount');
        if (cntEl) cntEl.textContent = allMembers.length + ' member' + (allMembers.length !== 1 ? 's' : '');
        renderEmployeeTaskSelector(allMembers);
    }

    function renderEmployeeTaskSelector(members) {
        const container = document.getElementById('execGrid');
        if (!container) return;
        container.className = '';
        _memberById = new Map();

        const options = (members || []).map((member, idx) => {
            const id = Number(member.employeeId ?? member.EmployeeId ?? 0);
            if (id > 0) {
                const name = member.employeeName ?? member.EmployeeName ?? 'Employee';
                const roleName = member.roleName ?? member.RoleName ?? (Number(member.roleTypeId ?? member.RoleTypeId ?? 0) === 1 ? 'HOD' : Number(member.roleTypeId ?? member.RoleTypeId ?? 0) === 2 ? 'Sub-HOD' : 'Executive');
                const subDept = member.subDepartmentName ?? member.SubDepartmentName ?? '';
                const total = member.totalTasks ?? member.TotalTasks ?? 0;
                const done = member.completedCount ?? member.CompletedCount ?? 0;
                const rate = Math.round(member.completionRate ?? member.CompletionRate ?? (total > 0 ? done / total * 100 : 0));
                _memberById.set(id, {
                    name,
                    employeeCode: member.employeeCode ?? member.EmployeeCode ?? '',
                    roleName,
                    subDept,
                    total,
                    rate
                });
                return `<option value="${id}">${esc(name)} - ${esc(roleName)}${subDept ? ` (${esc(subDept)})` : ''}</option>`;
            }
            return '';
        }).join('');

        container.innerHTML = `
            <div class="od-employee-picker">
                <label>
                    Employee List of Selected Department
                    <select id="ownerEmployeeSelect" onchange="onOwnerEmployeeChange()">
                        <option value="">Select employee</option>
                        ${options}
                    </select>
                </label>
                <span class="od-task-count" id="inlineTaskCount">Loading tasks...</span>
            </div>
            <div class="od-inline-task-list" id="inlineTaskList">
                <div class="od-spin-wrap"><div class="od-spinner"></div></div>
            </div>`;
        loadInlineDepartmentTasks();
    }

    async function onOwnerEmployeeChange() {
        const select = document.getElementById('ownerEmployeeSelect');
        const employeeId = Number(select?.value || 0);
        const list = document.getElementById('inlineTaskList');
        const count = document.getElementById('inlineTaskCount');
        if (!employeeId) {
            loadInlineDepartmentTasks();
            return;
        }

        const member = _memberById.get(employeeId) || {};
        if (count) count.textContent = 'Loading tasks...';
        if (list) list.innerHTML = '<div class="od-spin-wrap"><div class="od-spinner"></div></div>';

        try {
                _inlineTasks = await fetchEmployeeTasks(member, employeeId);
                if (count) count.textContent = `${_inlineTasks.length} task${_inlineTasks.length !== 1 ? 's' : ''}`;
                if (!list) return;
                list.innerHTML = _inlineTasks.length
                    ? _inlineTasks.map((task, index) => renderTaskDetailCard(task, index, 'inline')).join('')
                    : '<div class="od-empty">No tasks found for this employee.</div>';
        } catch {
            _inlineTasks = [];
            if (count) count.textContent = '0 tasks';
            if (list) list.innerHTML = '<div class="od-empty">Error loading task details.</div>';
        }
    }

    async function loadInlineDepartmentTasks() {
        const list = document.getElementById('inlineTaskList');
        const count = document.getElementById('inlineTaskCount');
        if (!_selectedDeptId) {
            _inlineTasks = [];
            if (count) count.textContent = '0 tasks';
            if (list) list.innerHTML = '<div class="od-empty">Select a department to view tasks.</div>';
            return;
        }

        if (count) count.textContent = 'Loading tasks...';
        if (list) list.innerHTML = '<div class="od-spin-wrap"><div class="od-spinner"></div></div>';

        try {
            _inlineTasks = applyCurrentDateRange(await postTaskSearch({
                page: 1,
                limit: 99999,
                deptId: _selectedDeptId,
                viewMode: 'ALL',
                sortBy: 'expected_end_date',
                sortOrder: 'ASC'
            }));
            renderInlineTaskList();
        } catch {
            _inlineTasks = [];
            if (count) count.textContent = '0 tasks';
            if (list) list.innerHTML = '<div class="od-empty">Error loading task details.</div>';
        }
    }

    function taskTotal(node) { return node?.totalTasks ?? node?.TotalTasks ?? 0; }
    function taskDone(node) { return node?.completedCount ?? node?.CompletedCount ?? 0; }
    function nodeKey(node) {
        const id = node?.employeeId ?? node?.EmployeeId ?? 0;
        const code = node?.employeeCode ?? node?.EmployeeCode ?? '';
        return id > 0 ? `id:${id}` : `code:${code}`;
    }
    function dedupeMembers(nodes) {
        const seen = new Set();
        return nodes.filter(node => {
            if (!node) return false;
            const key = nodeKey(node);
            if (seen.has(key)) return false;
            seen.add(key);
            return true;
        });
    }
    function getGroupMembers(group, includeHod = false) {
        const members = [];
        const hodName = group?.hodName || nodeName(group?.hod);
        const withHod = node => ({ ...node, _hodName: hodName, _parentHodName: hodName });
        if (includeHod && group?.hod) members.push(withHod(group.hod));
        if (group?.subHod) members.push(withHod(group.subHod));
        members.push(...(group?.executives ?? []).map(withHod));
        return dedupeMembers(members);
    }
    function getAllMembers() {
        const out = [];
        _subHodGroups.forEach(g => out.push(...getGroupMembers(g, true)));
        return dedupeMembers(out);
    }

    // ── Sub-HOD horizontal tabs ─────────────────────────────────────
    function renderSubHodTabs() {
        const container = document.getElementById('subHodTabs');
        if (!container) return;

        if (_subHodGroups.length === 0) {
            container.innerHTML = '<div class="od-empty">No sub-departments found.</div>';
            return;
        }

        // "All" tab aggregate stats
        const allMembers = getAllMembers();
        const allTotal = allMembers.reduce((s, e) => s + taskTotal(e), 0);
        const allDone  = allMembers.reduce((s, e) => s + taskDone(e), 0);
        const allRate  = allTotal > 0 ? Math.round(allDone / allTotal * 100) : 0;

        let html = `<button class="od-shod-tab ${_selectedSubHodIdx === -1 ? 'active' : ''}" onclick="selectSubHodTab(-1)">
            <div class="od-shod-tab-name">All</div>
            <div class="od-shod-tab-sub">${_subHodGroups.length} sub-dept${_subHodGroups.length !== 1 ? 's' : ''}</div>
            <div class="od-shod-tab-stats">${allMembers.length} member${allMembers.length !== 1 ? 's' : ''} · ${allRate}% done</div>
        </button>`;

        _subHodGroups.forEach((group, idx) => {
            const members     = getGroupMembers(group, true);
            const memberTotal = members.reduce((s, e) => s + taskTotal(e), 0);
            const memberDone  = members.reduce((s, e) => s + taskDone(e), 0);
            const rate        = memberTotal > 0 ? Math.round(memberDone / memberTotal * 100) : 0;
            html += `<button class="od-shod-tab ${_selectedSubHodIdx === idx ? 'active' : ''}" onclick="selectSubHodTab(${idx})">
                <div class="od-shod-tab-name">${esc(group.subDeptName)}</div>
                <div class="od-shod-tab-sub">Under: ${esc(group.hodName || '—')}</div>
                <div class="od-shod-tab-stats">${members.length} member${members.length !== 1 ? 's' : ''} · ${rate}% done</div>
            </button>`;
        });

        container.innerHTML = html;
    }

    function selectSubHodTab(idx) {
        _selectedSubHodIdx = idx;
        renderSubHodTabs();
        renderExecCards();
    }

    function renderMemberCard(node, i, hodNameOverride = '', extraClass = '') {
        const name     = node.employeeName    ?? node.EmployeeName    ?? 'Unknown';
        const roleType = node.roleTypeId      ?? node.RoleTypeId      ?? 0;
        const roleName = node.roleName        ?? node.RoleName        ?? (roleType === 1 ? 'HOD' : roleType === 2 ? 'Sub-HOD' : 'Executive');
        const subDept  = node.subDepartmentName ?? node.SubDepartmentName ?? '';
        const hodName  = roleType === 1 ? name : (hodNameOverride || node._hodName || node._parentHodName || '');
        const total    = node.totalTasks      ?? node.TotalTasks      ?? 0;
        const pend     = node.pendingCount    ?? node.PendingCount    ?? 0;
        const inP      = node.inProgressCount ?? node.InProgressCount ?? 0;
        const done     = node.completedCount  ?? node.CompletedCount  ?? 0;
        const over     = node.overdueCount    ?? node.OverdueCount    ?? 0;
        const rate     = Math.round(node.completionRate ?? node.CompletionRate ?? (total > 0 ? done / total * 100 : 0));
        const employeeId = node.employeeId ?? node.EmployeeId ?? 0;
        const employeeCode = node.employeeCode ?? node.EmployeeCode ?? '';
        if (employeeId > 0) {
            _memberById.set(employeeId, { name, employeeCode, roleName, subDept, hodName, total, pend, inP, done, over, rate });
        }

        const {cls, badge, barColor} = perfLabel(rate, over, total);
        const initials = name.split(' ').slice(0, 2).map(w => w[0] || '').join('').toUpperCase() || '?';
        const avatarColor = roleType === 1 ? '#123f6d' : roleType === 2 ? '#d97706' : AV_COLORS[i % AV_COLORS.length];

        return `<div class="od-emp-card ${cls} ${extraClass}" role="button" tabindex="0" onclick="openEmployeeTasks(${employeeId})" onkeydown="handleMemberCardKey(event, ${employeeId})" title="View task details">
            <div class="od-emp-head">
                <div class="od-emp-avatar" style="background:${avatarColor}">${esc(initials)}</div>
                <div style="flex:1;min-width:0">
                    <div class="od-emp-name">${esc(name)}</div>
                    <div style="display:flex;gap:5px;align-items:center;margin-top:3px;flex-wrap:wrap">
                        ${roleName ? `<span class="od-role-chip" style="background:#ccfbf1;color:#0d9488">👤 ${esc(roleName)}</span>` : ''}
                        ${hodName  ? `<span class="od-role-chip" style="background:#dbeafe;color:#1d4ed8">HOD: ${esc(hodName)}</span>` : ''}
                        ${subDept  ? `<span style="font-size:10px;color:#64748b;font-weight:600">· ${esc(subDept)}</span>` : ''}
                    </div>
                </div>
                <span class="od-emp-perf ${badge.cls}">${badge.icon} ${badge.label}</span>
            </div>
            <div class="od-emp-nums">
                <div class="od-num-cell"><span class="od-num-val">${total}</span><span class="od-num-lbl">Total</span></div>
                <div class="od-num-cell"><span class="od-num-val" style="color:#d97706">${pend}</span><span class="od-num-lbl">Pending</span></div>
                <div class="od-num-cell"><span class="od-num-val" style="color:#2563eb">${inP}</span><span class="od-num-lbl">In Prog</span></div>
                <div class="od-num-cell"><span class="od-num-val" style="color:#059669">${done}</span><span class="od-num-lbl">Done</span></div>
                <div class="od-num-cell"><span class="od-num-val" style="color:#dc2626">${over}</span><span class="od-num-lbl">Overdue</span></div>
            </div>
            <div class="od-emp-prog">
                <div class="od-emp-prog-track">
                    <div class="od-emp-prog-fill" style="width:${rate}%;background:${barColor}"></div>
                </div>
                <span class="od-emp-prog-pct" style="color:${barColor}">${rate}%</span>
            </div>
        </div>`;
    }

    // ── Hierarchy cards: HOD → Sub-HOD → Executives ────────────────
    function renderExecCards() {
        const grid = document.getElementById('execGrid');
        if (!grid) return;
        _memberById.clear();

        const members = getAllMembers();

        if (!members.length) {
            grid.innerHTML = `<div class="od-empty" style="grid-column:1/-1">
                <div style="font-size:32px;margin-bottom:8px">👤</div>
                No team members found.
            </div>`;
            return;
        }

        const byHod = new Map();
        _subHodGroups.forEach(group => {
            const hod = group.hod;
            const key = hod ? nodeKey(hod) : `hod:${group.hodName || 'unknown'}`;
            if (!byHod.has(key)) byHod.set(key, { hod, hodName: group.hodName || nodeName(hod), groups: [] });
            byHod.get(key).groups.push(group);
        });

        grid.className = 'od-tree-stack';
        grid.innerHTML = Array.from(byHod.values()).map((hodGroup, hodIdx) => {
            const hodName = hodGroup.hodName || 'HOD';
            const hodTreeKey = `hod-${hodIdx}-${treeKey(hodName)}`;
            const hodCollapsed = _collapsedHods.has(hodTreeKey);
            const hodCard = hodGroup.hod
                ? renderMemberCard(hodGroup.hod, hodIdx, hodName, 'hod-card')
                : `<div class="od-emp-card hod-card"><div class="od-emp-name">${esc(hodName)}</div></div>`;

            const subSections = hodGroup.groups.map((group, groupIdx) => {
                const subHod = group.subHod;
                const execs = group.executives ?? [];
                const title = subHod ? 'Sub-HOD' : 'Direct Executives';
                const subName = subHod ? nodeName(subHod) : title;
                const subTreeKey = `${hodTreeKey}-sub-${groupIdx}-${treeKey(subName)}`;
                const subCollapsed = _collapsedSubHods.has(subTreeKey);
                const subCard = subHod
                    ? renderMemberCard({ ...subHod, _hodName: hodName }, groupIdx, hodName, 'subhod-card')
                    : `<div class="od-subhod-title">${esc(title)}</div>`;

                const execHtml = execs.length
                    ? `<div class="od-exec-grid">${execs.map((ex, exIdx) => renderMemberCard({ ...ex, _hodName: hodName }, exIdx, hodName)).join('')}</div>`
                    : `<div class="od-empty" style="padding:18px">No executives found under this ${subHod ? 'Sub-HOD' : 'HOD'}.</div>`;

                return `<div class="od-subhod-section">
                    <div class="od-tree-head">
                        <button type="button" class="od-tree-toggle" aria-expanded="${!subCollapsed}" onclick="toggleSubHodSection(event, '${escAttr(subTreeKey)}')" title="${subCollapsed ? 'Expand' : 'Collapse'} ${escAttr(title)}">
                            <span class="od-tree-plus">+</span><span class="od-tree-minus">-</span>
                        </button>
                        <div>
                            <div class="od-subhod-title">${esc(title)}</div>
                            ${subCard}
                        </div>
                    </div>
                    <div class="od-tree-children" style="${subCollapsed ? 'display:none' : ''}">${execHtml}</div>
                </div>`;
            }).join('');

            return `<div class="od-hod-section">
                <div class="od-tree-head">
                    <button type="button" class="od-tree-toggle" aria-expanded="${!hodCollapsed}" onclick="toggleHodSection(event, '${escAttr(hodTreeKey)}')" title="${hodCollapsed ? 'Expand' : 'Collapse'} HOD">
                        <span class="od-tree-plus">+</span><span class="od-tree-minus">-</span>
                    </button>
                    ${hodCard}
                </div>
                <div class="od-subhod-list" style="${hodCollapsed ? 'display:none' : ''}">${subSections || '<div class="od-empty">No Sub-HODs or Executives found.</div>'}</div>
            </div>`;
        }).join('');
    }

    function toggleHodSection(event, key) {
        event?.stopPropagation();
        if (_collapsedHods.has(key)) _collapsedHods.delete(key);
        else _collapsedHods.add(key);
        renderExecCards();
    }

    function toggleSubHodSection(event, key) {
        event?.stopPropagation();
        if (_collapsedSubHods.has(key)) _collapsedSubHods.delete(key);
        else _collapsedSubHods.add(key);
        renderExecCards();
    }

    function handleMemberCardKey(event, employeeId) {
        if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            openEmployeeTasks(employeeId);
        }
    }

    async function openEmployeeTasks(employeeId) {
        if (!employeeId || employeeId <= 0) return;

        const member = _memberById.get(employeeId) || {};
        const overlay = document.getElementById('taskOverlay');
        const title = document.getElementById('taskDrawerTitle');
        const role = document.getElementById('taskDrawerRole');
        const sub = document.getElementById('taskDrawerSub');
        const list = document.getElementById('taskDrawerList');
        const count = document.getElementById('taskDrawerCount');
        const filter = document.getElementById('taskStatusFilter');

        if (filter) filter.value = '';
        if (title) title.textContent = member.name || 'Employee tasks';
        if (role) role.textContent = member.roleName || 'Team member';
        if (sub) sub.textContent = `${member.total ?? 0} total tasks · ${member.rate ?? 0}% completion`;
        if (count) count.textContent = 'Loading tasks...';
        if (list) list.innerHTML = '<div class="od-spin-wrap"><div class="od-spinner"></div></div>';
        if (overlay) overlay.classList.add('open');

        try {
            _drawerTasks = await fetchEmployeeTasks(member, employeeId);
            renderTaskDrawerList();
        } catch (e) {
            _drawerTasks = [];
            if (count) count.textContent = '0 tasks';
            if (list) list.innerHTML = '<div class="od-empty">Error loading task details.</div>';
        }
    }

    async function fetchEmployeeTasks(member, employeeId) {
        const request = {
            page: 1,
            limit: 500,
            assignedToEmployeeId: employeeId,
            deptId: _selectedDeptId || null,
            viewMode: 'ALL',
            sortBy: 'expected_end_date',
            sortOrder: 'ASC'
        };

        const directTasks = await postTaskSearch(request);
        const deptTasks = await postTaskSearch({
            page: 1,
            limit: 99999,
            deptId: _selectedDeptId || null,
            viewMode: 'ALL',
            sortBy: 'expected_end_date',
            sortOrder: 'ASC'
        });

        return mergeTasksById([
            ...directTasks,
            ...deptTasks.filter(task => taskBelongsToMember(task, member, employeeId))
        ]);
    }

    async function postTaskSearch(request) {
        const res = await fetch(_apiAllTasks, {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify(request)
        });
        const json = await res.json();
        return json.data ?? json.Data ?? [];
    }

    async function openKpiTasks(status, label) {
        const overlay = document.getElementById('taskOverlay');
        const title = document.getElementById('taskDrawerTitle');
        const role = document.getElementById('taskDrawerRole');
        const sub = document.getElementById('taskDrawerSub');
        const list = document.getElementById('taskDrawerList');
        const count = document.getElementById('taskDrawerCount');
        const filter = document.getElementById('taskStatusFilter');
        const dept = null;

        if (filter) filter.value = status || '';
        if (title) title.textContent = label || 'Task details';
        if (role) role.textContent = 'All tasks';
        if (sub) {
            const dateText = _fromDate || _toDate ? `${_fromDate || 'Start'} to ${_toDate || 'Today'}` : 'All time';
            sub.textContent = dept ? `${dept.name} · ${dateText}` : dateText;
        }
        if (count) count.textContent = 'Loading tasks...';
        if (list) list.innerHTML = '<div class="od-spin-wrap"><div class="od-spinner"></div></div>';
        if (overlay) overlay.classList.add('open');

        try {
            const tasks = applyCurrentDateRange(await postTaskSearch({
                page: 1,
                limit: 99999,
                viewMode: 'ALL',
                sortBy: 'expected_end_date',
                sortOrder: 'ASC'
            }));

            _drawerTasks = status
                ? tasks.filter(task => taskMatchesStatus(task, status))
                : tasks;
            renderTaskDrawerList();
        } catch (e) {
            _drawerTasks = [];
            if (count) count.textContent = '0 tasks';
            if (list) list.innerHTML = '<div class="od-empty">Error loading task details.</div>';
        }
    }

    function getCurrentTaskScopeDeptId() {
        if (_selectedDeptId) return _selectedDeptId;
        const activeDept = document.querySelector('.od-dept-item.active, .od-hod-dept.active');
        const deptId = Number(activeDept?.dataset?.id || 0);
        return deptId > 0 ? deptId : null;
    }

    function openActiveDepartments() {
        const overlay = document.getElementById('taskOverlay');
        const title = document.getElementById('taskDrawerTitle');
        const role = document.getElementById('taskDrawerRole');
        const sub = document.getElementById('taskDrawerSub');
        const list = document.getElementById('taskDrawerList');
        const count = document.getElementById('taskDrawerCount');
        const filter = document.getElementById('taskStatusFilter');

        const activeDepts = Object.values(_taskByDept || {})
            .filter(dept => (dept.totalTasks ?? dept.TotalTasks ?? 0) > 0)
            .sort((a, b) => (b.totalTasks ?? b.TotalTasks ?? 0) - (a.totalTasks ?? a.TotalTasks ?? 0));

        if (filter) filter.value = '';
        if (title) title.textContent = 'Active Departments';
        if (role) role.textContent = 'Department workload';
        if (sub) sub.textContent = _fromDate || _toDate ? `${_fromDate || 'Start'} to ${_toDate || 'Today'}` : 'All time';
        if (count) count.textContent = `${activeDepts.length} department${activeDepts.length !== 1 ? 's' : ''}`;
        if (list) {
            list.innerHTML = activeDepts.length
                ? activeDepts.map(renderDepartmentDetailCard).join('')
                : '<div class="od-empty">No active departments found.</div>';
        }
        if (overlay) overlay.classList.add('open');
    }

    function renderDepartmentDetailCard(dept) {
        const deptId = dept.deptId ?? dept.DeptId ?? 0;
        const deptName = dept.deptName ?? dept.DeptName ?? 'No Department';
        const total = dept.totalTasks ?? dept.TotalTasks ?? 0;
        const pending = dept.pendingCount ?? dept.PendingCount ?? 0;
        const inProgress = dept.inProgressCount ?? dept.InProgressCount ?? 0;
        const completed = dept.completedCount ?? dept.CompletedCount ?? 0;
        const overdue = dept.overdueCount ?? dept.OverdueCount ?? 0;
        const avgProgress = Math.round(dept.avgProgress ?? dept.AvgProgress ?? 0);

        return `<article class="od-task-card">
            <div class="od-task-card-top">
                <div>
                    <div class="od-task-name">${esc(deptName)}</div>
                    ${deptId ? `<div class="od-task-id">Department ID: ${esc(deptId)}</div>` : ''}
                </div>
                <div class="od-task-badges">
                    <span class="od-task-badge">${total} task${total !== 1 ? 's' : ''}</span>
                    <span class="od-task-badge">${avgProgress}% avg</span>
                </div>
            </div>
            <div class="od-task-meta">
                ${taskMeta('Active Dept', deptName)}
                ${taskMeta('Total', total)}
                ${taskMeta('Pending', pending)}
                ${taskMeta('In Progress', inProgress)}
                ${taskMeta('Completed', completed)}
                ${taskMeta('Overdue', overdue)}
            </div>
        </article>`;
    }

    function taskBelongsToMember(task, member, employeeId) {
        const memberCode = normalizeCompare(member.employeeCode);
        const taskCode = normalizeCompare(task.assignedToCode ?? task.AssignedToCode);
        if (memberCode && taskCode && memberCode === taskCode) return true;

        const createdByCode = normalizeCompare(task.createdByCode ?? task.CreatedByCode);
        if (memberCode && createdByCode && memberCode === createdByCode) return true;

        const memberName = normalizeCompare(member.name);
        const taskName = normalizeCompare(task.assignedTo ?? task.AssignedTo);
        if (memberName && taskName && memberName === taskName) return true;

        const createdByName = normalizeCompare(task.createdBy ?? task.CreatedBy);
        if (memberName && createdByName && memberName === createdByName) return true;

        const taskEmployeeId = Number(task.assignedToEmployeeId ?? task.AssignedToEmployeeId ?? 0);
        if (employeeId > 0 && taskEmployeeId > 0 && taskEmployeeId === employeeId) return true;

        const createdByEmployeeId = Number(task.createdByEmployeeId ?? task.CreatedByEmployeeId ?? 0);
        return employeeId > 0 && createdByEmployeeId > 0 && createdByEmployeeId === employeeId;
    }

    function mergeTasksById(tasks) {
        const seen = new Set();
        return (tasks || []).filter((task, index) => {
            const taskId = task.taskId ?? task.TaskId;
            const key = taskId ? `id:${taskId}` : `row:${index}`;
            if (seen.has(key)) return false;
            seen.add(key);
            return true;
        });
    }

    function closeTaskDrawer(event) {
        if (event && event.target?.id !== 'taskOverlay') return;
        const overlay = document.getElementById('taskOverlay');
        if (overlay) overlay.classList.remove('open');
    }

    function renderTaskDrawerList() {
        const list = document.getElementById('taskDrawerList');
        const count = document.getElementById('taskDrawerCount');
        const statusFilter = (document.getElementById('taskStatusFilter')?.value || '').toUpperCase();
        if (!list) return;

        let tasks = _drawerTasks;
        if (statusFilter) {
            tasks = tasks.filter(t => taskMatchesStatus(t, statusFilter));
        }

        if (count) count.textContent = `${tasks.length} task${tasks.length !== 1 ? 's' : ''}`;
        if (!tasks.length) {
            list.innerHTML = '<div class="od-empty">No tasks found for this selection.</div>';
            return;
        }

        list.innerHTML = tasks.map((task, index) => renderTaskDetailCard(task, index, 'drawer')).join('');
    }

    function renderTaskDetailCard(task, index = 0, source = 'drawer') {
        const name = task.taskName ?? task.TaskName ?? 'Untitled task';
        const activeDept = getTaskDeptName(task);

        return `<article class="od-task-card od-task-card-compact" role="button" tabindex="0" onclick="openTaskFullDetail('${source}', ${index})" onkeydown="handleTaskCardKey(event, '${source}', ${index})" title="Open task details">
            <div class="od-task-meta">
                ${taskMeta('Department', activeDept)}
                ${taskMeta('Task', name)}
            </div>
        </article>`;
    }

    function handleTaskCardKey(event, source, index) {
        if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            openTaskFullDetail(source, index);
        }
    }

    function openTaskFullDetail(source, index) {
        const tasks = source === 'inline' ? _inlineTasks : getVisibleDrawerTasks();
        const task = tasks[index];
        if (!task) return;

        const listId = source === 'inline' ? 'inlineTaskList' : 'taskDrawerList';
        const list = document.getElementById(listId);
        const count = source === 'inline' ? document.getElementById('inlineTaskCount') : document.getElementById('taskDrawerCount');

        if (count) count.textContent = 'Task detail';
        if (list) {
            list.innerHTML = `
                <div class="od-task-detail-actions">
                    <button type="button" class="od-task-back" onclick="${source === 'inline' ? 'renderInlineTaskList()' : 'renderTaskDrawerList()'}">&larr; Back to tasks</button>
                </div>
                ${renderTaskFullDetailCard(task)}`;
        }
    }

    function getVisibleDrawerTasks() {
        const statusFilter = (document.getElementById('taskStatusFilter')?.value || '').toUpperCase();
        return statusFilter
            ? _drawerTasks.filter(t => taskMatchesStatus(t, statusFilter))
            : _drawerTasks;
    }

    function renderInlineTaskList() {
        const list = document.getElementById('inlineTaskList');
        const count = document.getElementById('inlineTaskCount');
        if (count) count.textContent = `${_inlineTasks.length} task${_inlineTasks.length !== 1 ? 's' : ''}`;
        if (!list) return;
        list.innerHTML = _inlineTasks.length
            ? _inlineTasks.map((task, index) => renderTaskDetailCard(task, index, 'inline')).join('')
            : '<div class="od-empty">No tasks found for this employee.</div>';
    }

    function renderTaskFullDetailCard(task) {
        const taskId = task.taskId ?? task.TaskId ?? '';
        const name = task.taskName ?? task.TaskName ?? 'Untitled task';
        const desc = task.description ?? task.Description ?? 'No description added.';
        const status = normalizeStatus(task.status ?? task.Status);
        const priority = task.priority ?? task.Priority ?? 'Normal';
        const progress = task.percentComplete ?? task.PercentComplete ?? 0;
        const overdue = isTaskOverdue(task, status);
        const statusClass = overdue ? 'overdue' : status.includes('COMPLETED') ? 'completed' : status.includes('PROGRESS') ? 'progress' : 'pending';
        const executiveName = task.assignedTo ?? task.AssignedTo ?? 'Unassigned';
        const activeDept = getTaskDeptName(task);

        return `<article class="od-task-card">
            <div class="od-task-card-top">
                <div>
                    <div class="od-task-name">${esc(name)}</div>
                    ${taskId ? `<div class="od-task-id">${esc(taskId)}</div>` : ''}
                </div>
                <div class="od-task-badges">
                    <span class="od-task-badge ${statusClass}">${esc(overdue ? 'OVERDUE' : status || 'PENDING')}</span>
                    <span class="od-task-badge">${esc(priority)}</span>
                    <span class="od-task-badge">${progress}%</span>
                </div>
            </div>
            <div class="od-task-desc">${esc(desc)}</div>
            <div class="od-task-meta">
                ${taskMeta('Executive', executiveName)}
                ${taskMeta('Active Dept', activeDept)}
                ${taskMeta('Project', task.projectName ?? task.ProjectName)}
                ${taskMeta('Module', task.moduleName ?? task.ModuleName)}
                ${taskMeta('Type', task.taskType ?? task.TaskType)}
                ${taskMeta('Start', fmtDate(task.startDate ?? task.StartDate))}
                ${taskMeta('Due', fmtDate(task.expectedEndDate ?? task.ExpectedEndDate))}
                ${taskMeta('Completed', fmtDate(task.completionDate ?? task.CompletionDate))}
                ${taskMeta('Created by', task.createdBy ?? task.CreatedBy)}
                ${taskMeta('Assigned by', task.assignedByName ?? task.AssignedByName)}
                ${taskMeta('Last updated', fmtDate(task.lastModifiedOn ?? task.LastModifiedOn))}
            </div>
            ${(task.remarks ?? task.Remarks) ? `<div class="od-task-desc"><strong>Remarks:</strong> ${esc(task.remarks ?? task.Remarks)}</div>` : ''}
        </article>`;
    }

    function taskMeta(label, value) {
        return `<div class="od-task-meta-cell"><span class="od-task-meta-lbl">${esc(label)}</span><span class="od-task-meta-val">${esc(value || '-')}</span></div>`;
    }

    function getTaskDeptName(task) {
        const directName = task.deptName ?? task.DeptName;
        if (directName) return directName;

        const deptId = task.deptId ?? task.DeptId ?? 0;
        const summary = _taskByDept[deptId];
        const summaryName = summary?.deptName ?? summary?.DeptName;
        if (summaryName) return summaryName;

        const listedDept = _allDepts.find(d => Number(d.id) === Number(deptId));
        return listedDept?.name || 'No Department';
    }

    function taskMatchesStatus(task, expectedStatus) {
        const normalized = normalizeStatus(task.status ?? task.Status);
        if (expectedStatus === 'PENDING') return normalized === 'PENDING' || normalized === 'SUBMITTED';
        return expectedStatus === 'COMPLETED'
            ? normalized === 'COMPLETED' || normalized === 'COMPLETED AHEAD'
            : normalized === expectedStatus;
    }

    function applyCurrentDateRange(tasks) {
        if (!_fromDate && !_toDate) return tasks;
        const from = _fromDate ? new Date(_fromDate + 'T00:00:00') : null;
        const to = _toDate ? new Date(_toDate + 'T23:59:59') : null;
        return tasks.filter(task => {
            const raw = task.startDate ?? task.StartDate ?? task.createdOn ?? task.CreatedOn;
            if (!raw) return true;
            const date = new Date(raw);
            if (from && date < from) return false;
            if (to && date > to) return false;
            return true;
        });
    }

    function normalizeStatus(status) {
        return String(status || 'PENDING').replace(/_/g, ' ').trim().toUpperCase();
    }

    function isPendingLikeStatus(status) {
        const normalized = normalizeStatus(status);
        return normalized === 'PENDING' || normalized === 'SUBMITTED';
    }

    function normalizeCompare(value) {
        return String(value || '').trim().toUpperCase();
    }

    function isTaskOverdue(task, status) {
        if (status === 'COMPLETED') return false;
        const due = task.expectedEndDate ?? task.ExpectedEndDate;
        return due ? new Date(due) < new Date() : false;
    }

    function fmtDate(value) {
        if (!value) return '-';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return '-';
        return date.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' });
    }

    function perfLabel(rate, overdue, total) {
        if (total === 0) return { cls:'perf-none', badge:{cls:'none', icon:'—', label:'No Tasks'}, barColor:'#cbd5e1' };
        const highOverdue = overdue >= Math.ceil(total * 0.4);
        if (rate >= 75 && !highOverdue) return { cls:'perf-top',  badge:{cls:'top', icon:'⭐',label:'Top Performer'}, barColor:'#10b981' };
        if (rate >= 50 && !highOverdue) return { cls:'perf-good', badge:{cls:'good',icon:'👍',label:'On Track'},       barColor:'#3b82f6' };
        if (rate >= 25)                 return { cls:'perf-avg',  badge:{cls:'avg', icon:'⚠', label:'Needs Improvement'}, barColor:'#f59e0b' };
        return                                 { cls:'perf-risk', badge:{cls:'risk',icon:'🔴',label:'At Risk'},         barColor:'#ef4444' };
    }

    function resetDetail(message) {
        document.getElementById('detailPanel').innerHTML = `
            <div class="od-panel">
                <div class="od-placeholder">
                    <div class="od-placeholder-icon">🏢</div>
                    <div class="od-placeholder-txt">${_selectedHodId ? 'Select a department' : 'Select a HOD'}</div>
                    <div class="od-placeholder-sub">${message || 'Choose a HOD, then choose a department to review employees and task details.'}</div>
                </div>
            </div>`;
        _subHodGroups      = [];
        _selectedSubHodIdx = -1;
        _hodNames          = [];
        _collapsedHods     = new Set();
        _collapsedSubHods  = new Set();
    }

    function setText(id, val) { const el=document.getElementById(id); if(el) el.textContent=val; }
    function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function escAttr(s) { return esc(s).replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
    function treeKey(value) { return normalizeCompare(value).replace(/[^A-Z0-9]+/g, '-').replace(/^-|-$/g, '') || 'NODE'; }
</script>
