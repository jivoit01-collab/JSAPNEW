        if (ext === "pdf") {
            $("#viewerBody").html(`<iframe class="viewer-frame" src="/DocumentHub/Preview?fileId=${fileId}"></iframe>`);
        } else if (["png","jpg","jpeg","gif"].includes(ext)) {
            $("#viewerBody").html(`<div class="viewer-img-container"><img class="viewer-img" src="/DocumentHub/Preview?fileId=${fileId}" alt="${escAttr(file.fileName)}" /></div>`);
        // } else {
        //     $("#viewerBody").html(`
        //         <div class="p-4 bg-white text-dark">
        //             <h6 class="font-weight-bold mb-3"><i class="${fileIcon(ext)}"></i> ${escHtml(file.fileName)}</h6>
        //             <table class="table table-sm">
        //                 <tbody>
        //                     <tr><th>File Type</th><td>${escHtml(file.fileType)}</td></tr>
        //                     <tr><th>File Size</th><td>${fmtSize(file.fileSize)}</td></tr>
        //                     <tr><th>Uploaded By</th><td>${escHtml(file.uploadedBy)}</td></tr>
        //                     <tr><th>Uploaded Date</th><td>${fmtDate(file.uploadedDate)}</td></tr>
        //                     <tr><th>Version</th><td>v${file.versionNumber}</td></tr>
        //                 </tbody>
        //             </table>
        //             <p class="small text-muted mb-0">Preview is available for PDF and image files. Word and Excel documents are shown as metadata only.</p>
        //         </div>`);
        // }
        }
        else if (["doc","docx","xls","xlsx","csv","ppt","pptx"].includes(ext)) {
    window.open(`/DocumentHub/Preview?fileId=${fileId}`, "_blank");
    return;
}
        $("#viewerModal").modal("show");
    }

    /* ─────────────────────────────────────────────
       FOLDER PIN
    ───────────────────────────────────────────── */
    function submitFolderUnlock() {
        const folderId = $("#pinFolderId").val();
        const pin = $("#folderAccessPin").val().trim();
        if (!pin) return;
        $.post("/DocumentHub/ConfirmFolderAccess", { folderId, pin }).done(function (res) {
            if (res.success) {
                $("#folderPinModal").modal("hide");
                showToast("Access granted.", "success");
                requestLoadHub("submitFolderUnlock:success", { folderId });
            } else {
                $("#folderPinFeedback").show();
            }
        }).fail(() => showToast("Request failed.", "error"));
    }

    function cancelFolderUnlock() {
        $("#folderPinModal").modal("hide");
        goFolder(null);
    }

    /* ─────────────────────────────────────────────
       VERSION HISTORY
    ───────────────────────────────────────────── */
    function showVersions(fileId) {
        $.get("/DocumentHub/VersionHistory", { fileId }).done(function (res) {
            const rows = (res.data || []).map(v => `
                <tr>
                    <td class="small font-weight-bold">v${v.versionNumber}</td>
                    <td class="small">${escHtml(v.uploadedBy)}</td>
                    <td class="small text-muted">${fmtDate(v.uploadedDate)}</td>
                    <td class="small text-muted">${fmtSize(v.fileSize)}</td>
                    <td class="text-end">
                        ${hasDocumentHubPermission("versionRestore") ? `<button class="btn btn-warning text-dark btn-sm dh-version-restore-action" style="font-size:10px;padding:2px 6px;" onclick="restoreVersion(${fileId},${v.versionNumber})"><i class="fa-solid fa-rotate-left"></i> Restore</button>` : ""}
                    </td>
                </tr>`).join("");
            $("#listTitle").text("Version History");
            $("#listBody").html(`
                <div class="p-3">
                    <table class="table align-middle mb-0">
                        <thead class="table-light"><tr><th>Ver.</th><th>Uploaded By</th><th>Date</th><th>Size</th><th class="text-end">Action</th></tr></thead>
                        <tbody>${rows || '<tr><td colspan="5" class="text-center text-muted p-3 small">No previous versions</td></tr>'}</tbody>
                    </table>
                </div>`);
            $("#listModal").modal("show");
        });
