        if (canCreateFolders())
            m += `<li><a class="dropdown-item" onclick="openFolderModal('subfolder',${f.folderId})"><i class="fa-solid fa-folder-plus text-success"></i> Create Subfolder</a></li>`;
        if (hasDocumentHubPermission("rename"))
            m += `<li><a class="dropdown-item" onclick="openFolderModal('rename',${f.folderId},'${escAttr(f.folderName)}')"><i class="fa-solid fa-pen text-info"></i> Rename</a></li>
                  <li><a class="dropdown-item" onclick="openMoveModal('folder',${f.folderId})"><i class="fa-solid fa-arrows-up-down-left-right text-warning"></i> Move</a></li>`;
        if (hasDocumentHubPermission("confidential")) {
            m += `<li><a class="dropdown-item pin-admin-only" onclick="openPinManager('set',${f.folderId})"><i class="fa-solid fa-key text-warning"></i> Set PIN</a></li>
                  <li><a class="dropdown-item pin-admin-only" onclick="openPinManager('change',${f.folderId})"><i class="fa-solid fa-lock text-warning"></i> Change PIN</a></li>
                  <li><a class="dropdown-item pin-admin-only" onclick="openPinManager('reset',${f.folderId})"><i class="fa-solid fa-rotate text-warning"></i> Reset PIN</a></li>
                  <li><a class="dropdown-item pin-admin-only" onclick="openPinManager('remove',${f.folderId})"><i class="fa-solid fa-unlock text-warning"></i> Remove PIN</a></li>`;
        }
        m += `
              <li><a class="dropdown-item text-danger" onclick="deleteFolder(${f.folderId})"><i class="fa-solid fa-trash"></i> Delete Folder</a></li>`;
