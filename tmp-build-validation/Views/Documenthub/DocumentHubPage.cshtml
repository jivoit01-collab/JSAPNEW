    function openPinManager(mode, folderId) {
        if (!hasDocumentHubPermission("confidential")) {
            showToast("You do not have permission to manage confidential folders.", "error");
            return;
        }
        $("#pinManageFolderId").val(folderId);
        $("#pinManageMode").val(mode);
        $("#pinCurrent,#pinNew,#pinConfirm").val("");
        $(".pin-current-row").toggle(mode !== "set" && mode !== "reset");
        $(".pin-new-row").toggle(mode !== "remove" && mode !== "reset");
        $("#pinManageTitle").text(mode === "set" ? "Set Folder PIN" : (mode === "change" ? "Change Folder PIN" : (mode === "reset" ? "Reset Folder PIN" : "Remove Folder PIN")));
        $("#pinManageModal").modal("show");
    }

    function saveFolderPin() {
        if (!hasDocumentHubPermission("confidential")) {
            showToast("You do not have permission to manage confidential folders.", "error");
            return;
        }
        const mode = $("#pinManageMode").val();
        const folderId = parseNullInt($("#pinManageFolderId").val());
        const payload = {
            folderId: folderId,
            currentPin: $("#pinCurrent").val(),
            newPin: $("#pinNew").val(),
            confirmPin: $("#pinConfirm").val()
        };

        const url = mode === "set" ? "/DocumentHub/SetFolderPin"
            : mode === "change" ? "/DocumentHub/ChangeFolderPin"
            : mode === "reset" ? "/DocumentHub/ResetFolderPin"
            : "/DocumentHub/RemoveFolderPin";

        $.ajax({
            url: url,
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload)
        }).done(function (res) {
            showToast(res.message, res.success ? "success" : "error");
            if (res.success) {
                $("#pinManageModal").modal("hide");
                requestLoadHub("saveFolderPin:success", { folderId });
            }
        }).fail(() => showToast("PIN request failed.", "error"));
    }

    /* ─────────────────────────────────────────────
       BACKUP & RECOVERY
    ───────────────────────────────────────────── */
    function loadBackupList() {
        if (!hasDocumentHubPermission("backup")) {
            showToast("You do not have permission to access Backup & Recovery.", "error");
            return;
        }
        $.get("/DocumentHub/GetBackups").done(function (backups) {
            if (backups && backups.success === false) {
                showToast(backups.message || "Unable to retrieve backups.", "error");
                return;
            }
            if (!backups || !backups.length) {
                $("#backupListBody").html(`<tr><td colspan="7" class="text-center text-muted p-4 small">No backups found</td></tr>`);
                $("#lblLastBackupTime").text("Never");
                return;
            }
            $("#lblLastBackupTime").text(fmtDate(backups[0].backupDate));
            $("#lblBackupStorage").text(fmtSize(backups.reduce((a, b) => a + b.fileSize, 0)));
            $("#backupListBody").html(backups.map(b => `
                <tr>
                    <td><strong class="font-monospace text-primary small">${escHtml(b.backupId)}</strong></td>
                    <td>${fmtDate(b.backupDate)}</td>
                    <td><span class="badge bg-light text-dark border">${escHtml(b.backupType)}</span></td>
                    <td>${fmtSize(b.fileSize)}</td>
                    <td>${b.folderCount} folders, ${b.fileCount} files</td>
                    <td><span class="badge bg-success-subtle text-success py-1 px-2 border border-success"><i class="fa-solid fa-circle-check"></i> ${escHtml(b.status)}</span></td>
                    <td class="text-end d-flex justify-content-end gap-1">
                        <button class="btn btn-sm btn-outline-primary" style="font-size:11px;padding:3px 8px;" onclick="browseBackup('${b.backupId}')"><i class="fa-solid fa-folder-open"></i> Browse</button>
                        ${hasDocumentHubPermission("restore") ? `<button class="btn btn-sm btn-danger dh-restore-action" style="font-size:11px;padding:3px 8px;" onclick="restoreBackup('${b.backupId}')"><i class="fa-solid fa-trash-can-arrow-up"></i> Restore</button>` : ""}
                    </td>
                </tr>`).join(""));
            applyDocumentHubPermissions("loadBackupList render");
        }).fail(function (xhr) {
            const message = xhr.responseJSON?.message || xhr.responseText || "Unable to retrieve backups.";
            showToast(message, "error");
        });
    }

    function triggerManualBackup(type) {
        if (!hasDocumentHubPermission("backup")) {
            showToast("You do not have permission to create backups.", "error");
            return;
        }
        showToast("Generating backup snapshot...", "success");
        $.post("/DocumentHub/CreateBackup", { type }).done(function (res) {
            showToast(res.message, res.success ? "success" : "error");
            loadBackupList();
        }).fail(function (xhr) {
            const message = xhr.responseJSON?.message || xhr.responseText || "Unable to create backup.";
            showToast(message, "error");
        });
    }

    function restoreBackup(backupId) {
        if (!hasDocumentHubPermission("restore")) {
            showToast("You do not have permission to restore backups.", "error");
            return;
        }
        showConfirm("Restore Backup", "DANGER: This will overwrite current folder structure, documents, permissions, and logs. Proceed?", "Restore", function () {
            $.post("/DocumentHub/RestoreBackup", { backupId }).done(function (res) {
                showToast(res.message, res.success ? "success" : "error");
                loadBackupList();
                requestLoadHub("restoreBackup:done", { backupId });
            });
        });
    }

    function browseBackup(backupId) {
        if (!hasDocumentHubPermission("backup")) {
            showToast("You do not have permission to browse backups.", "error");
            return;
        }
        $.ajax({
            url: `/DocumentHub/GetBackupContent?backupId=${encodeURIComponent(backupId)}`,
            type: "GET",
            success: function (res) {
                if (!res || res.success === false) {
                    showToast(res?.message || "Unable to retrieve backup.", "error");
                    return;
                }

                const d = res.data || res;
                renderBackupBrowse(backupId, d.folders || d.Folders || [], d.files || d.Files || []);
            },
            error: function (xhr) {
                const message = xhr.responseJSON?.message || xhr.responseText || "Unable to retrieve backup.";
                showToast(message, "error");
            }
        });
    }

    function renderBackupBrowse(backupId, folders, files) {
        const folderRows = folders.map(f => `
            <div class="d-flex justify-content-between align-items-center mb-1 pb-1 border-bottom small">
                <span><i class="fa-solid fa-folder text-warning"></i> ${escHtml(f.folderName)}</span>
                ${hasDocumentHubPermission("restore") ? `<button class="btn btn-xs btn-primary py-0 px-2 dh-restore-action" style="font-size:10px;" onclick="restoreSingleFolder('${backupId}',${f.folderId})">Restore</button>` : ""}
            </div>`).join("") || `<span class="text-muted small">No folders</span>`;

        const fileRows = files.map(f => `
            <div class="d-flex justify-content-between align-items-center mb-1 pb-1 border-bottom small">
                <span><i class="${fileIcon(f.fileType)}"></i> ${escHtml(f.fileName)}</span>
                ${hasDocumentHubPermission("restore") ? `<button class="btn btn-xs btn-primary py-0 px-2 dh-restore-action" style="font-size:10px;" onclick="restoreSingleFile('${backupId}',${f.fileId})">Restore</button>` : ""}
            </div>`).join("") || `<span class="text-muted small">No files</span>`;

        $("#listTitle").text("Browse Backup Snapshot");
        $("#listBody").html(`
            <div class="p-3">
                <p class="small text-muted mb-3">Restore items from <strong>${escHtml(backupId)}</strong>:</p>
                <h6 class="small text-primary font-weight-bold mb-1">Folders:</h6>
                <div style="max-height:120px;overflow-y:auto;" class="border rounded bg-light p-2 mb-3">${folderRows}</div>
                <h6 class="small text-primary font-weight-bold mb-1">Files:</h6>
                <div style="max-height:150px;overflow-y:auto;" class="border rounded bg-light p-2">${fileRows}</div>
            </div>`);
        $("#listModal").modal("show");
        applyDocumentHubPermissions("renderBackupBrowse");
    }

    function restoreSingleFolder(backupId, folderId) {
        if (!hasDocumentHubPermission("restore")) {
            showToast("You do not have permission to restore folders.", "error");
            return;
        }
        showConfirm("Restore Folder", "Restore this folder from backup?", "Restore", function () {
            $.post("/DocumentHub/RestoreSingleFolder", { backupId, folderId }).done(r => { showToast(r.message, r.success ? "success" : "error"); $("#listModal").modal("hide"); requestLoadHub("restoreSingleFolder:done", { backupId, folderId }); });
        });
    }

    function restoreSingleFile(backupId, fileId) {
        if (!hasDocumentHubPermission("restore")) {
            showToast("You do not have permission to restore files.", "error");
            return;
        }
        showConfirm("Restore File", "Restore this file from backup?", "Restore", function () {
            $.post("/DocumentHub/RestoreSingleFile", { backupId, fileId }).done(r => { showToast(r.message, r.success ? "success" : "error"); $("#listModal").modal("hide"); requestLoadHub("restoreSingleFile:done", { backupId, fileId }); });
        });
    }

    /* ─────────────────────────────────────────────
       UTILITIES
    ───────────────────────────────────────────── */
    function fileIcon(ext) {
        ext = (ext || "").toLowerCase();
        if (ext === "pdf")                        return "fa-solid fa-file-pdf icon-pdf";
        if (["png","jpg","jpeg","gif"].includes(ext)) return "fa-solid fa-file-image icon-image";
        if (["xlsx","xls"].includes(ext))         return "fa-solid fa-file-excel icon-excel";
        if (["docx","doc"].includes(ext))         return "fa-solid fa-file-word icon-word";
        if (ext === "csv")                        return "fa-solid fa-file-csv icon-csv";
        if (["pptx","ppt"].includes(ext))         return "fa-solid fa-file-powerpoint icon-ppt";
        if (["zip","rar","tar"].includes(ext))    return "fa-solid fa-file-zipper icon-zip";
        return "fa-solid fa-file text-secondary";
    }

    function fmtSize(bytes) {
        bytes = Number(bytes || 0);
        if (bytes < 1024)    return bytes + " B";
        if (bytes < 1048576) return (bytes/1024).toFixed(1) + " KB";
        return (bytes/1048576).toFixed(1) + " MB";
    }

    function fmtDate(v) {
        if (!v) return "-";
        const d = new Date(v);
        return isNaN(d) ? v : d.toLocaleString("en-IN", { dateStyle:"medium", timeStyle:"short" });
    }

    function escHtml(v)  { return $("<div>").text(v == null ? "" : v).html(); }
    function escAttr(v)  { return escHtml(v).replace(/'/g,"&#39;").replace(/"/g,"&quot;"); }
    function parseNullInt(v) { const n = parseInt(v,10); return isFinite(n) ? n : null; }
    function isSelected(type, id) { return hub.selectedItem?.type === type && hub.selectedItem?.id === id; }

    function debounce(fn, wait) {
        let t;
        let ctx;
        let args;
        const debounced = function () {
            clearTimeout(t);
            ctx = this;
            args = arguments;
            t = setTimeout(() => {
                const callCtx = ctx;
                const callArgs = args;
                t = null;
                ctx = null;
                args = null;
                fn.apply(callCtx, callArgs);
            }, wait);
        };
        debounced.cancel = function () {
            if (!t) return false;
            clearTimeout(t);
            t = null;
            ctx = null;
            args = null;
            return true;
        };
        debounced.pending = function () {
            return !!t;
        };
        return debounced;
    }

    function showToast(msg, type) {
        const ok = type === "success";
        $("#hubToast")
            .removeClass("bg-toast-success bg-toast-error")
            .addClass(ok ? "bg-toast-success" : "bg-toast-error");
        $("#toastIcon").html(ok ? '<i class="fa-solid fa-circle-check"></i>' : '<i class="fa-solid fa-triangle-exclamation"></i>');
        $("#toastText").text(msg);
        $("#hubToast").fadeIn(150);
        setTimeout(() => $("#hubToast").fadeOut(250), 3000);
    }

    function showConfirm(title, message, okText, onOk) {
        $("#hubConfirmTitle").text(title);
        $("#hubConfirmMessage").text(message);
        $("#hubConfirmOkBtn").text(okText || "Confirm").off("click").on("click", function () {
            $("#hubConfirmModal").modal("hide");
            if (typeof onOk === "function") onOk();
        });
        $("#hubConfirmModal").modal("show");
    }

    function afterMutation(res) {
        showToast(res.message || "Action processed.", res.success ? "success" : "error");
        if (res.success) $(".modal").modal("hide");
        requestLoadHub("afterMutation", { success: !!res?.success, message: res?.message });
    }

    function onMutate(res) {
        showToast(res.message, res.success ? "success" : "error");
        requestLoadHub("onMutate", { success: !!res?.success, message: res?.message });
    }

</script>
}
