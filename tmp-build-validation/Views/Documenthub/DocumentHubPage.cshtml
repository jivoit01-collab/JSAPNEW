@using JSAPNEW.Models
@{
    ViewData["Title"] = "Document Hub";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var permissions = ViewBag.DocumentHubPermissions as DocumentHubPermissionDto ?? new DocumentHubPermissionDto();
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --hub-primary: #0f172a;
        --hub-primary-light: #1e293b;
        --hub-accent: #4f46e5;
        --hub-accent-hover: #4338ca;
        --hub-success: #10b981;
        --hub-warning: #f59e0b;
        --hub-danger: #ef4444;
        --hub-bg: #f8fafc;
        --hub-card: #ffffff;
        --hub-border: #e2e8f0;
        --hub-text: #0f172a;
        --hub-muted: #64748b;
        --hub-font: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .doc-hub-container {
        font-family: var(--hub-font);
        color: var(--hub-text);
        background: var(--hub-bg);
        margin: -15px;
        padding: 24px;
        min-height: 100vh;
    }

    /* ── Toolbar ── */
    .hub-toolbar {
        background: var(--hub-card);
        border: 1px solid var(--hub-border);
        border-radius: 12px;
        padding: 12px 18px;
        box-shadow: 0 4px 20px -2px rgba(15,23,42,.04);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .toolbar-group { display: flex; align-items: center; gap: 8px; }

    .hub-toolbar .btn {
        font-size: 13px;
        font-weight: 600;
        border-radius: 8px;
        padding: 8px 14px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all .2s;
    }

    /* ── Tabs ── */
    .hub-tabs-row { margin-top: 16px; }
    .hub-tabs-row .nav-tabs { border-bottom: 2px solid var(--hub-border); }
    .hub-tabs-row .nav-link {
        font-size: 13.5px;
        font-weight: 600;
        color: var(--hub-muted);
        border: 0;
        border-bottom: 2px solid transparent;
        padding: 10px 18px;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .hub-tabs-row .nav-link:hover { color: var(--hub-accent); border-bottom-color: var(--hub-border); }
    .hub-tabs-row .nav-link.active { color: var(--hub-accent); background: transparent; border-bottom-color: var(--hub-accent); }

    /* ── Shell ── */
    .doc-shell {
        display: grid;
        grid-template-columns: 280px minmax(0,1fr) 320px;
        gap: 20px;
        margin-top: 20px;
        align-items: start;
    }

    .doc-sidebar, .doc-main, .doc-detail-pane {
        background: var(--hub-card);
        border: 1px solid var(--hub-border);
        border-radius: 12px;
        box-shadow: 0 4px 20px -2px rgba(15,23,42,.04);
        overflow: hidden;
    }

    /* ── Sidebar ── */
    .doc-sidebar {
        padding: 16px;
        position: sticky;
        top: 86px;
        max-height: calc(100vh - 120px);
        overflow-y: auto;
    }

    .sidebar-section { margin-bottom: 24px; }

    .section-label {
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--hub-muted);
        letter-spacing: .05em;
        margin-bottom: 8px;
        padding-left: 6px;
    }

    .nav-item-btn {
        width: 100%;
        border: 0;
        background: transparent;
        border-radius: 8px;
        padding: 10px 12px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--hub-primary-light);
        font-size: 13.5px;
        font-weight: 600;
        text-align: left;
        cursor: pointer;
        transition: all .2s;
    }
    .nav-item-btn:hover { background: #f1f5f9; color: var(--hub-accent); }
    .nav-item-btn.active { background: #e0e7ff; color: var(--hub-accent); }

    /* ── Tree ── */
    .tree-container { padding-left: 4px; }
    .tree-list { list-style: none; padding-left: 12px; margin: 0; }
    .tree-node-item { margin-top: 2px; }

    .tree-row {
        display: flex;
        align-items: center;
        padding: 7px 8px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 550;
        color: #475569;
        cursor: pointer;
        transition: all .15s;
        gap: 6px;
        user-select: none;
    }
    .tree-row:hover, .tree-row.drag-over { background: #f8fafc; color: var(--hub-accent); }
    .tree-row.active { background: #eef2ff; color: var(--hub-accent); font-weight: 600; }

    .tree-arrow {
        font-size: 10px;
        width: 12px;
        height: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform .2s;
        color: var(--hub-muted);
    }
    .tree-arrow.rotate-90 { transform: rotate(90deg); }
    .tree-arrow-spacer { width: 12px; height: 12px; display: inline-block; }

    .tree-row .count {
        margin-left: auto;
        background: #f1f5f9;
        color: var(--hub-muted);
        font-size: 11px;
        border-radius: 10px;
        padding: 1px 6px;
    }

    .tree-node-children { display: none; }
    .tree-node-children.show { display: block; }

    /* ── Main ── */
    .doc-main { padding: 20px; min-height: 500px; }

    .search-breadcrumb-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        border-bottom: 1px solid var(--hub-border);
        padding-bottom: 16px;
    }

    .hub-breadcrumb {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 6px;
        font-size: 14px;
        font-weight: 600;
        color: var(--hub-muted);
    }
    .hub-breadcrumb a { color: var(--hub-primary-light); text-decoration: none; cursor: pointer; transition: color .15s; }
    .hub-breadcrumb a:hover { color: var(--hub-accent); }

    .search-box { position: relative; min-width: 280px; max-width: 400px; flex: 1; }
    .search-box i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--hub-muted); }
    .search-box input {
        width: 100%;
        border: 1px solid var(--hub-border);
        border-radius: 8px;
        padding: 9px 12px 9px 36px;
        font-size: 13.5px;
        outline: none;
        transition: all .2s;
    }
    .search-box input:focus { border-color: var(--hub-accent); box-shadow: 0 0 0 3px rgba(79,70,229,.1); }

    /* ── Stats ── */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(180px,1fr)); gap: 16px; }

    .stat-card {
        background: var(--hub-card);
        border: 1px solid var(--hub-border);
        border-radius: 10px;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .bg-soft-primary { background: #e0e7ff; }
    .bg-soft-success { background: #d1fae5; }
    .bg-soft-warning { background: #fef3c7; }
    .bg-soft-danger  { background: #fee2e2; }

    .stat-data { display: flex; flex-direction: column; }
    .stat-value { font-size: 18px; font-weight: 800; color: var(--hub-primary); line-height: 1.2; }
    .stat-label { font-size: 12px; color: var(--hub-muted); font-weight: 500; }

    /* ── Content header ── */
    .content-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--hub-border);
        padding-bottom: 10px;
        margin-top: 24px;
    }

    .section-title { font-size: 16px; font-weight: 700; margin: 0; color: var(--hub-primary); }

    .view-toggle-container {
        display: flex;
        background: #f1f5f9;
        padding: 2px;
        border-radius: 8px;
        border: 1px solid var(--hub-border);
    }
    .view-toggle-container .btn {
        font-size: 12px;
        font-weight: 600;
        border: 0;
        padding: 6px 12px;
        border-radius: 6px;
        background: transparent;
        color: var(--hub-muted);
        transition: all .15s;
    }
    .view-toggle-container .btn.active-toggle {
        background: #fff;
        color: var(--hub-accent);
        box-shadow: 0 2px 6px rgba(15,23,42,.08);
    }

    /* ── Cards (folder & file share base styles) ── */
    .item-card {
        background: var(--hub-card);
        border: 1px solid var(--hub-border);
        border-radius: 10px;
        padding: 14px;
        cursor: pointer;
        transition: all .2s ease;
        position: relative;
    }
    .item-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(15,23,42,.08); border-color: #cbd5e1; }
    .item-card.selected { border-color: var(--hub-accent); background: #f5f3ff; box-shadow: 0 0 0 2px rgba(79,70,229,.15); }
    .item-card.drag-over { border-color: var(--hub-accent); background: #f5f3ff; }

    .card-top { display: flex; align-items: center; gap: 12px; }

    .item-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: var(--hub-muted);
        flex-shrink: 0;
    }
    .folder-card .item-icon { background: #fef3c7; color: #d97706; }

    .item-info { min-width: 0; flex-grow: 1; }
    .item-title { font-size: 13.5px; font-weight: 700; color: var(--hub-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin: 0; }
    .item-meta { font-size: 11.5px; color: var(--hub-muted); margin-top: 2px; }

    .item-menu-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 0;
        background: transparent;
        color: var(--hub-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-left: auto;
    }
    .item-menu-btn:hover { background: #f1f5f9; color: var(--hub-text); }

    .item-menu-host {
        flex-shrink: 0;
        margin-left: auto;
        position: relative;
    }

    .doc-hub-container .dropdown {
        position: relative;
    }
    .doc-hub-container .dropdown-menu {
        min-width: 160px;
        padding: 6px;
        border: 1px solid var(--hub-border);
        border-radius: 8px;
        box-shadow: 0 14px 30px rgba(15,23,42,.14);
        z-index: 1080;
    }
    .doc-hub-container .dropdown-menu.show {
        display: block;
        position: absolute;
        top: 100%;
        right: 0;
        left: auto;
        margin-top: 4px;
    }
    .doc-hub-container .item-card .dropdown > .dropdown-menu,
    .doc-hub-container .file-list-view .dropdown > .dropdown-menu {
        display: none !important;
    }
    #hubFloatingItemMenu.hub-floating-menu {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: auto;
        min-width: 170px;
        max-width: calc(100vw - 16px);
        max-height: min(320px, calc(100vh - 16px));
        overflow-y: auto;
        padding: 6px;
        border: 1px solid var(--hub-border);
        border-radius: 8px;
        box-shadow: 0 14px 30px rgba(15,23,42,.14);
        z-index: 99999;
        background: #fff;
        list-style: none;
        margin: 0;
    }
    #hubFloatingItemMenu.hub-floating-menu.show {
        display: block;
    }
    .doc-hub-container .dropdown-item,
    #hubFloatingItemMenu .dropdown-item {
        display: flex;
        align-items: center;
        gap: 10px;
        border-radius: 6px;
        padding: 8px 10px;
        font-size: 13px;
        font-weight: 600;
        color: var(--hub-primary-light);
        cursor: pointer;
    }
    .doc-hub-container .dropdown-item i,
    #hubFloatingItemMenu .dropdown-item i {
        width: 16px;
        text-align: center;
        flex-shrink: 0;
    }
    .doc-hub-container .dropdown-item:hover,
    #hubFloatingItemMenu .dropdown-item:hover {
        background: #f8fafc;
        color: var(--hub-accent);
    }
    .doc-hub-container .dropdown-item.text-danger:hover,
    #hubFloatingItemMenu .dropdown-item.text-danger:hover {
        background: #fee2e2;
        color: var(--hub-danger) !important;
    }

    /* ── List view ── */
    .file-list-view table tr { cursor: pointer; transition: background .15s; }
    .file-list-view table tr.selected { background-color: #f5f3ff !important; }
    .file-list-view th { font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--hub-muted); letter-spacing: .03em; }
    .file-list-view td { font-size: 13px; padding: 12px; }

    /* ── Detail pane ── */
    .doc-detail-pane {
        padding: 20px;
        position: sticky;
        top: 86px;
        max-height: calc(100vh - 120px);
        overflow-y: auto;
    }

    .detail-empty { text-align: center; padding: 40px 10px; color: var(--hub-muted); }
    .detail-empty-icon { font-size: 40px; margin-bottom: 12px; opacity: .3; }

    .detail-header { text-align: center; border-bottom: 1px solid var(--hub-border); padding-bottom: 16px; margin-bottom: 16px; }
    .detail-file-icon {
        width: 72px;
        height: 72px;
        border-radius: 12px;
        background: #f8fafc;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        margin-bottom: 12px;
        border: 1px solid var(--hub-border);
    }
    .detail-filename { font-size: 15px; font-weight: 700; margin: 0; word-break: break-all; }
    .detail-table th { font-size: 12px; font-weight: 600; color: var(--hub-muted); padding: 6px 0; width: 40%; }
    .detail-table td { font-size: 12.5px; color: var(--hub-primary); padding: 6px 0; text-align: right; }
    .detail-actions { display: flex; flex-direction: column; gap: 8px; }
    .detail-actions .btn { width: 100%; font-size: 13px; font-weight: 600; border-radius: 8px; padding: 8px 12px; }

    /* ── Upload dropzone ── */
    .upload-dropzone {
        border: 2px dashed #cbd5e1;
        border-radius: 12px;
        padding: 30px;
        text-align: center;
        background: var(--hub-bg);
        color: var(--hub-muted);
        cursor: pointer;
        transition: all .2s;
    }
    .upload-dropzone:hover, .upload-dropzone.dragging { border-color: var(--hub-accent); background: #eef2ff; color: var(--hub-accent); }

    .upload-progress { height: 6px; border-radius: 10px; background: #e2e8f0; overflow: hidden; margin-top: 16px; display: none; }
    .upload-progress-bar { height: 100%; background: var(--hub-accent); width: 0; transition: width .15s; }

    /* ── Badges ── */
    .version-badge { background: #e0f2fe; color: #0369a1; font-size: 11px; font-weight: 700; border-radius: 4px; padding: 2px 6px; }

    /* ── File icons ── */
    .icon-pdf   { color: var(--hub-danger); }
    .icon-excel { color: var(--hub-success); }
    .icon-word  { color: #3b82f6; }
    .icon-image { color: #8b5cf6; }
    .icon-csv   { color: #0d9488; }
    .icon-ppt   { color: var(--hub-warning); }
    .icon-zip   { color: #64748b; }

    /* ── Viewer ── */
    .viewer-frame { width: 100%; height: 70vh; border: 0; border-radius: 8px; background: #1e293b; }
    .viewer-img-container { display: flex; justify-content: center; align-items: center; height: 70vh; background: #0f172a; border-radius: 8px; }
    .viewer-img { max-width: 100%; max-height: 100%; object-fit: contain; }

    /* ── Move tree ── */
    .move-tree-item { padding: 4px 8px; border-radius: 4px; cursor: pointer; display: flex; align-items: center; gap: 6px; font-size: 13px; }
    .move-tree-item:hover { background: #eef2ff; color: var(--hub-accent); }
    .move-tree-item.selected { background: #e0e7ff; color: var(--hub-accent); font-weight: 600; }

    /* ── Toast ── */
    .hub-toast {
        position: fixed;
        right: 24px;
        bottom: 24px;
        z-index: 2000;
        box-shadow: 0 10px 30px rgba(0,0,0,.1);
        border-radius: 8px;
        padding: 12px 18px;
        color: white;
        font-weight: 600;
        font-size: 13.5px;
        display: none;
        align-items: center;
        gap: 8px;
        animation: slideUp .3s ease;
    }
    @@keyframes slideUp { from { transform: translateY(50px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    .bg-toast-success { background: var(--hub-success); }
    .bg-toast-error   { background: var(--hub-danger); }

</style>

<div class="doc-hub-container">

    <!-- Toolbar -->
    <header class="hub-toolbar mb-2">
        <div class="toolbar-group">
            <button class="btn btn-primary d-none dh-permission-action" data-dh-permission="upload" id="hdrUploadBtn"><i class="fa-solid fa-cloud-arrow-up"></i> Upload</button>
            <button class="btn btn-outline-primary d-none dh-permission-action" data-dh-permission="createFolder" id="hdrNewFolderBtn"><i class="fa-solid fa-folder-plus"></i> New Folder</button>
        </div>
        <div class="toolbar-group">
            <button class="btn btn-light" onclick="requestLoadHub('toolbar-refresh')"><i class="fa-solid fa-arrows-rotate"></i> Refresh</button>
            <button class="btn btn-light d-none" id="hdrDownloadBtn" disabled onclick="downloadSelected()"><i class="fa-solid fa-download"></i> Download</button>
            <button class="btn btn-light d-none dh-permission-action" data-dh-permission="move" id="hdrMoveBtn" disabled onclick="openMoveModal()"><i class="fa-solid fa-arrows-up-down-left-right"></i> Move</button>
            <button class="btn btn-light text-danger d-none dh-permission-action" data-dh-permission="delete" id="hdrDeleteBtn" disabled onclick="deleteSelected()"><i class="fa-solid fa-trash"></i> Delete</button>
        </div>
    </header>

    <!-- Tabs -->
    <div class="hub-tabs-row">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#explorerView" type="button" role="tab">
                    <i class="fa-solid fa-folder-tree"></i> Explorer View
                </button>
            </li>
            <li class="nav-item d-none dh-permission-action" data-dh-permission="backup" id="backupTabItem" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#backupView" type="button" role="tab" onclick="loadBackupList()">
                    <i class="fa-solid fa-database"></i> Backup & Recovery
                </button>
            </li>
        </ul>
    </div>

    <div class="tab-content">

        <!-- ─── EXPLORER TAB ─── -->
        <div class="tab-pane fade show active" id="explorerView" role="tabpanel">
            <div class="doc-shell">

                <!-- Left sidebar -->
                <aside class="doc-sidebar">
                    <div class="sidebar-section">
                        <div class="section-label">Quick Access</div>
                        <button class="nav-item-btn active" onclick="selectNavFilter('', this)"><i class="fa-solid fa-layer-group"></i> All Documents</button>
                        <button class="nav-item-btn" onclick="selectNavFilter('recent', this)"><i class="fa-solid fa-clock-rotate-left"></i> Recent Files</button>
                        <button class="nav-item-btn" onclick="selectNavFilter('trash', this)"><i class="fa-solid fa-trash-can"></i> Trash / Deleted</button>
                    </div>
                    <div class="sidebar-section">
                        <div class="section-label">Folder Hierarchy</div>
                        <div id="folderTreeContainer" class="tree-container">
                            <p class="text-muted small p-2">Loading hierarchy...</p>
                        </div>
                    </div>
                </aside>

                <!-- Main content -->
                <main class="doc-main">
                    <div class="search-breadcrumb-row">
                        <div class="hub-breadcrumb" id="breadcrumb">
                            <a onclick="goFolder(null)">Home</a>
                        </div>
                        <div class="search-box">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <input type="search" id="hubSearch" placeholder="Search files, folders, owner..." autocomplete="off" />
                        </div>
                    </div>

                    <!-- Stats -->
                    <div class="stats-grid mt-4 mb-4">
                        <div class="stat-card">
                            <span class="stat-icon bg-soft-primary"><i class="fa-solid fa-file-lines text-primary"></i></span>
                            <div class="stat-data"><span class="stat-value" id="statFiles">0</span><span class="stat-label">Total Files</span></div>
                        </div>
                        <div class="stat-card">
                            <span class="stat-icon bg-soft-success"><i class="fa-solid fa-folder-tree text-success"></i></span>
                            <div class="stat-data"><span class="stat-value" id="statFolders">0</span><span class="stat-label">Folders</span></div>
                        </div>
                        <div class="stat-card">
                            <span class="stat-icon bg-soft-warning"><i class="fa-solid fa-database text-warning"></i></span>
                            <div class="stat-data"><span class="stat-value" id="statStorage">0 B</span><span class="stat-label">Storage Used</span></div>
                        </div>
                        <div class="stat-card">
                            <span class="stat-icon bg-soft-danger"><i class="fa-solid fa-clock text-danger"></i></span>
                            <div class="stat-data"><span class="stat-value" id="statRecent">0</span><span class="stat-label">Recent Uploads</span></div>
                        </div>
                    </div>

                    <!-- Folder / file header -->
                    <div class="content-header-row">
                        <h5 class="section-title" id="contentTitle">Files and Folders</h5>
                        <div class="view-toggle-container">
                            <button class="btn btn-sm active-toggle" id="toggleGridBtn" onclick="setViewMode('grid')"><i class="fa-solid fa-grip"></i> Grid</button>
                            <button class="btn btn-sm" id="toggleListBtn" onclick="setViewMode('list')"><i class="fa-solid fa-list"></i> List</button>
                        </div>
                    </div>

                    <!-- Folders -->
                    <div id="folderSection" class="mt-3 mb-4">
                        <div class="row g-3" id="folderGrid"></div>
                    </div>

                    <!-- Files -->
                    <div class="mt-3">
                        <div id="fileGridView" class="row g-3"></div>
                        <div id="fileListView" class="file-list-view border rounded shadow-sm bg-white" style="display:none;">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:35%">Name</th>
                                        <th style="width:15%">Folder</th>
                                        <th style="width:10%">Type</th>
                                        <th style="width:10%">Size</th>
