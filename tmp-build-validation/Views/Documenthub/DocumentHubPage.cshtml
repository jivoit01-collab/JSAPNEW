    function renderBreadcrumb(items) {
        const html = items.map((item, i) => {
            const sep = i ? ` <i class="fa-solid fa-chevron-right mx-1 small text-muted"></i> ` : "";
            return `${sep}<a onclick="goFolder(${item.folderId || 'null'})">${escHtml(item.folderName || "Home")}</a>`;
