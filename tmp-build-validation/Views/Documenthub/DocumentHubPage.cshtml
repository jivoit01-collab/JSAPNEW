            m += `<li><a class="dropdown-item" onclick="openFile(${f.fileId},'download')"><i class="fa-solid fa-download text-success"></i> Download</a></li>`;
        if (hasDocumentHubPermission("move"))
            m += `<li><a class="dropdown-item" onclick="openMoveModal('file',${f.fileId})"><i class="fa-solid fa-arrows-up-down-left-right text-warning"></i> Move File</a></li>`;
        m += `<li><a class="dropdown-item text-danger" onclick="deleteFile(${f.fileId})"><i class="fa-solid fa-trash"></i> Delete File</a></li>`;
        return m;
    }

    /* ─────────────────────────────────────────────
       DRAG & DROP
    ───────────────────────────────────────────── */
    function setupDragAndDrop() {
        if (!hasDocumentHubPermission("move")) return;
        debugFolderMenu("setupDragAndDrop", { draggableCount: $("[draggable='true']").length });

        $("[draggable='true']").off(".documentHubDrag").on("dragstart.documentHubDrag", function (e) {
            debugFolderMenu("dragstart", {
                type: $(this).data("drag-type"),
                id: $(this).data("drag-id"),
                targetClass: e.target?.className || e.target?.tagName
            });
            e.originalEvent.dataTransfer.setData("text/plain", JSON.stringify({
                type: $(this).data("drag-type"),
                id:   parseInt($(this).data("drag-id"))
            }));
        });

        $("[data-drop-folder-id],[data-tree-folder-id]").off(".documentHubDrop").on("dragover.documentHubDrop", function (e) {
            e.preventDefault();
            $(this).addClass("drag-over");
        }).on("dragleave.documentHubDrop", function () {
            $(this).removeClass("drag-over");
        }).on("drop.documentHubDrop", function (e) {
            e.preventDefault();
            $(this).removeClass("drag-over");
            const raw = e.originalEvent.dataTransfer.getData("text/plain");
            if (!raw) return;
            let drag;
            try {
                drag = JSON.parse(raw);
            } catch {
                return;
            }
            const raw2 = $(this).data("drop-folder-id") !== undefined ? $(this).data("drop-folder-id") : $(this).data("tree-folder-id");
            const targetId = (raw2 === "null" || raw2 === null) ? null : parseInt(raw2);
            if (drag.type === 'folder' && drag.id === targetId) return;
            if (!confirm(`Move selected ${drag.type} to this folder?`)) return;
            doDrop(drag.type, drag.id, targetId);
        });
    }

    function doDrop(type, id, targetId) {
        if (!hasDocumentHubPermission("move")) {
            showToast("You do not have permission to move items.", "error");
            return;
        }
        if (type === 'file') {
            if (!targetId) { showToast("Files must reside inside subfolders.", "error"); return; }
            $.post("/DocumentHub/MoveFile", { fileId: id, targetFolderId: targetId }).done(onMutate);
        } else {
            $.post("/DocumentHub/MoveFolder", { folderId: id, targetParentFolderId: targetId }).done(onMutate);
        }
    }

    /* ─────────────────────────────────────────────
       SELECTION & DETAIL PANE
    ───────────────────────────────────────────── */
    function selectItem(type, id, e) {
        debugFolderMenu("selectItem:attempt", {
            type,
            id,
            targetClass: e?.target?.className || e?.target?.tagName,
            fromFolderMenu: !!$(e?.target).closest(".item-menu-host,.folder-menu-btn,#hubFloatingItemMenu").length
        });
        if ($(e?.target).closest(".item-menu-host,.folder-menu-btn,#hubFloatingItemMenu").length) {
            e.preventDefault();
            e.stopPropagation();
            debugFolderMenu("selectItem:blocked-menu-origin", { type, id });
            return;
        }
        if (e) e.stopPropagation();
        if (hub.selectedItem && hub.selectedItem.type === type && hub.selectedItem.id === id) { deselectItem(); return; }

        const data = type === 'file'
            ? hub.currentFiles.find(x => x.fileId === id)
            : hub.currentFolders.find(x => x.folderId === id);
        if (!data) return;

        hub.selectedItem = { type, id, data };

        $(".item-card,.file-list-view tr").removeClass("selected");
        $(`.item-card[onclick*="'${type}',${id}"]`).addClass("selected");
        $(`.file-list-view tr[onclick*="${id}"]`).addClass("selected");

        renderDetailPane(type, data);
        applyDocumentHubPermissions("selectItem");
    }

    function deselectItem() {
        hub.selectedItem = null;
        $(".item-card,.file-list-view tr").removeClass("selected");
        $("#detailPane").html(`
            <div class="detail-empty">
                <div class="detail-empty-icon"><i class="fa-solid fa-file-invoice"></i></div>
                <h5>Select an item</h5>
                <p class="text-muted">Select a folder or document to view details.</p>
            </div>`);
        applyDocumentHubPermissions("deselectItem");
    }

    function renderDetailPane(type, item) {
        if (type === 'file') {
            const confBadge = item.isConfidential ? `<span class="badge bg-danger mb-2"><i class="fa-solid fa-lock"></i> Confidential</span>` : "";
            $("#detailPane").html(`
                <div class="detail-header">
                    <div class="detail-file-icon"><i class="${fileIcon(item.fileType)}"></i></div>
                    <h6 class="detail-filename" title="${escHtml(item.fileName)}">${escHtml(item.fileName)}</h6>
                    <div class="mt-2">${confBadge}</div>
                </div>
                <table class="table table-borderless table-sm detail-table mb-3">
                    <tbody>
                        <tr><th>File Type</th><td>${escHtml(item.fileType)}</td></tr>
                        <tr><th>File Size</th><td>${fmtSize(item.fileSize)}</td></tr>
                        <tr><th>Owner</th><td>${escHtml(item.owner || item.uploadedBy)}</td></tr>
                        <tr><th>Uploaded</th><td>${fmtDate(item.uploadedDate)}</td></tr>
                        <tr><th>Access Level</th><td><span class="badge bg-light text-info border">${escHtml(item.accessLevel || 'Public')}</span></td></tr>
                        <tr><th>Version</th><td><span class="version-badge">v${item.versionNumber}</span></td></tr>
                    </tbody>
                </table>
                <div class="detail-actions">
                    <button class="btn btn-primary" onclick="openFile(${item.fileId},'view')"><i class="fa-solid fa-eye"></i> Preview</button>
                    ${hasDocumentHubPermission("download") ? `<button class="btn btn-outline-success" onclick="openFile(${item.fileId},'download')"><i class="fa-solid fa-download"></i> Download</button>` : ""}
                    <button class="btn btn-outline-secondary" onclick="showVersions(${item.fileId})"><i class="fa-solid fa-code-branch"></i> Version History</button>
                </div>`);
        } else {
            const confBadge = item.isConfidential ? `<span class="badge bg-warning text-dark mb-2"><i class="fa-solid fa-lock"></i> Confidential</span>` : "";
            $("#detailPane").html(`
                <div class="detail-header">
                    <div class="detail-file-icon"><i class="fa-solid fa-folder text-warning"></i></div>
                    <h6 class="detail-filename">${escHtml(item.folderName)}</h6>
                    <div class="mt-2">${confBadge}</div>
                </div>
                <table class="table table-borderless table-sm detail-table mb-3">
                    <tbody>
                        <tr><th>Contains</th><td>${item.fileCount} files, ${item.childFolderCount} subfolders</td></tr>
                        <tr><th>Last Updated</th><td>${fmtDate(item.lastUpdated || item.createdDate)}</td></tr>
                    </tbody>
                </table>
                <div class="detail-actions">
                    <button class="btn btn-primary" onclick="goFolder(${item.folderId})"><i class="fa-solid fa-folder-open"></i> Open Folder</button>
                    ${hasDocumentHubPermission("rename") ? `<button class="btn btn-outline-secondary" onclick="openFolderModal('rename',${item.folderId},'${escAttr(item.folderName)}')"><i class="fa-solid fa-pen"></i> Rename</button>` : ""}
                    ${hasDocumentHubPermission("confidential") ? `<button class="btn btn-outline-warning pin-admin-only" onclick="openPinManager('set',${item.folderId})"><i class="fa-solid fa-key"></i> Manage PIN</button>` : ""}
                </div>`);
        }
    }

    /* ─────────────────────────────────────────────
       TOOLBAR ACTIONS
    ───────────────────────────────────────────── */
    function downloadSelected() {
        if (hub.selectedItem?.type === 'file') openFile(hub.selectedItem.id, 'download');
    }

    function deleteSelected() {
        if (!hub.selectedItem) return;
        if (!hasDocumentHubPermission("delete")) {
            showToast("You do not have permission to delete items.", "error");
            return;
        }
        hub.selectedItem.type === 'file' ? deleteFile(hub.selectedItem.id) : deleteFolder(hub.selectedItem.id);
    }

    /* ─────────────────────────────────────────────
       FOLDER OPERATIONS
    ───────────────────────────────────────────── */
    function openNewFolderModal() {
        if (!canCreateFolders()) {
            showToast("You do not have permission to create folders.", "error");
            return;
        }
        $("#folderIdInput").val("");
        $("#folderNameInput").val("");
        $("#folderModalTitle").text("New Folder");
        $("#folderModal").data("mode", "create").modal("show");
    }

    function openFolderModal(mode, folderId, name) {
        if (mode !== "rename" && !canCreateFolders()) {
            showToast("You do not have permission to create folders.", "error");
            return;
        }
        $("#folderIdInput").val(folderId || "");
        $("#folderNameInput").val(name || "");
        $("#folderModalTitle").text(mode === "rename" ? "Rename Folder" : "Create Subfolder");
        $("#folderModal").data("mode", mode).modal("show");
    }

function saveFolder() {

    const mode = $("#folderModal").data("mode");
    const folderId = parseNullInt($("#folderIdInput").val());
    const folderName = $("#folderNameInput").val().trim();

    if (mode === "rename" && !hasDocumentHubPermission("rename")) {
        return showToast("You do not have permission to rename folders.", "error");
    }

    if (mode !== "rename" && !hasDocumentHubPermission("createFolder")) {
        return showToast("You do not have permission to create folders.", "error");
    }

    if (!folderName) {
        return showToast("Folder name is required.", "error");
    }

    if (mode === "rename") {

        $.post("/DocumentHub/RenameFolder", {
            folderId: folderId,
            folderName: folderName
        }).done(afterMutation);

        return;
    }

    const parentFolderId =
        mode === "subfolder"
            ? folderId
            : hub.folderId;

    $.ajax({
        url: "/DocumentHub/CreateFolder",
        type: "POST",
        contentType: "application/json",
        data: JSON.stringify({
            parentFolderId: parentFolderId,
            folderName: folderName,
            department: null
        })
    })
    .done(afterMutation)
    .fail(function (xhr) {
        showToast("Folder creation failed.", "error");
    });
}


    function deleteFolder(folderId) {
        if (!hasDocumentHubPermission("delete")) {
            showToast("You do not have permission to delete folders.", "error");
            return;
        }
        const folder = hub.allFolders.find(x => x.folderId === folderId) || hub.currentFolders.find(x => x.folderId === folderId);
        if (folder && ((folder.fileCount || 0) > 0 || (folder.childFolderCount || 0) > 0)) {
            showToast("Only empty folders can be deleted. Move or delete files and subfolders first.", "error");
            return;
        }
        showConfirm("Delete Folder", "Are you sure you want to delete this empty folder?", "Delete Folder", function () {
            $.post("/DocumentHub/DeleteFolder", { folderId }).done(afterMutation);
        });
    }

    /* ─────────────────────────────────────────────
       FILE OPERATIONS
    ───────────────────────────────────────────── */
    function renameFile(fileId, currentName) {
        if (!hasDocumentHubPermission("rename")) {
            showToast("You do not have permission to rename files.", "error");
            return;
        }
        const fileName = prompt("New file name:", currentName);
        if (!fileName) return;
        $.post("/DocumentHub/RenameFile", { fileId, fileName }).done(afterMutation);
    }

    function deleteFile(fileId) {
        if (!hasDocumentHubPermission("delete")) {
            showToast("You do not have permission to delete files.", "error");
            return;
        }
        showConfirm("Delete File", "Are you sure you want to delete this file?", "Delete File", function () {
            $.post("/DocumentHub/DeleteFile", { fileId }).done(afterMutation);
        });
    }

    function toggleFavorite(fileId) {
        if (!hasDocumentHubPermission("favorite")) {
            showToast("You do not have permission to update favorites.", "error");
            return;
        }
        $.post("/DocumentHub/ToggleFavorite", { fileId }).done(onMutate)
            .fail(() => showToast("Unable to update favorite.", "error"));
    }

    /* ─────────────────────────────────────────────
       MOVE
    ───────────────────────────────────────────── */
    let _moveTarget = null;
    let _moveItem   = null;

    function openMoveModal(type, id) {
        if (!hasDocumentHubPermission("move")) {
            showToast("You do not have permission to move items.", "error");
            return;
        }
        if (!type && hub.selectedItem) { type = hub.selectedItem.type; id = hub.selectedItem.id; }
        if (!type) return;
        _moveItem   = { type, id };
        _moveTarget = null;

        const invalid = [];
        if (type === 'folder') {
            invalid.push(id);
            const getDesc = pid => hub.allFolders.filter(x => x.parentFolderId === pid).forEach(x => { invalid.push(x.folderId); getDesc(x.folderId); });
            getDesc(id);
        }

        let html = `<div class="move-tree-item ${_moveTarget === null ? "selected" : ""}" onclick="pickMoveTarget(null,this)"><i class="fa-solid fa-house-laptop"></i> Home (Root)</div>`;
        const addNodes = (parent, depth) => {
            hub.allFolders.filter(x => !x.isDeleted && x.parentFolderId === parent && !invalid.includes(x.folderId)).forEach(n => {
                html += `<div class="move-tree-item" style="padding-left:${20+depth*15}px" onclick="pickMoveTarget(${n.folderId},this)"><i class="fa-solid fa-folder text-warning"></i> ${escHtml(n.folderName)}</div>`;
                addNodes(n.folderId, depth + 1);
            });
        };
        addNodes(null, 0);

        $("#moveDestinationsTree").html(html);
        $("#moveModal").modal("show");
    }

    function pickMoveTarget(id, el) {
        _moveTarget = id;
        $(".move-tree-item").removeClass("selected");
        $(el).addClass("selected");
    }

    function executeMove() {
        if (!_moveItem) return;
        if (!hasDocumentHubPermission("move")) {
            showToast("You do not have permission to move items.", "error");
            return;
        }
        const { type, id } = _moveItem;
        if (type === 'file') {
            if (_moveTarget === null) { showToast("Files must reside in a folder.", "error"); return; }
            $.post("/DocumentHub/MoveFile", { fileId: id, targetFolderId: _moveTarget }).done(r => { onMutate(r); if (r.success) $("#moveModal").modal("hide"); });
        } else {
            $.post("/DocumentHub/MoveFolder", { folderId: id, targetParentFolderId: _moveTarget }).done(r => { onMutate(r); if (r.success) $("#moveModal").modal("hide"); });
        }
    }

    /* ─────────────────────────────────────────────
       UPLOAD
    ───────────────────────────────────────────── */
    function openUploadModal() {
        if (!hasDocumentHubPermission("upload")) {
            showToast("You do not have permission to upload documents.", "error");
            return;
        }
        if (!hub.folderId) { showToast("Select a folder before uploading.", "error"); return; }
        hub.uploadFiles = [];
        $("#fileInput").val("");
        $("#selectedFiles").empty();
        $("#uploadProgressBar").css("width", "0");
        $("#uploadProgress").hide();
        $("#uploadStatusText").hide().text("Ready");
        $("#isConfidentialInput").prop("checked", false);
        $("#uploadLevel").val("Public");
        $("#uploadModal").modal("show");
    }

    function handleFileSelection(files) {
        const allowed = ['.pdf','.doc','.docx','.xls','.xlsx','.png','.jpg','.jpeg','.csv'];
        const incoming = Array.from(files || []);
        const validFiles = incoming.filter(f => allowed.includes("." + f.name.split('.').pop().toLowerCase()));
        const rejectedCount = incoming.length - validFiles.length;
        hub.uploadFiles = validFiles;
        $("#selectedFiles").html(hub.uploadFiles.map(f => `
            <div class="alert alert-light border d-flex align-items-center justify-content-between p-2 mb-1 rounded">
                <span class="text-truncate small" style="max-width:320px;"><i class="${fileIcon(f.name.split('.').pop())} me-2"></i>${escHtml(f.name)} (${fmtSize(f.size)}, ${escHtml(f.name.split('.').pop().toUpperCase())})</span>
                <button class="btn btn-link text-danger p-0" onclick="removeUploadFile('${escAttr(f.name)}')"><i class="fa-solid fa-times"></i></button>
            </div>`).join(""));
        if (rejectedCount) showToast(`${rejectedCount} unsupported file(s) ignored.`, "error");
    }

    function removeUploadFile(name) {
        hub.uploadFiles = hub.uploadFiles.filter(f => f.name !== name);
        handleFileSelection(hub.uploadFiles);
    }

    function confirmUploadFiles() {
        if (!hub.folderId) return showToast("Select a folder first.", "error");
        if (!hub.uploadFiles.length) return showToast("Choose at least one file.", "error");

        const folder = hub.allFolders.find(x => x.folderId === hub.folderId);
        $("#uploadConfirmFolder").text(folder ? folder.folderName : "Selected folder");
        $("#uploadConfirmFiles").html(hub.uploadFiles.map(f => `
            <div class="d-flex align-items-center justify-content-between border-bottom py-1 small">
                <span class="text-truncate" style="max-width:300px;"><i class="${fileIcon(f.name.split('.').pop())} me-2"></i>${escHtml(f.name)}</span>
                <span class="text-muted ms-2">${fmtSize(f.size)}</span>
            </div>`).join(""));
        $("#uploadConfirmModal").modal("show");
    }

    function uploadFiles() {
        if (!hub.folderId)         return showToast("Select a folder first.", "error");
        if (!hub.uploadFiles.length) return showToast("Choose at least one file.", "error");

        const fd = new FormData();
        const accessLevel = $("#uploadLevel").val();
        fd.append("folderId",      hub.folderId);
        fd.append("isConfidential", $("#isConfidentialInput").is(":checked") || accessLevel === "Confidential" || accessLevel === "Highly Restricted");
        fd.append("accessLevel",   accessLevel);
        hub.uploadFiles.forEach(f => fd.append("files", f));

        $("#uploadConfirmModal").modal("hide");
        $("#startUploadBtn").prop("disabled", true).html(`<i class="fa-solid fa-spinner fa-spin"></i> Uploading`);
        $("#uploadProgress").show();
        $("#uploadProgressBar").css("width", "10%");
        $("#uploadStatusText").show().text("Uploading 10%");

        $.ajax({
            url: "/DocumentHub/Upload", type: "POST",
            data: fd, processData: false, contentType: false,
            xhr: function () {
                const x = $.ajaxSettings.xhr();
                if (x.upload) x.upload.addEventListener("progress", function (e) {
                    if (e.lengthComputable) {
                        const pct = Math.max(10, Math.round(e.loaded/e.total*100));
                        $("#uploadProgressBar").css("width", pct + "%");
                        $("#uploadStatusText").text("Uploading " + pct + "%");
                    }
                });
                return x;
            }
        }).done(function (res) {
            showToast(res.message || "Upload completed.", res.success ? "success" : "error");
            if (res.success) {
                $("#uploadProgressBar").css("width", "100%");
                $("#uploadStatusText").text("Upload completed");
                $("#uploadModal").modal("hide");
            }
            requestLoadHub("uploadFiles:done", { success: !!res.success });
        }).fail(() => showToast("Upload failed.", "error")
        ).always(() => {
            $("#startUploadBtn").prop("disabled", false).html("Upload Now");
            setTimeout(() => { $("#uploadProgress").hide(); $("#uploadProgressBar").css("width","0"); $("#uploadStatusText").hide(); }, 300);
        });
    }

    /* ─────────────────────────────────────────────
       FILE VIEWER / DOWNLOAD
    ───────────────────────────────────────────── */
    function openFile(fileId, mode) {
    $.get("/DocumentHub/FileAccessInfo", { fileId: fileId })
        .done(function (res) {

            if (res.isConfidential && !res.accessGranted) {
                $("#accessFileId").val(fileId);
                $("#accessMode").val(mode);
                $("#accessUsername").val("");
                $("#accessPin").val("");
                $("#accessModal").modal("show");
                return;
            }

            launchFile(fileId, mode, res.file);
        })
        .fail(function () {
            showToast("Unable to access file.", "error");
        });
}

    function confirmAccess() {
        const fileId = $("#accessFileId").val();
        const mode   = $("#accessMode").val();
        $.post("/DocumentHub/ConfirmAccess", {
            fileId,
            usernameConfirmation: $("#accessUsername").val(),
            pin: $("#accessPin").val()
        }).done(function (res) {
            if (!res.success) return showToast(res.message, "error");
            $("#accessModal").modal("hide");
            $.get("/DocumentHub/FileAccessInfo", { fileId }).done(info => launchFile(fileId, mode, info.file));
        });
    }

    function launchFile(fileId, mode, file) {
        const ext = (file.fileType || "").toLowerCase();
        if (mode === "download") {
            window.location.href = `/DocumentHub/Download?fileId=${fileId}`;
