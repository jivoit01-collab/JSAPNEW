@section scripts {
<script>
    if (window.jQuery && window.bootstrap && !$.fn.modal) {
        $.fn.modal = function (action) {
            return this.each(function () {
                const modal = bootstrap.Modal.getOrCreateInstance(this);
                if (typeof modal[action] === "function") modal[action]();
            });
        };
    }

    /* ─────────────────────────────────────────────
       STATE
    ───────────────────────────────────────────── */
    const hub = {
        folderId: null,
        filter: "",
        search: "",
        viewMode: "grid",
        selectedItem: null,        // { type, id, data }
        allFolders: [],
        currentFolders: [],
        currentFiles: [],
        uploadFiles: [],
        folderMenus: {},
        loadSeq: 0,
        permissionsLoaded: false,
        permissions: {
            canView:          true,
            canUpload:        @(permissions.CanUpload.ToString().ToLowerInvariant()),
            canDownload:      @(permissions.CanDownload.ToString().ToLowerInvariant()),
            canDelete:        @(permissions.CanDelete.ToString().ToLowerInvariant()),
            canManageFolders: @(permissions.CanManageFolders.ToString().ToLowerInvariant()),
            canRename:        @(permissions.CanRename.ToString().ToLowerInvariant()),
            canShare:         @(permissions.CanShare.ToString().ToLowerInvariant()),
            roleName:         "@permissions.RoleName"
        }
    };
    let hubSearchInputHandler = null;
    const documentHubPermissionRules = {
        upload:       perms => !!perms.canUpload,
        download:     perms => !!perms.canDownload,
        createFolder: perms => !!perms.canManageFolders,
        move:         perms => !!perms.canManageFolders,
        delete:       perms => !!perms.canDelete,
        rename:       perms => !!perms.canRename,
        backup:       perms => !!perms.canManageFolders,
        restore:      perms => !!perms.canManageFolders,
        confidential: perms => !!perms.canDelete,
        versionRestore: perms => !!perms.canRename,
        favorite:     perms => !!perms.canRename
    };

    const DH_FOLDER_MENU_DEBUG = true;

    function debugFolderMenu(label, data) {
        if (!DH_FOLDER_MENU_DEBUG || !window.console) return;
        console.log(`[DocumentHubFolderMenu] ${label}`, data || {});
    }

    function debugSearchReload(label, data) {
        if (!window.console) return;
        console.log(`[DocumentHubSearch] ${label}`, data || {});
    }

    function hasDocumentHubPermission(permissionName) {
        if (!hub.permissionsLoaded) return false;
        const rule = documentHubPermissionRules[permissionName];
        return typeof rule === "function" ? rule(hub.permissions) : false;
    }

    function setDocumentHubActionVisibility(selector, visible, source) {
        const $el = $(selector);
        if (!$el.length) return;
        $el.toggleClass("d-none", !visible).toggle(visible);
    }

    /* ─────────────────────────────────────────────
       INIT
    ───────────────────────────────────────────── */
    $(function () {
        requestLoadHub("init");

        hubSearchInputHandler = debounce(function (e) {
            const previousSearch = hub.search;
            const eventType = e?.type || "unknown";
            const isTrusted = e?.originalEvent?.isTrusted ?? e?.isTrusted ?? null;
            hub.search = this.value;
            debugSearchReload("debounced-input-fired", {
                eventType,
                isTrusted,
                search: hub.search,
                previousSearch,
                activeElementId: document.activeElement?.id || "",
                activeElementClass: document.activeElement?.className || ""
            });
            if (hub.search === previousSearch) {
                debugSearchReload("debounced-input-skipped-same-value", { search: hub.search });
                return;
            }
            requestLoadHub("search-input", { search: hub.search, eventType, isTrusted });
        }, 250);

        $("#hubSearch")
            .off(".documentHubSearch")
            .on("input.documentHubSearch", function (e) {
                debugSearchReload("input-event", {
                    eventType: e.type,
                    isTrusted: e.originalEvent?.isTrusted ?? null,
                    value: this.value,
                    activeElementId: document.activeElement?.id || ""
                });
                hubSearchInputHandler.call(this, e);
            })
            .on("keyup.documentHubSearch change.documentHubSearch", function (e) {
                debugSearchReload("non-reload-event", {
                    eventType: e.type,
                    isTrusted: e.originalEvent?.isTrusted ?? null,
                    value: this.value
                });
            });

        $("#hdrUploadBtn").on("click", openUploadModal);
        $("#hdrNewFolderBtn").on("click", openNewFolderModal);

        $("#browseFilesBtn").on("click", function (e) {
            e.preventDefault();
            e.stopPropagation();
            const input = document.getElementById("fileInput");
            if (input) input.click();
        });
        $("#fileInput")
            .on("click", e => e.stopPropagation())
            .on("change", function () { handleFileSelection(this.files); });
        $("#uploadLevel").on("change", function () {
            const level = ($(this).val() || "").toLowerCase();
            $("#isConfidentialInput").prop("checked", level === "confidential" || level === "highly restricted");
        });
        $("#dropzone")
            .on("dragover", e => { e.preventDefault(); $("#dropzone").addClass("dragging"); })
            .on("dragleave", () => $("#dropzone").removeClass("dragging"))
            .on("drop", function (e) {
                e.preventDefault();
                $(this).removeClass("dragging");
                handleFileSelection(e.originalEvent.dataTransfer.files);
            });

        $(document)
            .off("click.documentHubMenus")
            .on("click.documentHubMenus", closeItemMenus);

        bindFolderMenuCaptureHandlers();
    });

    /* ─────────────────────────────────────────────
       CORE LOAD
    ───────────────────────────────────────────── */
    function loadHub() {
        const requestSeq = ++hub.loadSeq;
        console.trace("loadHub called", {
            requestSeq,
            folderId: hub.folderId,
            currentFolderId: hub.folderId,
            activeFolderId: hub.folderId,
            selectedFolderId: hub.selectedItem?.type === "folder" ? hub.selectedItem.id : null,
            filter: hub.filter,
            search: hub.search,
            selectedItem: hub.selectedItem,
            currentSnapshot: hub.currentSnapshot || null,
            folders: hub.currentFolders,
            currentFolderCount: hub.currentFolders?.length,
            currentFileCount: hub.currentFiles?.length
        });
        debugFolderMenu("loadHub:start", { requestSeq, folderId: hub.folderId, filter: hub.filter, search: hub.search });
        $.get("/DocumentHub/GetHub", { folderId: hub.folderId, filter: hub.filter, search: hub.search })
            .done(function (res) {
                debugFolderMenu("loadHub:done", { requestSeq, activeSeq: hub.loadSeq, folderLockRequired: !!res?.folderLockRequired });
                if (requestSeq !== hub.loadSeq) {
                    debugFolderMenu("loadHub:ignored-stale-response", { requestSeq, activeSeq: hub.loadSeq });
                    return;
                }
                hub.permissions = normalizePermissions(res?.permissions || {});
                hub.permissionsLoaded = true;
                applyDocumentHubPermissions("GetHub response");
                if (res.folderLockRequired) {
                    $("#pinFolderId").val(res.folderId);
                    $("#folderAccessPin,#folderPinFeedback").val && $("#folderAccessPin").val("");
                    $("#folderPinFeedback").hide();
                    $("#folderPinModal").modal("show");
                    return;
                }
                const d = res.data || {};
                hub.currentFolders = d.folders || [];
                hub.currentFiles   = d.files   || [];
                debugFolderMenu("loadHub:data-applied", { folderCount: hub.currentFolders.length, fileCount: hub.currentFiles.length });

                deselectItem();
                renderStats(d.stats || {});
                renderBreadcrumb(d.breadcrumb || []);
                renderFolders();
                renderFiles();
                loadFolderTree();
                setupDragAndDrop();
                applyDocumentHubPermissions("loadHub render complete");
            })
            .fail(() => {
                debugFolderMenu("loadHub:fail", { requestSeq, activeSeq: hub.loadSeq });
                if (requestSeq === hub.loadSeq) showToast("Unable to load Document Hub.", "error");
            });
    }

    function normalizePermissions(perms) {
        if (!perms) {
            return {
                canView: false,
                canUpload: false,
                canDownload: false,
                canDelete: false,
                canManageFolders: false,
                canRename: false,
                canShare: false,
                roleName: ""
            };
        }

        const normalized = {
            canView:       (perms.canView ?? perms.CanView) === true,
            canUpload:     (perms.canUpload ?? perms.CanUpload) === true,
            canDownload:   (perms.canDownload ?? perms.CanDownload) === true,
            canDelete:     (perms.canDelete ?? perms.CanDelete) === true,
            canManageFolders: (perms.canManageFolders ?? perms.CanManageFolders) === true,
            canRename:     (perms.canRename ?? perms.CanRename) === true,
            canShare:      (perms.canShare ?? perms.CanShare) === true,
            roleName:      perms.roleName ?? perms.RoleName ?? ""
        };
        return normalized;
    }

    function loadFolderTree() {
        $.get("/DocumentHub/GetFolders").done(function (folders) {
            hub.allFolders = folders || [];
            renderSidebarTree();
        });
    }

    function applyDocumentHubPermissions(source) {
        const selected = !!hub.selectedItem;
        const decisions = {
            upload: hasDocumentHubPermission("upload"),
            createFolder: hasDocumentHubPermission("createFolder"),
            move: hasDocumentHubPermission("move"),
            delete: hasDocumentHubPermission("delete"),
            download: hasDocumentHubPermission("download"),
            backup: hasDocumentHubPermission("backup"),
            confidential: hasDocumentHubPermission("confidential")
        };

        setDocumentHubActionVisibility("#hdrUploadBtn", decisions.upload, source);
        setDocumentHubActionVisibility("#hdrNewFolderBtn", decisions.createFolder, source);
        setDocumentHubActionVisibility("#hdrMoveBtn", decisions.move, source);
        setDocumentHubActionVisibility("#hdrDeleteBtn", decisions.delete, source);
        setDocumentHubActionVisibility("#hdrDownloadBtn", decisions.download && hub.selectedItem?.type === "file", source);
        setDocumentHubActionVisibility("#backupTabItem", decisions.backup, source);
        setDocumentHubActionVisibility(".pin-admin-only", decisions.confidential, source);
        setDocumentHubActionVisibility(".dh-restore-action", hasDocumentHubPermission("restore"), source);
        setDocumentHubActionVisibility(".dh-version-restore-action", hasDocumentHubPermission("versionRestore"), source);
        $(".dh-permission-action[data-dh-permission]").each(function () {
            const permissionName = $(this).data("dh-permission");
            setDocumentHubActionVisibility(this, hasDocumentHubPermission(permissionName), `${source}:${permissionName}`);
        });

        $("#hdrMoveBtn").prop("disabled", !selected || !decisions.move);
        $("#hdrDeleteBtn").prop("disabled", !selected || !decisions.delete);
        $("#hdrDownloadBtn").prop("disabled", hub.selectedItem?.type !== "file" || !decisions.download);

        if (!decisions.backup && $("#backupView").hasClass("active")) {
            const explorerTab = document.querySelector('[data-bs-target="#explorerView"]');
            if (explorerTab && window.bootstrap?.Tab) bootstrap.Tab.getOrCreateInstance(explorerTab).show();
        }

    }

    function applyPermissions() {
        applyDocumentHubPermissions("legacy applyPermissions wrapper");
    }

    function canCreateFolders() {
        return hasDocumentHubPermission("createFolder");
    }

    function traceLoadHubCall(reason, data) {
        console.trace("loadHub called", { reason, ...(data || {}) });
    }

    function requestLoadHub(reason, data) {
        traceLoadHubCall(reason, data);
        loadHub();
    }

    function openFolderFromGrid(folderId, e) {
        if (e) {
            e.preventDefault();
            e.stopPropagation();
            if (e.stopImmediatePropagation) e.stopImmediatePropagation();
        }
        debugFolderMenu("openFolderFromGrid", {
            folderId,
            eventType: e?.type || "",
            eventTarget: e?.target?.className || e?.target?.tagName,
            currentFolderId: hub.folderId,
            search: hub.search
        });
        goFolder(folderId);
        return false;
    }

    function openFileFromGrid(fileId, e) {
        if (e) {
            e.preventDefault();
            e.stopPropagation();
            if (e.stopImmediatePropagation) e.stopImmediatePropagation();
        }
        debugFolderMenu("openFileFromGrid", {
            fileId,
            eventType: e?.type || "",
            eventTarget: e?.target?.className || e?.target?.tagName,
            currentFolderId: hub.folderId,
            search: hub.search
        });
        openFile(fileId, "view");
        return false;
    }

    function cancelPendingSearchReload(reason) {
        const canceled = !!hubSearchInputHandler?.cancel?.();
        debugSearchReload("pending-search-cancel-check", {
            reason,
            canceled,
            currentSearch: hub.search,
            inputValue: $("#hubSearch").val(),
            activeElementId: document.activeElement?.id || "",
            activeElementClass: document.activeElement?.className || ""
        });
        return canceled;
    }

    function bindFolderMenuCaptureHandlers() {
        const grid = document.getElementById("folderGrid");
        if (!grid || grid.dataset.folderMenuCaptureBound === "1") return;
        grid.dataset.folderMenuCaptureBound = "1";

        grid.addEventListener("click", function (e) {
            const btn = e.target.closest(".folder-menu-btn");
            if (!btn || !grid.contains(btn)) return;

            debugFolderMenu("folderGrid:capture-click-folder-menu", {
                menuId: btn.dataset.menuId,
                eventTarget: e.target?.className || e.target?.tagName,
                folderGridChildren: $("#folderGrid").children().length
            });
            cancelPendingSearchReload("folder-menu-click");
            toggleItemMenu(e, btn);
        }, true);

        ["mousedown", "dblclick", "dragstart"].forEach(eventName => {
            grid.addEventListener(eventName, function (e) {
                const menuHost = e.target.closest(".item-menu-host,.folder-menu-btn");
                if (!menuHost || !grid.contains(menuHost)) return;

                debugFolderMenu(`folderGrid:capture-${eventName}-blocked`, {
                    menuId: menuHost.dataset.menuId || menuHost.querySelector?.(".folder-menu-btn")?.dataset?.menuId,
                    eventTarget: e.target?.className || e.target?.tagName
                });
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();
            }, true);
        });
    }

    function closeItemMenus(e) {
        if (e?.target && $(e.target).closest(".item-menu-host,.folder-menu-btn,#hubFloatingItemMenu").length) {
            cancelPendingSearchReload("folder-menu-close");
        }
        debugFolderMenu("closeItemMenus", { target: e?.target?.className || e?.target?.tagName });
        $("#hubFloatingItemMenu").removeClass("show").empty();
        $(".doc-hub-container .item-menu-btn[aria-expanded='true']").attr("aria-expanded", "false");
    }

    function toggleItemMenu(e, btn) {
        cancelPendingSearchReload("toggle-item-menu");
        e.preventDefault();
        e.stopPropagation();
        if (e.stopImmediatePropagation) e.stopImmediatePropagation();

        const menuId = $(btn).data("menuId");
        const sourceMenuHtml = (menuId && hub.folderMenus[menuId]) || $(btn).siblings(".dropdown-menu").html();
        const $floatingMenu = $("#hubFloatingItemMenu");
        const wasOpen = $floatingMenu.hasClass("show") && btn.getAttribute("aria-expanded") === "true";
        debugFolderMenu("toggleItemMenu:click", {
            menuId,
            wasOpen,
            hasMenuHtml: !!sourceMenuHtml,
            folderGridChildrenBefore: $("#folderGrid").children().length,
            currentFoldersBefore: hub.currentFolders.length,
            selectedItem: hub.selectedItem
        });
        closeItemMenus(e);

        if (wasOpen || !sourceMenuHtml) {
            debugFolderMenu("toggleItemMenu:exit", { wasOpen, hasMenuHtml: !!sourceMenuHtml });
            return;
        }

        const rect = btn.getBoundingClientRect();
        const menuWidth = 170;
        const estimatedHeight = Math.min(320, Math.max(44, sourceMenuHtml.split("<li").length * 38));
        const hasRoomBelow = rect.bottom + estimatedHeight + 8 <= window.innerHeight;
        const top = hasRoomBelow
            ? rect.bottom + 4
            : Math.max(8, rect.top - estimatedHeight - 4);

        $floatingMenu
            .html(sourceMenuHtml)
            .css({
                top: Math.round(top) + "px",
                left: Math.round(Math.max(8, Math.min(rect.right - menuWidth, window.innerWidth - menuWidth - 8))) + "px"
            })
            .addClass("show");

        $(btn).attr("aria-expanded", "true");
        debugFolderMenu("toggleItemMenu:opened", {
            menuId,
            folderGridChildrenAfter: $("#folderGrid").children().length,
            currentFoldersAfter: hub.currentFolders.length,
            selectedItem: hub.selectedItem
        });
    }

