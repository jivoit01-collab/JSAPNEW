    function restoreVersion(fileId, versionNumber) {
        if (!hasDocumentHubPermission("versionRestore")) {
            showToast("You do not have permission to restore versions.", "error");
            return;
        }
        showConfirm("Restore Version", `Restore version ${versionNumber} as the current active version?`, "Restore", function () {
            $.post("/DocumentHub/RestoreVersion", { fileId, versionNumber }).done(function (res) {
                showToast(res.message, res.success ? "success" : "error");
                $("#listModal").modal("hide");
                requestLoadHub("restoreVersion:done", { fileId, versionNumber });
            });
        });
    }

    function showActivityLog(fileId) {
        $.get("/DocumentHub/ActivityLog", { fileId }).done(function (res) {
            const rows = (res.data || []).map(a => `
                <tr>
                    <td class="small text-muted">${fmtDate(a.activityDate)}</td>
                    <td class="small">${escHtml(a.userName)}</td>
                    <td class="small font-weight-bold">${escHtml(a.action)}</td>
                    <td class="small">${escHtml(a.details || "")}</td>
                </tr>`).join("");
