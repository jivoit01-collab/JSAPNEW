    /* ─────────────────────────────────────────────
       RENDER — Sidebar tree
    ───────────────────────────────────────────── */
    function renderSidebarTree() {
        const tree = buildTree(hub.allFolders.filter(x => !x.isDeleted));
        const inner = renderTreeNodes(tree);
        $("#folderTreeContainer").html(`
            <ul class="tree-list" style="padding-left:0;">
                <li class="tree-node-item">
                    <div class="tree-row ${hub.folderId === null && !hub.filter ? "active" : ""}"
                         onclick="goFolder(null)" data-tree-folder-id="null">
                        <span class="tree-arrow-spacer"></span>
                        <i class="fa-solid fa-house-laptop text-primary"></i>
                        <span class="tree-label">Root Directory</span>
                    </div>
                    <div class="tree-node-children show">${inner}</div>
                </li>
            </ul>`
         );
    }

    function buildTree(folders) {
        const map = {};
        folders.forEach(f => map[f.folderId] = { ...f, children: [] });
        const roots = [];
        folders.forEach(f => {
            const node = map[f.folderId];
            (f.parentFolderId && map[f.parentFolderId]) ? map[f.parentFolderId].children.push(node) : roots.push(node);
        });
        return roots;
    }

    function renderTreeNodes(nodes) {
        if (!nodes || !nodes.length) return "";
        return `<ul class="tree-list">` + nodes.map(n => {
            const hasKids  = n.children && n.children.length;
            const isActive = hub.folderId === n.folderId;
            const isOpen   = sessionStorage.getItem(`fo_${n.folderId}`) === "1";
            const arrow    = hasKids
                ? `<i class="fa-solid fa-chevron-right tree-arrow ${isOpen ? "rotate-90" : ""}" onclick="toggleTree(${n.folderId},event)"></i>`
                : `<span class="tree-arrow-spacer"></span>`;
            const icon     = n.isConfidential ? "fa-solid fa-folder-lock text-warning"
                           : (isActive        ? "fa-solid fa-folder-open text-primary"
                                              : "fa-solid fa-folder text-secondary");
            const kids     = hasKids
                ? `<div class="tree-node-children ${isOpen ? "show" : ""}" id="treeKids_${n.folderId}">${renderTreeNodes(n.children)}</div>`
                : "";
            return `
                <li class="tree-node-item">
                    <div class="tree-row ${isActive ? "active" : ""}" onclick="goFolder(${n.folderId})" data-tree-folder-id="${n.folderId}">
                        ${arrow}
                        <i class="${icon}"></i>
                        <span class="text-truncate" style="max-width:140px;" title="${escHtml(n.folderName)}">${escHtml(n.folderName)}</span>
                        <span class="count">${n.fileCount}</span>
                    </div>
                    ${kids}
                </li>`;
        }).join("") + `</ul>`;
    }

    function toggleTree(folderId, e) {
        e.stopPropagation();
        const key = `fo_${folderId}`;
        sessionStorage.setItem(key, sessionStorage.getItem(key) === "1" ? "0" : "1");
        requestLoadHub("toggleTree", { folderId });
    }

    /* ─────────────────────────────────────────────
       RENDER — Folders
    ───────────────────────────────────────────── */
    function renderFolders() {
        const folders = hub.currentFolders;
