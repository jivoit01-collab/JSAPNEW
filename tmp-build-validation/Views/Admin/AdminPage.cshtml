    /* ══════════════════════════════════════════
    SCROLL BUTTONS — show after 200px
    ══════════════════════════════════════════ */
    window.addEventListener('scroll', function () {
    const btns = document.getElementById('scroll-btns');
    btns.classList.toggle('visible', window.scrollY > 200);
    });

    /* ══════════════════════════════════════════
    TOP SCROLL SYNC (mirrors horizontal scroll
    bar above each table)
    ══════════════════════════════════════════ */
    (function () {
    const wraps  = document.querySelectorAll('.t-wrap');
    const tops   = document.querySelectorAll('.top-scroll');
    const inners = document.querySelectorAll('.top-scroll-inner');

    wraps.forEach((wrap, i) => {
    const top   = tops[i];
    const inner = inners[i];
    const table = wrap.querySelector('table');
    if (!top || !inner || !table) return;

    let lockTop = false, lockWrap = false;

    top.addEventListener('scroll', function () {
    if (lockWrap) return;
    lockTop = true;
    wrap.scrollLeft = top.scrollLeft;
    lockTop = false;
    });

    wrap.addEventListener('scroll', function () {
    if (lockTop) return;
    lockWrap = true;
    top.scrollLeft = wrap.scrollLeft;
    lockWrap = false;
    });

    function syncWidth() {
    requestAnimationFrame(() => {
    inner.style.width = table.scrollWidth + 'px';
    });
    }

    syncWidth();
    window.addEventListener('resize', syncWidth);
    new MutationObserver(syncWidth).observe(wrap, { childList: true, subtree: true });
    });
    })();

    function exportCurrentTab() {
    var activeTab = $(".tp.on").attr("id");

    var tab = activeTab ? activeTab.replace("tp-", "") : null;
    if (!tab) { alert("No active tab found"); return; }

    var data = pgState[tab] ? pgState[tab].data : null;
    if (!data || !data.length) { alert("No data to export"); return; }

    var fromDate = $("#fromDate").val() || "all";
    var toDate   = $("#toDate").val()   || "";
    var filename = tab + "_export_" + fromDate + (toDate ? "_to_" + toDate : "") + ".csv";

    var rows = [];

    if (tab === "maker") {
    rows.push(["Account Name","Voucher No","Voucher Date","Bill Amount","Maker Remark","Maker Status","Attachment"]);
    data.forEach(function(x) {
    rows.push([
    x.accountName    || "",
    x.vchNumber      || "",
    x.voucherDate    || "",
    x.billAmount     || "",
    x.makerRemark    || "",
    x.makerStatus    || "",
    x.attachmentPath ? "Yes" : "No"
    ]);
    });
    // Totals
    var totalAmt = data.reduce(function(s,x){ return s + (parseFloat(x.billAmount)||0); }, 0);
    rows.push([]);
    rows.push(["","","Total Bill Amount","₹" + totalAmt.toLocaleString("en-IN"),"","",""]);
    }

    else if (tab === "checker") {
    rows.push(["Account Name","Voucher No","Voucher Date","Bill Amount","Supplier Ref","Due Date","Attachment","Maker Remark","Checker Status","Checker Remark","Serial No"]);
    data.forEach(function(x) {
    rows.push([
    x.accountName    || "",
    x.vchNumber      || "",
    x.voucherDate    || "",
    x.billAmount     || "",
    x.supplierRef    || "",
    x.dueDate        || "",
    x.attachmentPath ? "Yes" : "No",
    x.makerRemark    || "",
    x.checkerStatus  || "",
    x.checkerRemark  || "",
    x.serialNumber   || ""
    ]);
    });
    var totalAmt = data.reduce(function(s,x){ return s + (parseFloat(x.billAmount)||0); }, 0);
    rows.push([]);
    rows.push(["","","Total Bill Amount","₹" + totalAmt.toLocaleString("en-IN"),"","","","","","",""]);
    }

    else if (tab === "invoice") {
    rows.push(["Account Name","Voucher No","Voucher Date","Bill Amount","Checker Status","Payment Status"]);
    data.forEach(function(x) {
    rows.push([
    x.accountName   || "",
    x.vchNumber     || "",
    x.voucherDate   || "",
    x.billAmount    || "",
    x.checkerStatus || "",
    x.paymentStatus || ""
    ]);
    });
    var totalAmt    = data.reduce(function(s,x){ return s + (parseFloat(x.billAmount)||0); }, 0);
    var paidCount   = data.filter(function(x){ return (x.paymentStatus||"").toLowerCase()==="paid"; }).length;
    var unpaidCount = data.length - paidCount;
    rows.push([]);
    rows.push(["","","Total Bill Amount","₹" + totalAmt.toLocaleString("en-IN"),"",""]);
    rows.push(["","","Paid","" + paidCount,"Unpaid","" + unpaidCount]);
    }

    else if (tab === "paymentchecker") {
    rows.push(["Account Name","Voucher No","Voucher Date","Bill Amount","Payment Date","Payment Status"]);
    data.forEach(function(x) {
    rows.push([
    x.accountName   || "",
    x.vchNumber     || "",
    x.voucherDate   || "",
    x.billAmount    || "",
    x.paymentDate   || "",
    x.paymentStatus || ""
    ]);
    });
    var totalAmt = data.reduce(function(s,x){ return s + (parseFloat(x.billAmount)||0); }, 0);
    rows.push([]);
    rows.push(["","","Total Paid Amount","₹" + totalAmt.toLocaleString("en-IN"),"",""]);
    }

    downloadCSV(rows, filename);
    }
    /* ═══════════════════════════════════════
    SHARED CSV EXPORT UTILITY
    Add once per page — handles all escaping,
    BOM, and clean formatting.
    ═══════════════════════════════════════ */
    function downloadCSV(rows, filename) {
    var BOM = "\uFEFF"; // UTF-8 BOM — ensures Excel opens with correct encoding
    var csv = BOM + rows.map(function(row) {
    return row.map(function(cell) {
    var v = (cell === null || cell === undefined) ? "" : String(cell);
    // Normalise whitespace — remove line breaks, collapse spaces
    v = v.replace(/[\r\n\t]+/g, " ").replace(/\s{2,}/g, " ").trim();
    // Escape double-quotes
    v = v.replace(/"/g, '""');
    // Always quote every cell for safety
    return '"' + v + '"';
    }).join(",");
    }).join("\r\n");

    var blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    var url  = URL.createObjectURL(blob);
    var a    = document.createElement("a");
    a.href     = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    }



    function initAdminTopScroll() {

    const topScroll = document.getElementById('adminTopScroll');
    const topInner = document.getElementById('adminTopScrollInner');

    if (!topScroll || !topInner) return;

    function bindActiveTable() {

    const activeTab = document.querySelector('.tp.on');
    if (!activeTab) return;

    const tableWrap = activeTab.querySelector('.t-wrap');
    const table = activeTab.querySelector('table');

    if (!tableWrap || !table) return;

    topInner.style.width = table.scrollWidth + 'px';

    topScroll.onscroll = function () {
    tableWrap.scrollLeft = topScroll.scrollLeft;
    };

    tableWrap.onscroll = function () {
    topScroll.scrollLeft = tableWrap.scrollLeft;
    };
    }

    bindActiveTable();

    const tabButtons = document.querySelectorAll('.tab-btn');

    tabButtons.forEach(btn => {
    btn.addEventListener('click', function () {

    setTimeout(() => {
    bindActiveTable();
    }, 100);

    });
    });

    window.addEventListener('resize', bindActiveTable);
    }

    window.addEventListener('load', initAdminTopScroll);
</script>

