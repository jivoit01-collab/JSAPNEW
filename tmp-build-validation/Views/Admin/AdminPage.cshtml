<div class="admin-dashboard-shell">
<nav class="premium-nav">
    <div class="nav-glass">
        <div class="nav-left-section">
            <div class="brand-logo-wrap">
                <img src="~/images/logo.png" class="brand-logo" alt="Akal Rozgar Yojana logo" />
            </div>
            <div class="brand-content">
                <div class="ary-brand-header">Akal Rozgar Yojana A U/O JWPL</div>
                <div class="brand-title">Wellness Finance Operations</div>
                <div class="brand-subtitle">Healthy Oils • Super Juices • Smart Living</div>
            </div>
        </div>

        <div class="product-slider" aria-label="Product showcase">
            <div class="product-track">
                <img src="@Url.Content("~/images/canola.jpg")" class="product-img clickable-product" alt="Canola oil" />
                <img src="@Url.Content("~/images/5L-Pomace-new.tif-.png")" class="product-img clickable-product" alt="Pomace oil" />
                <img src="@Url.Content("~/images/groundnut-oil.jpg")" class="product-img clickable-product" alt="Groundnut oil" />
                <img src="@Url.Content("~/images/Desi-Ghee.jpg")" class="product-img clickable-product" alt="Desi ghee" />
                <img src="@Url.Content("~/images/download.jpg")" class="product-img clickable-product" alt="Wellness product" />
            </div>
        </div>

        <div class="module-box">
            <span class="module-dot"></span>
            <i class="fa-solid fa-shield-halved"></i>
            <span>Admin Dashboard</span>
        </div>
    </div>
</nav>
<div class="body admin-dashboard-body">

    <!-- PRODUCT MODAL -->
    <div class="product-modal" id="productModal">
        <span class="close-modal">&times;</span>
        <img id="modalImage" class="modal-product-image" />
    </div>

    <!-- FILTER -->
    <div class="filter-card dashboard-filter-card">
        <div class="f-group">
            <span class="f-label">From Date</span>
            <input type="date" class="f-input" id="fromDate" />
        </div>
        <div class="f-group">
            <span class="f-label">To Date</span>
            <input type="date" class="f-input" id="toDate" />
        </div>
        <div class="f-group grow">
            <span class="f-label">Account Name</span>
            <input type="text" class="f-input" id="accountName" placeholder="Search vendor..." />
        </div>
            <div class="admin-filter-actions">

                <button class="btn btn-dark admin-search-btn"
                        onclick="loadAllData()">

                    <i class="fa-solid fa-magnifying-glass"></i>

                    Search

                </button>

                <button class="btn btn-export"
                        onclick="exportCurrentTab()">

                    <i class="fa-solid fa-file-excel"></i>

                    Export

                </button>

            </div>
    </div>

    <!-- =========================================================
         KPI GRID — REDESIGNED
    ========================================================= -->
    <div class="kpi-grid">

        <div class="kpi-card k-blue">
            <div class="kpi-top">
                <div>
                    <div class="kpi-val" id="totalBills">0</div>
                    <div class="kpi-label">Total Bills</div>
                </div>
                <div class="kpi-icon">
                    <i class="fa-solid fa-file-invoice"></i>
                </div>
            </div>
            <div class="kpi-bottom">
                <svg class="kpi-wave" viewBox="0 0 80 28" fill="none">
                    <polyline points="0,22 12,14 24,18 36,8 48,16 60,6 72,12 80,8"
                              stroke="#3B82F6" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div class="kpi-trend"><i class="fa-solid fa-arrow-trend-up fa-xs"></i> All Entries</div>
            </div>
        </div>

        <div class="kpi-card k-amber">
            <div class="kpi-top">
                <div>
                    <div class="kpi-val" id="pendingMaker">0</div>
                    <div class="kpi-label">Pending Maker</div>
                </div>
                <div class="kpi-icon">
                    <i class="fa-solid fa-clock"></i>
                </div>
            </div>
            <div class="kpi-bottom">
                <svg class="kpi-wave" viewBox="0 0 80 28" fill="none">
                    <polyline points="0,10 12,18 24,12 36,20 48,10 60,16 72,8 80,14"
                              stroke="#F59E0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div class="kpi-trend"><i class="fa-solid fa-hourglass-half fa-xs"></i> Awaiting</div>
            </div>
        </div>

        <div class="kpi-card k-green">
            <div class="kpi-top">
                <div>
                    <div class="kpi-val" id="approvedChecker">0</div>
                    <div class="kpi-label">Approved Checker</div>
                </div>
                <div class="kpi-icon">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
            </div>
            <div class="kpi-bottom">
                <svg class="kpi-wave" viewBox="0 0 80 28" fill="none">
                    <polyline points="0,18 12,10 24,16 36,6 48,14 60,4 72,10 80,6"
                              stroke="#10B981" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div class="kpi-trend"><i class="fa-solid fa-check fa-xs"></i> Verified</div>
            </div>
        </div>

        <div class="kpi-card k-purple">
            <div class="kpi-top">
                <div>
                    <div class="kpi-val" id="totalPaid">0</div>
                    <div class="kpi-label">Total Paid</div>
                </div>
                <div class="kpi-icon">
                    <i class="fa-solid fa-indian-rupee-sign"></i>
                </div>
            </div>
            <div class="kpi-bottom">
                <svg class="kpi-wave" viewBox="0 0 80 28" fill="none">
                    <polyline points="0,20 12,12 24,18 36,8 48,18 60,10 72,14 80,8"
                              stroke="#8B5CF6" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div class="kpi-trend"><i class="fa-solid fa-wallet fa-xs"></i> Cleared</div>
            </div>
        </div>

    </div>

    <!-- TABS -->
    <div class="tab-bar">
        <button class="tab-btn on" onclick="switchTab('maker',this)" type="button">
            <i class="fa-solid fa-pen-to-square"></i> Maker Activity
