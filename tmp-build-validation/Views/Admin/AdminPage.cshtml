    function confirmDeleteAttachment()
    {
    $.ajax({

    url: '/Admin/DeleteAttachment',

    type: 'POST',

    contentType: 'application/json',

    data: JSON.stringify({
    vchNumber: deleteVoucher
    }),

    success: function ()
    {
    closeConfirm();

    loadMaker();

    loadChecker();

    loadInvoicePayment();

    loadPaymentChecker();

    loadSummary();
    }
    });
    }

    $(document).on("click", ".adminRejectCheckerBtn", function () {
    const btn = $(this);
    const row = btn.closest("tr");
    const vch = btn.data("vch");
    const account = btn.data("account");
    const amount = btn.data("amount");
    const remark = row.find(".adminCheckerRemark").val() || "Rejected by Admin";

    $("#confirmTitle").text("Reject Checker Entry");
    $("#confirmSubtitle").text("Admin correction");
    $("#confirmWarningText").html("You are about to <strong>reject this checker entry</strong>. This will return the bill to rejected status.");
    $("#meta-vch").text(vch);
    $("#meta-account").text(account || "-");
    $("#meta-amount").text("₹" + (amount || "-"));
    $("#meta-remark").text(remark);
    $("#confirmProceed")
    .html('<i class="fa-solid fa-circle-xmark"></i> Reject')
    .css({ "background": "linear-gradient(135deg,#dc2626,#ef4444)" });

    $("#confirmOverlay").addClass("show");
    $("#confirmProceed").off("click").on("click", function () {
    rejectCheckerEntry(vch, remark, btn);
    });
    });

    function rejectCheckerEntry(vch, remark, btn) {
    btn.prop("disabled", true);

    $.ajax({
    url: '/Admin/RejectCheckerEntry',
    type: 'POST',
    contentType: 'application/json',
    data: JSON.stringify({
    vchNumber: vch,
    remark: remark
    }),
    success: function (res) {
    closeConfirm();

    if (!res || res.success === false) {
    alert((res && res.message) || "Unable to reject checker entry.");
    btn.prop("disabled", false);
    return;
    }

    loadChecker();
    loadMaker();
    loadInvoicePayment();
    loadPaymentChecker();
    loadSummary();
    },
    error: function () {
    closeConfirm();
    alert("Unable to reject checker entry.");
    btn.prop("disabled", false);
    }
    });
    }

