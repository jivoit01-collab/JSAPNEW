<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
    
    /* ══════════════════════════════════════════
    PAGINATION STATE
    ══════════════════════════════════════════ */
    var pgState = {
    maker:          { page: 1, perPage: 10, data: [] },
    checker:        { page: 1, perPage: 10, data: [] },
    invoice:        { page: 1, perPage: 10, data: [] },
    paymentchecker: { page: 1, perPage: 10, data: [] }
    };

    /* ══════════════════════════════════════════
    PAGINATION HELPERS
    ══════════════════════════════════════════ */
    function renderPagination(tab) {
    var s     = pgState[tab];
    var total = s.data.length;
    var pages = Math.ceil(total / s.perPage);
    var start = (s.page - 1) * s.perPage;
    var end   = Math.min(start + s.perPage, total);

    $('#' + tab + '-from').text(total ? start + 1 : 0);
    $('#' + tab + '-to').text(end);
    $('#' + tab + '-total').text(total);

    var btnContainer = $('#pg-btns-' + tab);
    btnContainer.empty();

    if (pages <= 1) return;

    // Prev
    btnContainer.append(
    '<button class="dt-pg-btn"' + (s.page === 1 ? ' disabled' : '') +
    ' onclick="goPage(\'' + tab + '\',' + (s.page - 1) + ')">' +
    '<i class="fa-solid fa-chevron-left fa-xs"></i></button>'
    );

    // Page numbers with ellipsis
    var pageNums = buildPageNums(s.page, pages);
    pageNums.forEach(function(p) {
    if (p === '...') {
    btnContainer.append('<span class="dt-pg-dots">…</span>');
    } else {
    btnContainer.append(
    '<button class="dt-pg-btn' + (p === s.page ? ' active' : '') +
    '" onclick="goPage(\'' + tab + '\',' + p + ')">' + p + '</button>'
    );
    }
    });

    // Next
    btnContainer.append(
    '<button class="dt-pg-btn"' + (s.page === pages ? ' disabled' : '') +
    ' onclick="goPage(\'' + tab + '\',' + (s.page + 1) + ')">' +
    '<i class="fa-solid fa-chevron-right fa-xs"></i></button>'
    );
    }

    function buildPageNums(current, total) {
    if (total <= 7) {
    var arr = [];
    for (var i = 1; i <= total; i++) arr.push(i);
    return arr;
    }
    var pages = [1];
    if (current > 3) pages.push('...');
    var lo = Math.max(2, current - 1);
    var hi = Math.min(total - 1, current + 1);
    for (var j = lo; j <= hi; j++) pages.push(j);
    if (current < total - 2) pages.push('...');
    pages.push(total);
    return pages;
    }

    function goPage(tab, page) {
    pgState[tab].page = page;
    renderTabBody(tab);
    renderPagination(tab);
    }

    function changePerPage(tab, val) {
    pgState[tab].perPage = parseInt(val);
    pgState[tab].page    = 1;
    renderTabBody(tab);
    renderPagination(tab);
    }

