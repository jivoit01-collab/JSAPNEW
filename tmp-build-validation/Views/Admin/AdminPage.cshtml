    function safeText(value) {
    if (value === null || value === undefined || value === '') return '-';

    return $('<div>').text(value).html();
    }

    function safeAttr(value) {
    return safeText(value).replace(/"/g, '&quot;');
    }

    function safeValueAttr(value) {
    if (value === null || value === undefined) return '';
    return $('<div>').text(value).html().replace(/"/g, '&quot;');
    }

    function statusBadge(status) {
    const value = safeText(status);
    const normalized = String(status || '').toLowerCase();
    let cls = 'sb-neutral';
    let icon = 'fa-minus';

    if (normalized.includes('approved') || normalized === 'paid') {
    cls = 'sb-approved';
    icon = 'fa-check';
    } else if (normalized.includes('pending') || normalized.includes('unpaid')) {
    cls = 'sb-pending';
    icon = 'fa-clock';
    } else if (normalized.includes('reject')) {
    cls = 'sb-rejected';
    icon = 'fa-xmark';
    }

    return `<span class="status-badge ${cls}"><i class="fa-solid ${icon}"></i>${value}</span>`;
    }

    function attachmentLink(path) {
    if (!path) return '<span class="muted-pill"><i class="fa-regular fa-file"></i>No File</span>';

    return `
    <a class="attach-view" target="_blank" rel="noopener" href="${safeAttr(path)}">
    <i class="fa-solid fa-eye"></i>
    View
    </a>`;
    }

    function checkerRejectButton(x, status) {
    if (String(status || '').toLowerCase() === 'rejected') {
    return '<span class="status-badge sb-rejected"><i class="fa-solid fa-ban"></i> Rejected</span>';
    }

    return `
    <button class="btn-reject adminRejectCheckerBtn"
    type="button"
    data-vch="${safeValueAttr(x.vchNumber)}"
    data-account="${safeValueAttr(x.accountName ?? '')}"
    data-amount="${safeValueAttr(x.billAmount ?? '')}">
    <i class="fa-solid fa-xmark"></i> Reject
