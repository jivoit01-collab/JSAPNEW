@{
    ViewData["Title"] = "AdminPage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/bill-verification.css" />

<div class="modern-admin-wrapper">

    <!-- HERO SECTION -->
    <div class="hero-section">

        <div class="hero-content">
            <div class="hero-text">
                <h1>
                    Welcome back,
                    <span>@User.Identity.Name</span>
                </h1>

                <p>
                    JIVO Wellness — Enterprise Bill Verification &
                    Invoice Payment Management System
                </p>
            </div>

            <div class="hero-logo">
                <img src="~/images/logo.png" alt="JIVO" />
            </div>
        </div>

    </div>

    <!-- HEADER -->
    <div class="dashboard-header">

        <div>
            <h2>Admin Dashboard — Bill Verification</h2>
            <span>Overview and Activity Tracker</span>
        </div>

        <div class="live-status">
            Real-time Activity
        </div>

    </div>

    <!-- SUMMARY CARDS -->
    <div class="stats-grid">

        <div class="stat-card blue">
            <div class="stat-icon">📄</div>

            <div class="stat-info">
                <h4>Total Bills</h4>
                <h2 id="totalBills">0</h2>
            </div>
        </div>

        <div class="stat-card cyan">
            <div class="stat-icon">🕒</div>

            <div class="stat-info">
                <h4>Pending Maker</h4>
                <h2 id="pendingMaker">0</h2>
            </div>
        </div>

        <div class="stat-card purple">
            <div class="stat-icon">✔</div>

            <div class="stat-info">
                <h4>Approved Checker</h4>
                <h2 id="approvedChecker">0</h2>
            </div>
        </div>

        <div class="stat-card green">
            <div class="stat-icon">₹</div>

            <div class="stat-info">
                <h4>Paid Invoice</h4>
                <h2 id="totalPaid">0</h2>
            </div>
        </div>

    </div>

    <!-- FILTER SECTION -->
    <div class="filter-section">

        <div class="filter-grid">

            <div class="filter-box">
                <label>From Date</label>
                <input type="date" id="fromDate" />
            </div>

            <div class="filter-box">
                <label>To Date</label>
                <input type="date" id="toDate" />
            </div>

            <div class="filter-box search-box">
                <label>Account Name</label>
                <input type="text"
                       id="accountName"
                       placeholder="Search account..." />
            </div>

            <div class="filter-btn">
                <button id="searchBtn">
                    Search
                </button>
            </div>

        </div>

    </div>

    <!-- ACTIVITY -->
    <div class="activity-wrapper">

        <div class="activity-header">
            <h3>User Activity Tracker</h3>
        </div>

        <!-- TABS -->
        <div class="modern-tabs">

            <button class="modern-tab active"
                    onclick="switchTab('maker', this)">
                Maker Activity
            </button>

            <button class="modern-tab"
                    onclick="switchTab('checker', this)">
                Checker Activity
            </button>

            <button class="modern-tab"
                    onclick="switchTab('invoice', this)">
                Invoice Payment
            </button>

            <button class="modern-tab"
                    onclick="switchTab('payment', this)">
                Payment Checker
            </button>

        </div>

        <!-- MAKER -->
        <div class="admin-section active" id="section-maker">

            <div class="table-card-modern">

                <div class="table-top">

                    <h3>Maker Activity</h3>

                    <input class="table-filter"
                           placeholder="Filter rows..."
                           oninput="filterTable('makerTable', this.value)" />

                </div>

                <div class="table-responsive">

                    <table class="modern-table" id="makerTable">

                        <thead>
                            <tr>

                                <th>Account</th>

                                <th>Voucher</th>

                                <th>Date</th>

                                <th>Amount</th>

                                <th>Status</th>

                                <th>Attachment</th>

                                <th>Delete</th>

                            </tr>
                        </thead>

                        <tbody id="makerBody">
                            <tr>
                                <td colspan="7">Loading...</td>
                            </tr>
                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- CHECKER -->
        <div class="admin-section" id="section-checker">

            <div class="table-card-modern">

                <div class="table-top">

                    <h3>Checker Activity</h3>

                    <input class="table-filter"
                           placeholder="Filter rows..."
                           oninput="filterTable('checkerTable', this.value)" />

                </div>

                <div class="table-responsive">

                    <table class="modern-table" id="checkerTable">

                        <thead>
                            <tr>
                                <th>Account</th>
                                <th>Voucher</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th> Remark</th>
                                <th>Status</th>
                                <th>Attachment</th>
                                <th>Delete</th>
                            </tr>
                        </thead>

                        <tbody id="checkerBody">
                            <tr>
                                <td colspan="7">Loading...</td>
                            </tr>
                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- INVOICE -->
        <div class="admin-section" id="section-invoice">

            <div class="table-card-modern">

                <div class="table-top">

                    <h3>Invoice Payment</h3>

                    <input class="table-filter"
                           placeholder="Filter rows..."
                           oninput="filterTable('invoiceTable', this.value)" />

                </div>

                <div class="table-responsive">

                    <table class="modern-table" id="invoiceTable">

                        <thead>
                            <tr>
                                <th>Account</th>
                                <th>Voucher</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Payment Status</th>
                                <th>Payment Date</th>
                                <th>Attachment</th>
                                <th>Delete</th>
                            </tr>
                        </thead>

                        <tbody id="invoiceBody">
                            <tr>
                                <td colspan="8">Loading...</td>
                            </tr>
                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- PAYMENT -->
        <div class="admin-section" id="section-payment">

            <div class="table-card-modern">

                <div class="table-top">

                    <h3>Payment Checker</h3>

                    <input class="table-filter"
                           placeholder="Filter rows..."
                           oninput="filterTable('paymentTable', this.value)" />

                </div>

                <div class="table-responsive">

                    <table class="modern-table" id="paymentTable">

                        <thead>
                            <tr>
                                <th>Account</th>
                                <th>Voucher</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Remark</th>
                                <th>Attachment</th>
                                <th>Delete</th>
                            </tr>
                        </thead>

                        <tbody id="paymentBody">
                            <tr>
                                <td colspan="8">Loading...</td>
                            </tr>
                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>
    <!-- DELETE MODAL -->

    <div class="modal fade"
         id="deleteModal"
         tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <div class="modal-header">

                    <h5 class="modal-title">
                        Delete Attachment
                    </h5>

                    <button type="button"
                            class="btn-close"
                            onclick="closeModal()">
                    </button>

                </div>

                <div class="modal-body">

                    Are you sure you want to delete this attachment?

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            onclick="closeModal()">

                        Cancel

                    </button>

                    <button type="button"
                            class="btn btn-danger"
                            id="confirmDeleteBtn">

                        Delete

                    </button>

                </div>

            </div>

        </div>

    </div>
    <!-- PDF VIEWER -->

    <div id="pdfContainer" class="pdf-modal">

        <div class="pdf-header">

            <button onclick="closePdf()">
                Close
            </button>

        </div>

        <iframe id="pdfFrame"></iframe>

    </div>
</div>




@section scripts {

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

        let currentVchNumber = null;
        let currentRow = null;

        // TAB SWITCH
        function switchTab(tab, el) {

        document.querySelectorAll('.admin-section')
        .forEach(s => s.classList.remove('active'));

        document.querySelectorAll('.modern-tab')
        .forEach(b => b.classList.remove('active'));

        document.getElementById('section-' + tab)
        .classList.add('active');

        el.classList.add('active');
        }

        // function filterStatus(tableId, status) {

        // const rows =
        // document.querySelectorAll(
        // '#' + tableId + ' tbody tr'
        // );

        // rows.forEach(row => {

        // if (!status) {

        // row.style.display = '';

        // return;
        // }

        // const rowText =
        // row.innerText.toLowerCase();

        // if (rowText.includes(status.toLowerCase())) {

        // row.style.display = '';
        // }
        // else {

        // row.style.display = 'none';
        // }
        // });
        // }

        // GET FILTERS
        function getFilters() {

        return {

        fromDate: $('#fromDate').val(),

        toDate: $('#toDate').val(),

        accountName:
        $('#accountName').val().trim() || null
        };
        }

        // BADGE
        function badge(status) {

        if (!status || status === '-')
        return '-';

        const s = status.toLowerCase();

        if (s === 'approved')
        return `<span class="badge-approved">Approved</span>`;

        if (s === 'rejected')
        return `<span class="badge-rejected">Rejected</span>`;

        if (s === 'paid')
        return `<span class="badge-paid">Paid</span>`;

        if (s === 'unpaid')
        return `<span class="badge-unpaid">UnPaid</span>`;

        return `<span class="badge-pending">${status}</span>`;
        }

        // PDF OPEN
        function openPdf(path) {

        document.getElementById("pdfFrame").src = path;

        document.getElementById("pdfContainer").style.display = "flex";
        }

        // PDF CLOSE
        function closePdf() {

        document.getElementById("pdfContainer").style.display = "none";

        document.getElementById("pdfFrame").src = "";
        }

        // ATTACHMENT
        function attachHtml(item) {

        if (item.attachment === 'File' &&
        item.attachmentPath) {

        return `
        <a href="#"
        onclick="openPdf('${item.attachmentPath}')"
        class="btn-view">
        View
        </a>`;
        }

        return `<span style="color:#aaa;">No file</span>`;
        }

        // DELETE BUTTON
        function deleteBtn(item) {

        if (item.attachment === 'File') {

        return `
        <button class="btn-delete"
        onclick="openDelete(${item.vchNumber}, this)">
        Delete
        </button>`;
        }

        return `
        <button class="btn-delete" disabled>
        Delete
        </button>`;
        }

        // LOAD SUMMARY
        function loadSummary() {

        $.get('/Admin/GetSummary', function (d) {

        $('#totalBills').text(d.totalBills ?? 0);

        $('#pendingMaker').text(d.pendingMaker ?? 0);

        $('#approvedChecker')
        .text(d.approvedChecker ?? 0);

        $('#totalPaid').text(d.totalPaid ?? 0);
        });
        }

        // LOAD MAKER
        function loadMaker() {

        $('#makerBody').html(`
        <tr>
        <td colspan="8">Loading...</td>
        </tr>`);

        $.get('/Admin/GetMakerActivity',
        getFilters(),
        function (data) {

        let html = '';

        if (!data || data.length === 0) {

        html = `
        <tr>
        <td colspan="8">
        No records found
        </td>
        </tr>`;
        }
        else {

        data.forEach(item => {

        html += `
        <tr>
        <td>${item.accountName}</td>
        <td>${item.vchNumber}</td>
        <td>${item.voucherDate}</td>
        <td>${item.billAmount}</td>
      
        <td>${badge(item.makerStatus)}</td>
        <td>${attachHtml(item)}</td>
        <td>${deleteBtn(item)}</td>
        </tr>`;
        });
        }

        $('#makerBody').html(html);
        });
        }

        // LOAD CHECKER
        function loadChecker() {

        $('#checkerBody').html(`
        <tr>
        <td colspan="8">Loading...</td>
        </tr>`);

        $.get('/Admin/GetCheckerActivity',
        getFilters(),
        function (data) {

        let html = '';

        if (!data || data.length === 0) {

        html = `
        <tr>
        <td colspan="8">
        No records found
        </td>
        </tr>`;
        }
        else {

        data.forEach(item => {

        html += `
        <tr>
        <td>${item.accountName}</td>
        <td>${item.vchNumber}</td>
        <td>${item.voucherDate}</td>
        <td>${item.billAmount}</td>
        <td>${item.checkerRemark}</td>
        <td>${badge(item.checkerStatus)}</td>
        <td>${attachHtml(item)}</td>
        <td>${deleteBtn(item)}</td>
        </tr>`;
        });
        }

        $('#checkerBody').html(html);
        });
        }

        // LOAD INVOICE
        function loadInvoice() {

        $('#invoiceBody').html(`
        <tr>
        <td colspan="9">Loading...</td>
        </tr>`);

        $.get('/Admin/GetInvoiceActivity',
        getFilters(),
        function (data) {

        let html = '';

        if (!data || data.length === 0) {

        html = `
        <tr>
        <td colspan="9">
        No records found
        </td>
        </tr>`;
        }
        else {

        data.forEach(item => {

        html += `
        <tr>
        <td>${item.accountName}</td>
        <td>${item.vchNumber}</td>
        <td>${item.voucherDate}</td>
        <td>${item.billAmount}</td>
        <td>${item.dueDate}</td>
        <td>${badge(item.paymentStatus)}</td>
        <td>${item.paymentDate}</td>
        <td>${attachHtml(item)}</td>
        <td>${deleteBtn(item)}</td>
        </tr>`;
        });
        }

        $('#invoiceBody').html(html);
        });
        }

        // LOAD PAYMENT CHECKER
        function loadPaymentChecker() {

        $('#paymentBody').html(`
        <tr>
        <td colspan="8">Loading...</td>
        </tr>`);

        $.get('/Admin/GetPaymentCheckerActivity',
        getFilters(),
        function (data) {

        let html = '';

        if (!data || data.length === 0) {

        html = `
        <tr>
        <td colspan="8">
        No records found
        </td>
        </tr>`;
        }
        else {

        data.forEach(item => {

        html += `
        <tr>
        <td>${item.accountName}</td>
        <td>${item.vchNumber}</td>
        <td>${item.voucherDate}</td>
        <td>${item.billAmount}</td>
        <td>${badge(item.paymentStatus)}</td>
        <td>${item.checkerRemark ?? '-'}</td>
        <td>${attachHtml(item)}</td>
        <td>${deleteBtn(item)}</td>
        </tr>`;
        });
        }

        $('#paymentBody').html(html);
        });
        }

        // OPEN DELETE MODAL
        function openDelete(vchNumber, btn) {

        currentVchNumber = vchNumber;

        currentRow = btn.closest('tr');

        document.getElementById('deleteModal')
        .style.display = 'block';

        document.getElementById('deleteModal')
        .classList.add('show');

        let backdrop = document.createElement('div');

        backdrop.className =
        'modal-backdrop fade show';

        backdrop.id = 'customBackdrop';

        document.body.appendChild(backdrop);
        }

        // CLOSE MODAL
        function closeModal() {

        document.getElementById('deleteModal')
        .style.display = 'none';

        document.getElementById('deleteModal')
        .classList.remove('show');

        let backdrop =
        document.getElementById('customBackdrop');

        if (backdrop)
        backdrop.remove();
        }

        // READY
        $(document).ready(function () {

        loadSummary();

        loadMaker();

        loadChecker();

        loadInvoice();

        loadPaymentChecker();

        // SEARCH
        $('#searchBtn').on('click', function () {

        loadSummary();

        loadMaker();

        loadChecker();

        loadInvoice();

        loadPaymentChecker();
        });

        // DELETE
        $('#confirmDeleteBtn').on('click', function () {

        $.ajax({

        url: '/Admin/DeleteAttachment',

        method: 'POST',

        contentType: 'application/json',

        data: JSON.stringify({
        vchNumber: currentVchNumber
        }),

        success: function (res) {

        if (res.success) {

        const tds =
        currentRow.querySelectorAll('td');

        tds[tds.length - 2].innerHTML =
        '<span style="color:#aaa;">Deleted</span>';

        tds[tds.length - 1].innerHTML =
        '<button disabled>Delete</button>';

        closeModal();
        }
        },

        error: function () {

        alert('Error deleting');

        closeModal();
        }
        });
        });

        });

    </script>

}

