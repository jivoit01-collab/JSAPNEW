             id="tableWrap">

            <table class="dt invoice-payment-table"
                   id="mainTable">

                <colgroup>
                    <col class="col-account" />
                    <col class="col-voucher" />
                    <col class="col-date" />
                    <col class="col-amount" />
                    <col class="col-supplier" />
                    <col class="col-date" />
                    <col class="col-date" />
                    <col class="col-attachment" />
                    <col class="col-checker-status" />
                    <col class="col-payment-status" />
                    <col class="col-maker-remark" />
                    <col class="col-checker-remark" />
                </colgroup>

                <thead>

                    <tr>

                        <th>Account</th>
                        <th>Voucher</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Supplier Ref</th>
                        <th>Ref Date</th>
                        <th>Due Date</th>
                        <th>Attachment</th>
             
                        <th>Checker Status</th>
                        <th>Payment Status</th>
                        <th>Maker Remark</th>
                        <th>Checker Remark</th>

                    </tr>

                </thead>

                <tbody id="PaymentTable">

                    <tr>

                        <td colspan="12"
                            class="empty-row">

                            <i class="fa-solid fa-spinner fa-spin"></i>

