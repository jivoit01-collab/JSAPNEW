                 class="product-img clickable-product" />

            <img src="@Url.Content("~/images/Desi-Ghee.jpg")"
                 class="product-img clickable-product" />

            <img src="@Url.Content("~/images/71ohxqRTikL._AC_UF894,1000_QL80_.jpg")"
                 class="product-img clickable-product" />

            <!-- DUPLICATE -->
            <img src="@Url.Content("~/images/canola.jpg")"
                 class="product-img clickable-product" />

            <img src="@Url.Content("~/images/js3.png")"
                 class="product-img clickable-product" />

            <img src="@Url.Content("~/images/Pomace-2-1000x1000.png")"
                 class="product-img clickable-product" />

            <img src="@Url.Content("~/images/Desi-Ghee.jpg")"
                 class="product-img clickable-product" />

            <img src="@Url.Content("~/images/71ohxqRTikL._AC_UF894,1000_QL80_.jpg")"
