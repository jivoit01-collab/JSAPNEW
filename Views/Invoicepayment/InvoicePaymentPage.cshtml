            </div>
            <div class="kpi-bottom">
                <svg class="kpi-wave" viewBox="0 0 80 28" fill="none">
                    <polyline points="0,12 12,18 24,10 36,20 48,12 60,18 72,8 80,14"
                              stroke="#F59E0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div class="kpi-trend"><i class="fa-solid fa-clock fa-xs"></i> Pending</div>
            </div>
        </div>

        <div class="kpi-card k-green">
            <div class="kpi-top">
                <div>
                    <div class="kpi-val" id="kpi-paid">0</div>
                    <div class="kpi-label"> Vendors Pending </div>
                </div>
                <div class="kpi-icon">
                    <i class="fa-solid fa-building"></i>
                </div>
            </div>
            <div class="kpi-bottom">
                <svg class="kpi-wave" viewBox="0 0 80 28" fill="none">
                    <polyline points="0,18 12,10 24,16 36,7 48,13 60,5 72,12 80,8"
                              stroke="#22C55E" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div class="kpi-trend"><i class="fa-solid fa-users fa-xs"></i> Vendors</div>
            </div>
        </div>

        <div class="kpi-card k-purple">
            <div class="kpi-top">
                <div>
                    <div class="kpi-val" id="kpi-amount">0</div>
                    <div class="kpi-label"> Overdue Bills </div>
                </div>
                <div class="kpi-icon">
                    <i class="fa-solid fa-calendar-xmark"></i>
                </div>
            </div>
            <div class="kpi-bottom">
                <svg class="kpi-wave" viewBox="0 0 80 28" fill="none">
                    <polyline points="0,20 12,12 24,18 36,10 48,18 60,8 72,15 80,9"
                              stroke="#8B5CF6" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div class="kpi-trend"><i class="fa-solid fa-triangle-exclamation fa-xs"></i> Overdue</div>
            </div>
