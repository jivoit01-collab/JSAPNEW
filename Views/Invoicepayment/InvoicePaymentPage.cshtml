<!-- PRODUCT MODAL -->
<div id="productModal" class="product-modal">

    <span class="close-modal">&times;</span>

    <img id="modalProductImage"
         class="modal-product-image" />

</div>

<div class="body">

    <!-- KPI -->
    <div class="kpi-grid">

        <div class="kpi-card k-blue">
            <div class="kpi-val" id="kpi-total">0</div>
            <div class="kpi-label">Total Unpaid Bills</div>
        </div>

        <div class="kpi-card k-amber">
            <div class="kpi-val" id="kpi-unpaid">0</div>
            <div class="kpi-label">
                Pending Amount
            </div>
        </div>

        <div class="kpi-card k-green">
            <div class="kpi-val" id="kpi-paid">0</div>
            <div class="kpi-label"> Vendors Pending </div>
        </div>

        <div class="kpi-card k-purple">
            <div class="kpi-val" id="kpi-amount">0</div>
            <div class="kpi-label"> Overdue Bills </div>
        </div>

    </div>

    <!-- PDF -->
    <div id="pdfContainer" class="pdf-modal">

        <div class="pdf-box">

            <button onclick="closePdf()"
                    class="pdf-close">

                ×

            </button>

            <iframe id="pdfFrame"></iframe>

        </div>

    </div>

    <!-- FILTER -->
    <div class="filter-card">

        <div class="f-group">

            <span class="f-label">
                From Date
            </span>

            <input type="date"
                   id="fromDate"
                   class="f-input" />

        </div>

        <div class="f-group">

            <span class="f-label">
                To Date
            </span>

            <input type="date"
                   id="toDate"
                   class="f-input" />

        </div>

        <div class="f-group grow">

            <span class="f-label">
                Account Name
            </span>

            <input type="text"
                   id="accountName"
                   class="f-input"
                   placeholder="Search account..." />

        </div>

        <button class="btn btn-dark"
                id="searchBtn">

            <i class="fa-solid fa-magnifying-glass"></i>

            Search

        </button>

    </div>

    <!-- TABLE -->
    <div class="t-card checker-table-card">

        <div class="t-header">

            <span class="t-title">

                <i class="fa-solid fa-money-check-dollar"></i>

                Invoice Monitoring

            </span>

            <span class="t-count"
                  id="rowCount">

                0 records

            </span>

        </div>

        <!-- HINT -->
        <div class="table-slide-hint">

            <i class="fa-solid fa-arrows-left-right"></i>

            Slide horizontally to inspect all columns

        </div>

        <!-- TOP SCROLL -->
        <div class="top-scroll"
             id="topScroll">

            <div class="top-scroll-inner"
                 id="topScrollInner">
            </div>

        </div>

        <!-- TABLE -->
        <div class="t-wrap"
             id="tableWrap">

            <table class="dt"
                   id="mainTable">

                <thead>

                    <tr>

                        <th>Account</th>
                        <th>Voucher</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Supplier Ref</th>
                        <th>Ref Date</th>
                        <th>Due Date</th>
                        <th>Attachment</th>
             
                        <th>Checker Status</th>
                        <th>Payment Status</th>
                        <th>Maker Remark</th>
                        <th>Checker Remark</th>

                    </tr>

                </thead>

                <tbody id="PaymentTable">

                    <tr>

                        <td colspan="12"
                            class="empty-row">

                            <i class="fa-solid fa-spinner fa-spin"></i>

                        </td>

                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>

    /* ═══════════════════════════════════════
    PRODUCT IMAGE MODAL
    ═══════════════════════════════════════ */

    $(document).on("click", ".clickable-product", function () {

    $("#modalProductImage")
    .attr("src", $(this).attr("src"));

    $("#productModal")
    .css("display", "flex");

    });

    $(".close-modal, #productModal").on("click", function (e) {

    if (
    e.target.id === "productModal"
    ||
    $(e.target).hasClass("close-modal")
    ) {

    $("#productModal").hide();

    }

    });

    /* ═══════════════════════════════════════
    KPI
    ═══════════════════════════════════════ */

    function updateKPIs(data) {

    if (!data || data.length === 0) {

    $("#kpi-total").text("0");

    $("#kpi-unpaid").text("₹0");

    $("#kpi-paid").text("0");

    $("#kpi-amount").text("0");

    return;
    }

    /* approved + unpaid from selected range */

    const unpaidBills = data.filter(x =>

    x.checkerStatus === "Approved"
    &&
    x.paymentStatus === "UnPaid"

    );

    /* unique vouchers */

    const uniqueBills = [
    ...new Map(
    unpaidBills.map(x => [x.vchNumber, x])
    ).values()
    ];

    /* total pending amount */

    const totalAmount =
    uniqueBills.reduce((sum, x) =>

    sum + (parseFloat(x.billAmount) || 0)

    , 0);

    /* unique vendors */

    const vendors =
    new Set(
    uniqueBills.map(x => x.accountName)
    ).size;

    /* overdue bills */

    const today = new Date();

    today.setHours(0,0,0,0);

    const overdue =
    uniqueBills.filter(x => {

    if (!x.dueDate) return false;

    const due = new Date(x.dueDate);

    due.setHours(0,0,0,0);

    return due < today;

    }).length;

    $("#kpi-total").text(
    uniqueBills.length
    );

    $("#kpi-unpaid").text(
    "₹" +
    totalAmount.toLocaleString("en-IN")
    );

    $("#kpi-paid").text(
    vendors
    );

    $("#kpi-amount").text(
    overdue
    );

    }

    /* ═══════════════════════════════════════
    LOAD DATA
    ═══════════════════════════════════════ */

    function loadData() {

    let fromDate = $("#fromDate").val();

    let toDate = $("#toDate").val();

    let accountName =
    $("#accountName").val().trim() || null;

    $("#PaymentTable").html(`
    <tr>
    <td colspan="12"
    class="empty-row">

    <i class="fa-solid fa-spinner fa-spin"></i>

    </td>
    </tr>
    `);

    $.get("/InvoicePayment/GetBillDetails", {

    fromDate: fromDate,
    toDate: toDate,
    accountName: accountName

    }, function (data) {

    let d = data || [];

    updateKPIs(d);

    renderTable(d);

    }).fail(function () {

    $("#PaymentTable").html(`
    <tr>
    <td colspan="12"
    class="empty-row"
    style="color:#EF4444">

    Error loading data

    </td>
    </tr>
    `);

    }).always(function () {

    $("#searchBtn")
    .prop("disabled", false)
    .html(`
    <i class="fa-solid fa-magnifying-glass"></i>
    Search
    `);

    });

    }

    /* ═══════════════════════════════════════
    TABLE
    ═══════════════════════════════════════ */

    function renderTable(data) {

    if (!data || data.length === 0) {

    $("#PaymentTable").html(`
    <tr>
    <td colspan="12"
    class="empty-row">

    No Data Found

    </td>
    </tr>
    `);

    return;
    }

    let approvedData = data.filter(item =>

    item.checkerStatus === "Approved"
    &&
    item.paymentStatus === "UnPaid"

    );

    if (approvedData.length === 0) {

    $("#PaymentTable").html(`
    <tr>
    <td colspan="12"
    class="empty-row">

    No Approved Records

    </td>
    </tr>
    `);

    return;
    }

    $("#rowCount").text(
    approvedData.length + " records"
    );

    let html = "";

    approvedData.forEach(item => {

    let checkerBadge =
    `<span class="status-badge sb-approved">
    <i class="fa-solid fa-circle-check"></i>
    Approved
    </span>`;

    let paymentBadge =
    item.paymentStatus === "Paid"
    ?
    `<span class="status-badge sb-approved">
    <i class="fa-solid fa-circle-check"></i>
    Paid
    </span>`
    :
    `<span class="status-badge sb-pending">
    <i class="fa-regular fa-clock"></i>
    UnPaid
    </span>`;

    let attachHtml =
    item.attachmentPath
    ?
    `<a href="#"
    onclick="openPdf('${item.attachmentPath}')"
    class="attach-view">

    <i class="fa-solid fa-eye"></i>

    View

    </a>`
    :
    `<span style="color:#9CA3AF">
    No File
    </span>`;

    html += `

    <tr>

    <td class="td-account">
    ${item.accountName ?? ""}
    </td>

    <td class="td-voucher">
    ${item.vchNumber ?? ""}
    </td>

    <td class="td-date">
    ${formatDate(item.voucherDate)}
    </td>

    <td class="td-amount">
    ₹${item.billAmount ?? ""}
    </td>

    <td>
    ${item.supplierRef || "-"}
    </td>

    <td class="td-date">
    ${formatDate(item.supplierRefDate)}
    </td>

    <td class="td-date">
    ${formatDate(item.dueDate)}
    </td>

    <td class="td-attach">
    ${attachHtml}
    </td>

    <td>
    ${checkerBadge}
    </td>

    <td>
    ${paymentBadge}
    </td>
    <td class="td-remark">
    ${item.makerRemark ?? "-"}
    </td>

    <td class="td-remark">
    ${item.checkerRemark ?? "-"}
    </td>
  
    </tr>
    `;
    });

    $("#PaymentTable").html(html);

    syncTopScroll();

    }

    /* ═══════════════════════════════════════
    DATE FORMAT
    ═══════════════════════════════════════ */

    function formatDate(ds) {

    if (!ds) return "";

    const d = new Date(ds);

    if (isNaN(d)) return ds;

    return d.toISOString().split("T")[0];

    }

    /* ═══════════════════════════════════════
    PDF
    ═══════════════════════════════════════ */

    function openPdf(path) {

    document.getElementById("pdfFrame").src = path;

    document.getElementById("pdfContainer")
    .style.display = "flex";

    }

    function closePdf() {

    document.getElementById("pdfContainer")
    .style.display = "none";

    document.getElementById("pdfFrame").src = "";

    }

    /* ═══════════════════════════════════════
    TOP SCROLL
    ═══════════════════════════════════════ */

    function initScrollSync() {

    const top =
    document.getElementById("topScroll");

    const wrap =
    document.getElementById("tableWrap");

    if (!top || !wrap) return;

    let lockTop = false;
    let lockWrap = false;

    top.addEventListener("scroll", function () {

    if (lockWrap) return;

    lockTop = true;

    wrap.scrollLeft = top.scrollLeft;

    lockTop = false;

    });

    wrap.addEventListener("scroll", function () {

    if (lockTop) return;

    lockWrap = true;

    top.scrollLeft = wrap.scrollLeft;

    lockWrap = false;

    });

    }

    function syncTopScroll() {

    requestAnimationFrame(function () {

    const table =
    document.getElementById("mainTable");

    const inner =
    document.getElementById("topScrollInner");

    if (!table || !inner) return;

    inner.style.width =
    table.scrollWidth + "px";

    });

    }

    /* ═══════════════════════════════════════
    SEARCH BUTTON
    ═══════════════════════════════════════ */

    $("#searchBtn").click(function () {

    let btn = $(this);

    btn.prop("disabled", true);

    btn.html(`
    <i class="fa-solid fa-spinner fa-spin"></i>
    Loading...
    `);

    loadData();

    });

    /* ═══════════════════════════════════════
    INIT
    ═══════════════════════════════════════ */

    $(document).ready(function () {

    initScrollSync();

    loadData();

    });

</script>
