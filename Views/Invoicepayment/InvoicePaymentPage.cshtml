        </div>

    </div>

</div>
</div><!-- /.invoice-payment-shell -->

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>

    /* ═══════════════════════════════════════
    PRODUCT IMAGE MODAL
    ═══════════════════════════════════════ */
    let _invoiceDataCache = [];

    $(document).on("click", ".clickable-product", function () {

    $("#modalProductImage")
    .attr("src", $(this).attr("src"));

    $("#productModal")
    .css("display", "flex");

    });

    $(".close-modal, #productModal").on("click", function (e) {

    if (
    e.target.id === "productModal"
    ||
    $(e.target).hasClass("close-modal")
    ) {

    $("#productModal").hide();

    }

    });

    /* ═══════════════════════════════════════
    KPI
    ═══════════════════════════════════════ */

    function updateKPIs(data) {

    if (!data || data.length === 0) {

    $("#kpi-total").text("0");

    $("#kpi-unpaid").text("₹0");

    $("#kpi-paid").text("0");

    $("#kpi-amount").text("0");

    return;
    }

    /* approved + unpaid from selected range */

    const unpaidBills = data.filter(x =>

    x.checkerStatus === "Approved"
    &&
    x.paymentStatus === "UnPaid"

    );

    /* unique vouchers */

    const uniqueBills = [
    ...new Map(
    unpaidBills.map(x => [x.vchNumber, x])
    ).values()
    ];

    /* total pending amount */

    const totalAmount =
    uniqueBills.reduce((sum, x) =>

    sum + (parseFloat(x.billAmount) || 0)

    , 0);

    /* unique vendors */

    const vendors =
    new Set(
    uniqueBills.map(x => x.accountName)
    ).size;

    /* overdue bills */

    const today = new Date();

    today.setHours(0,0,0,0);

    const overdue =
    uniqueBills.filter(x => {

    if (!x.dueDate) return false;

    const due = new Date(x.dueDate);

    due.setHours(0,0,0,0);

    return due < today;

    }).length;

    $("#kpi-total").text(
    uniqueBills.length
    );

    $("#kpi-unpaid").text(
    "₹" +
    totalAmount.toLocaleString("en-IN")
    );

    $("#kpi-paid").text(
    vendors
    );

    $("#kpi-amount").text(
    overdue
    );

    }

    /* ═══════════════════════════════════════
    LOAD DATA
    ═══════════════════════════════════════ */

    function loadData() {

    let fromDate = $("#fromDate").val();

    let toDate = $("#toDate").val();

    let accountName =
    $("#accountName").val().trim() || null;

    $("#PaymentTable").html(`
    <tr>
    <td colspan="12"
    class="empty-row">

    <i class="fa-solid fa-spinner fa-spin"></i>

    </td>
    </tr>
    `);

    $.get("/InvoicePayment/GetBillDetails", {

    fromDate: fromDate,
    toDate: toDate,
    accountName: accountName

    }, function (data) {

    let d = data || [];

    updateKPIs(d);

    renderTable(d);

    }).fail(function () {

    $("#PaymentTable").html(`
    <tr>
    <td colspan="12"
    class="empty-row"
    style="color:#EF4444">

    Error loading data

    </td>
    </tr>
    `);

    }).always(function () {

    $("#searchBtn")
    .prop("disabled", false)
    .html(`
    <i class="fa-solid fa-magnifying-glass"></i>
    Search
    `);

    });

    }

    function safeText(value) {

    if (value === null || value === undefined || value === "") return "-";

    return $("<div>").text(value).html();

    }

    function safeAttr(value) {

    return safeText(value).replace(/"/g, "&quot;");

    }

    function safeValueAttr(value) {

    if (value === null || value === undefined) return "";

    return $("<div>").text(value).html().replace(/"/g, "&quot;").replace(/'/g, "&#39;");

    }

    function safeJsString(value) {

    return JSON.stringify(value || "").replace(/"/g, "&quot;");

    }

    /* ═══════════════════════════════════════
    TABLE
    ═══════════════════════════════════════ */

    function renderTable(data) {

    if (!data || data.length === 0) {


    $("#rowCount").text("0 records");

    $("#PaymentTable").html(`
    <tr>
    <td colspan="12"
    class="empty-row">

    No Data Found

    </td>
    </tr>
    `);

    syncTopScroll();

    return;
    }
    _invoiceDataCache = data || [];

    let approvedData = data.filter(item =>

    item.checkerStatus === "Approved"
    &&
    item.paymentStatus === "UnPaid"

    );

    if (approvedData.length === 0) {

    $("#rowCount").text("0 records");

    $("#PaymentTable").html(`
    <tr>
    <td colspan="12"
    class="empty-row">

    No Approved Records

    </td>
    </tr>
    `);

    syncTopScroll();

    return;
    }

    $("#rowCount").text(
    approvedData.length + " records"
    );

    let html = "";

    approvedData.forEach(item => {

    let checkerBadge =
    `<span class="status-badge sb-approved"><i class="fa-solid fa-circle-check"></i> Approved</span>`;

    let paymentBadge =
    item.paymentStatus === "Paid"
    ?
    `<span class="status-badge sb-approved"><i class="fa-solid fa-circle-check"></i> Paid</span>`
    :
    `<span class="status-badge sb-pending"><i class="fa-regular fa-clock"></i> UnPaid</span>`;

    let attachHtml =
    item.attachmentPath
    ?
    `<a href="#"
    onclick="openPdf(${safeJsString(item.attachmentPath)});return false;"
    class="attach-view">

    <i class="fa-solid fa-eye"></i>

    View

    </a>`
    :
    `<span class="muted-pill"><i class="fa-regular fa-file"></i>No File</span>`;

    html += `

    <tr>

    <td class="td-account" title="${safeAttr(item.accountName ?? '')}">
    <span class="cell-text">${safeText(item.accountName ?? "")}</span>
    </td>

    <td class="td-voucher">
    <span class="cell-text">${safeText(item.vchNumber ?? "")}</span>
    </td>

    <td class="td-date">
    <span class="cell-text">${safeText(formatDate(item.voucherDate))}</span>
    </td>

    <td class="td-amount">
    <span class="cell-text">&#8377;${safeText(item.billAmount ?? "")}</span>
    </td>

    <td class="td-supplier" title="${safeAttr(item.supplierRef || '-')}">
    <span class="cell-text">${safeText(item.supplierRef || "-")}</span>
    </td>

    <td class="td-date">
    <span class="cell-text">${safeText(formatDate(item.supplierRefDate))}</span>
    </td>

    <td class="td-date">
    <span class="cell-text">${safeText(formatDate(item.dueDate))}</span>
    </td>

    <td class="td-attachment">
    ${attachHtml}
    </td>

    <td class="td-status">
    ${checkerBadge}
    </td>

    <td class="td-status">
    ${paymentBadge}
    </td>
    <td class="td-remark" title="${safeAttr(item.makerRemark ?? '-')}">
    <span class="cell-text clamp-text">${safeText(item.makerRemark ?? "-")}</span>
    </td>

    <td class="td-remark" title="${safeAttr(item.checkerRemark ?? '-')}">
    <span class="cell-text clamp-text">${safeText(item.checkerRemark ?? "-")}</span>
    </td>
  
    </tr>
    `;
    });

    $("#PaymentTable").html(html);

    syncTopScroll();

    }

    /* ═══════════════════════════════════════
    DATE FORMAT
    ═══════════════════════════════════════ */

    function formatDate(ds) {

    if (!ds) return "";

    const d = new Date(ds);

    if (isNaN(d)) return ds;

    return d.toISOString().split("T")[0];

    }

    /* ═══════════════════════════════════════
    PDF
    ═══════════════════════════════════════ */

    function openPdf(path) {

    document.getElementById("pdfFrame").src = path;

    document.getElementById("pdfContainer")
    .style.display = "flex";

    }

    function closePdf() {

    document.getElementById("pdfContainer")
    .style.display = "none";

    document.getElementById("pdfFrame").src = "";

    }

    /* ═══════════════════════════════════════
    TOP SCROLL
    ═══════════════════════════════════════ */

    function initScrollSync() {

    const top =
    document.getElementById("topScroll");

    const wrap =
    document.getElementById("tableWrap");

    if (!top || !wrap) return;

    let lockTop = false;
    let lockWrap = false;

    top.addEventListener("scroll", function () {

    if (lockWrap) return;

    lockTop = true;

    wrap.scrollLeft = top.scrollLeft;

    lockTop = false;

    });

    wrap.addEventListener("scroll", function () {

    if (lockTop) return;

    lockWrap = true;

    top.scrollLeft = wrap.scrollLeft;

    lockWrap = false;

    });

    }

    function syncTopScroll() {

    requestAnimationFrame(function () {

    const table =
    document.getElementById("mainTable");

    const inner =
    document.getElementById("topScrollInner");

    if (!table || !inner) return;

    inner.style.width =
    table.scrollWidth + "px";

    });

    }

    /* ═══════════════════════════════════════
    SEARCH BUTTON
    ═══════════════════════════════════════ */

    $("#searchBtn").click(function () {

    let btn = $(this);

    btn.prop("disabled", true);

    btn.html(`
    <i class="fa-solid fa-spinner fa-spin"></i>
    Loading...
    `);

    loadData();

    });

    /* ═══════════════════════════════════════
    INIT
    ═══════════════════════════════════════ */

    $(document).ready(function () {

    initScrollSync();

    loadData();

    });
    function exportToExcel() {

    var data = (_invoiceDataCache || []).filter(function(item) {
    return item.checkerStatus === "Approved" && item.paymentStatus === "UnPaid";
    });

    if (!data.length) { alert("No data to export"); return; }

    var fromDate = $("#fromDate").val() || "all";
    var toDate   = $("#toDate").val()   || "";
    var filename = "invoice-payment_" + fromDate + (toDate ? "_to_" + toDate : "") + ".csv";

    var rows = [];
    rows.push([
    "Account Name","Voucher No","Voucher Date","Bill Amount",
    "Supplier Ref","Ref Date","Due Date",
    "Checker Status","Payment Status",
    "Maker Remark","Checker Remark"
    ]);

    data.forEach(function(item) {
    rows.push([
    item.accountName   || "",
    item.vchNumber     || "",
    formatDate(item.voucherDate)      || "",
    item.billAmount    || "",
    item.supplierRef   || "",
    formatDate(item.supplierRefDate)  || "",
    formatDate(item.dueDate)          || "",
    item.checkerStatus || "",
    item.paymentStatus || "",
    item.makerRemark   || "",
    item.checkerRemark || ""
    ]);
    });

    var totalAmt    = data.reduce(function(s,x){ return s + (parseFloat(x.billAmount)||0); }, 0);
    var overdue     = 0;
    var today       = new Date(); today.setHours(0,0,0,0);
    data.forEach(function(x) {
    if (x.dueDate) { var d = new Date(x.dueDate); d.setHours(0,0,0,0); if(d<today) overdue++; }
    });
    var vendors = new Set(data.map(function(x){ return x.accountName; })).size;

    rows.push([]);
    rows.push(["TOTALS","","","₹" + totalAmt.toLocaleString("en-IN"),"","","","","","",""]);
    rows.push(["Unique Vendors","" + vendors,"Overdue Bills","" + overdue,"","","","","","",""]);

    downloadCSV(rows, filename);
    }
    /* ═══════════════════════════════════════
    SHARED CSV EXPORT UTILITY
    Add once per page — handles all escaping,
    BOM, and clean formatting.
    ═══════════════════════════════════════ */
    function downloadCSV(rows, filename) {
    var BOM = "\uFEFF"; // UTF-8 BOM — ensures Excel opens with correct encoding
    var csv = BOM + rows.map(function(row) {
    return row.map(function(cell) {
    var v = (cell === null || cell === undefined) ? "" : String(cell);
    // Normalise whitespace — remove line breaks, collapse spaces
    v = v.replace(/[\r\n\t]+/g, " ").replace(/\s{2,}/g, " ").trim();
    // Escape double-quotes
    v = v.replace(/"/g, '""');
    // Always quote every cell for safety
    return '"' + v + '"';
    }).join(",");
    }).join("\r\n");

    var blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    var url  = URL.createObjectURL(blob);
    var a    = document.createElement("a");
    a.href     = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    }

</script>
