@{
    ViewData["Title"] = "Task Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var employeeId   = (int)(ViewBag.EmployeeId  ?? 0);
    var roleTypeId   = (int)(ViewBag.RoleTypeId  ?? 3);
    var employeeName = ViewBag.EmployeeName?.ToString() ?? "User";
    var employeeCode = ViewBag.EmployeeCode?.ToString() ?? "";
    var isAdmin      = (bool)(ViewBag.IsAdmin     ?? false);
    var canAssignHod = (bool)(ViewBag.CanAssignHod ?? false);
    var isHod        = roleTypeId == 1;
    var isSubHod     = roleTypeId == 2;
    var hasTeam      = isHod || isSubHod || isAdmin;

    string roleLabel = isAdmin ? "Task Admin"
        : isHod        ? "HOD"
        : isSubHod     ? "Sub HOD"
        :                "Executive";
}

<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
    html, body { width: 100%; max-width: 100%; overflow-x: hidden; }

    .td-root, .td-root * {
        font-family: 'Sora', system-ui, sans-serif;
        box-sizing: border-box;
    }

    .td-root {
        background: #eef2f7;
        min-height: 100vh;
        width: 100%;
    }

    /* ── Header ── */
    .td-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 0 24px;
        height: 66px;
        background: #fff;
        border-bottom: 1.5px solid #e2e8f0;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 1px 6px rgba(0,0,0,.07);
    }

    .td-logo {
        width: 40px; height: 40px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1e3a5f, #2563eb);
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; color: #fff;
        box-shadow: 0 2px 8px rgba(37,99,235,.2);
        flex-shrink: 0;
    }

    .td-hd-title { font-size: 1.05rem; font-weight: 800; color: #0f172a; }
    .td-hd-sub   { font-size: 11px; color: #94a3b8; font-weight: 500; }

    .td-header-actions {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .td-role-pill {
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        background: rgba(37,99,235,.1);
        color: #2563eb;
        border: 1px solid rgba(37,99,235,.2);
    }

    .td-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: all .15s;
        text-decoration: none;
    }

    .td-btn-primary { background: #123f6d; color: #fff; }
    .td-btn-primary:hover { background: #1a5496; color: #fff; }
    .td-btn-outline { background: #fff; color: #123f6d; border: 1.5px solid #cbd5e1; }
    .td-btn-outline:hover { border-color: #123f6d; background: #f0f6ff; }

    /* ── Body ── */
    .td-body { padding: 28px 24px; max-width: 1400px; margin: 0 auto; }

    .td-tabs {
        display: inline-flex;
        gap: 4px;
        padding: 4px;
        margin-bottom: 22px;
        background: #dbe5f0;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
    }

    .td-tab {
        border: 0;
        border-radius: 7px;
        padding: 9px 18px;
        background: transparent;
        color: #475569;
        font-size: 13px;
        font-weight: 800;
        cursor: pointer;
    }

    .td-tab.active {
        background: #fff;
        color: #123f6d;
        box-shadow: 0 1px 4px rgba(15, 23, 42, .12);
    }

    .td-tab-panel { display: none; }
    .td-tab-panel.active { display: block; }

    .td-section-title {
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: #64748b;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .td-section-title::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e2e8f0;
    }

    /* ── Stat Cards ── */
    .td-cards {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 16px;
        margin-bottom: 28px;
    }

    .td-card {
        background: #fff;
        border-radius: 16px;
        padding: 22px 20px 18px;
        border-left: 4px solid #123f6d;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
        transition: transform .15s, box-shadow .15s;
        position: relative;
        overflow: hidden;
    }

    .td-card:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,.1); }
    .td-card.green  { border-left-color: #10b981; }
    .td-card.blue   { border-left-color: #3b82f6; }
    .td-card.red    { border-left-color: #ef4444; }
    .td-card.purple { border-left-color: #8b5cf6; }

    .td-card-icon {
        position: absolute; right: 14px; top: 14px;
        font-size: 28px; opacity: .12;
    }

    .td-card-val {
        font-size: 38px; font-weight: 800;
        color: #0f172a; line-height: 1;
        margin-bottom: 6px;
    }

    .td-card-lbl { font-size: 13px; color: #64748b; font-weight: 600; }

    .td-card-sub {
        margin-top: 10px;
        font-size: 11px;
        color: #94a3b8;
        font-weight: 600;
    }

    /* ── Two-column layout ── */
    .td-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }

    /* ── Panel ── */
    .td-panel {
        background: #fff;
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
    }

    .td-panel-title {
        font-size: 15px; font-weight: 800;
        color: #123f6d;
        margin-bottom: 18px;
        padding-bottom: 12px;
        border-bottom: 1.5px solid #e2e8f0;
        display: flex; align-items: center; gap: 8px;
    }

    /* ── Donut ── */
    .td-donut-wrap {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .td-donut-canvas { flex-shrink: 0; }

    .td-donut-legend { display: flex; flex-direction: column; gap: 10px; }

    .td-legend-row {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        color: #374151;
    }

    .td-legend-dot {
        width: 12px; height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .td-legend-count { margin-left: auto; font-weight: 800; color: #0f172a; }

    /* ── Progress bar list ── */
    .td-bar-list { display: flex; flex-direction: column; gap: 14px; }

    .td-bar-row { display: flex; flex-direction: column; gap: 5px; }

    .td-bar-info {
        display: flex; justify-content: space-between;
        font-size: 13px;
    }

    .td-bar-name { color: #374151; font-weight: 600; }
    .td-bar-count { color: #0f172a; font-weight: 800; }

    .td-bar-track {
        height: 8px;
        background: #e2e8f0;
        border-radius: 6px;
        overflow: hidden;
    }

    .td-bar-fill {
        height: 100%;
        border-radius: 6px;
        transition: width .6s ease;
    }

    /* ── Team table ── */
    .td-team-table { width: 100%; border-collapse: collapse; }

    .td-team-table th {
        text-align: left;
        padding: 10px 14px;
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: .4px;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .td-team-table td {
        padding: 12px 14px;
        font-size: 13px;
        color: #374151;
        border-bottom: 1px solid #f1f5f9;
    }

    .td-team-table tr:hover td { background: #f8fafc; }

    .td-member-link {
        border: 0;
        background: transparent;
        padding: 0;
        color: #123f6d;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
    }

    .td-member-link:hover { text-decoration: underline; }

    .td-mini-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 22px;
    }

    .td-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 2000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgba(15, 23, 42, .48);
    }

    .td-modal-overlay.open { display: flex; }

    .td-modal {
        width: min(1100px, 96vw);
        max-height: 86vh;
        overflow: hidden;
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 20px 60px rgba(15, 23, 42, .28);
        display: flex;
        flex-direction: column;
    }

    .td-modal-head {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 18px 22px;
        border-bottom: 1px solid #e2e8f0;
    }

    .td-modal-title { font-size: 18px; font-weight: 900; color: #0f172a; }
    .td-modal-sub { font-size: 12px; color: #64748b; font-weight: 600; margin-top: 3px; }

    .td-modal-close {
        margin-left: auto;
        width: 34px;
        height: 34px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        background: #fff;
        cursor: pointer;
        font-size: 20px;
        line-height: 1;
    }

    .td-modal-body {
        padding: 18px 22px 22px;
        overflow: auto;
    }

    .td-task-table { width: 100%; border-collapse: collapse; }
    .td-task-table th {
        text-align: left;
        padding: 10px 12px;
        font-size: 11px;
        color: #64748b;
        text-transform: uppercase;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }
    .td-task-table td {
        padding: 11px 12px;
        border-bottom: 1px solid #f1f5f9;
        font-size: 12px;
        color: #334155;
        vertical-align: top;
    }

    .td-task-name { font-weight: 800; color: #0f172a; }
    .td-muted { color: #94a3b8; font-size: 11px; margin-top: 3px; }

    .td-avatar {
        width: 30px; height: 30px;
        border-radius: 50%;
        background: linear-gradient(135deg, #123f6d, #2563eb);
        color: #fff;
        font-size: 11px; font-weight: 700;
        display: inline-flex; align-items: center; justify-content: center;
        margin-right: 8px;
        vertical-align: middle;
    }

    .td-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
    }

    .td-badge-pending  { background: #fef3c7; color: #d97706; }
    .td-badge-progress { background: #dbeafe; color: #2563eb; }
    .td-badge-done     { background: #d1fae5; color: #059669; }
    .td-badge-overdue  { background: #fee2e2; color: #dc2626; }

    /* ── Empty state ── */
    .td-empty {
        text-align: center;
        padding: 48px 24px;
        color: #94a3b8;
        font-size: 14px;
    }

    /* ── Spinner ── */
    .td-spinner-wrap { display: flex; align-items: center; justify-content: center; padding: 40px; }
    .td-spinner {
        width: 34px; height: 34px;
        border: 3px solid #e2e8f0;
        border-top-color: #123f6d;
        border-radius: 50%;
        animation: tdspin .8s linear infinite;
    }
    @@keyframes tdspin { to { transform: rotate(360deg); } }

    /* ── Responsive ── */
    @@media (max-width: 1100px) {
        .td-cards { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 860px) {
        .td-cols { grid-template-columns: 1fr; }
        .td-mini-grid { grid-template-columns: 1fr; }
        .td-cards { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 540px) {
        .td-cards { grid-template-columns: 1fr 1fr; }
        .td-body  { padding: 16px; }
    }
</style>

<div class="td-root">

    <!-- Header -->
    <header class="td-header">
        <div class="td-logo">📋</div>
        <div>
            <div class="td-hd-title">Task Dashboard</div>
            <div class="td-hd-sub">@employeeName &nbsp;·&nbsp; @employeeCode</div>
        </div>
        <div class="td-header-actions">
            <span class="td-role-pill">@roleLabel</span>
            <a href="/TaskWeb/Tasks" class="td-btn td-btn-outline">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                All Tasks
            </a>
        </div>
    </header>

    <div class="td-body">
        <div class="td-tabs" role="tablist" aria-label="Task dashboard sections">
            <button type="button" class="td-tab active" id="tab-my" role="tab" aria-selected="true" aria-controls="panel-my" onclick="switchTaskTab('my')">My Tasks</button>
            @if (hasTeam)
            {
                <button type="button" class="td-tab" id="tab-team" role="tab" aria-selected="false" aria-controls="panel-team" onclick="switchTaskTab('team')">Team Tasks</button>
            }
        </div>

        <!-- ── MY TASKS ── -->
        <section class="td-tab-panel active" id="panel-my" role="tabpanel" aria-labelledby="tab-my">
        <div class="td-section-title">My Tasks</div>

        <div class="td-cards" id="myCards">
            <div class="td-card">
                <span class="td-card-icon">📋</span>
                <div class="td-card-val" id="my-total">—</div>
                <div class="td-card-lbl">Total</div>
                <div class="td-card-sub" id="my-sub">Self &amp; Assigned</div>
            </div>
            <div class="td-card">
                <span class="td-card-icon">⏳</span>
                <div class="td-card-val" id="my-pending">—</div>
                <div class="td-card-lbl">Pending</div>
            </div>
            <div class="td-card blue">
                <span class="td-card-icon">🔄</span>
                <div class="td-card-val" id="my-progress">—</div>
                <div class="td-card-lbl">In Progress</div>
            </div>
            <div class="td-card green">
                <span class="td-card-icon">✅</span>
                <div class="td-card-val" id="my-done">—</div>
                <div class="td-card-lbl">Completed</div>
            </div>
            <div class="td-card red">
                <span class="td-card-icon">⏰</span>
                <div class="td-card-val" id="my-overdue">—</div>
                <div class="td-card-lbl">Overdue</div>
            </div>
        </div>

        <div class="td-cols" id="myCharts">
            <!-- Status donut -->
            <div class="td-panel">
                <div class="td-panel-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    My Tasks by Status
                </div>
                <div class="td-donut-wrap" id="myDonutWrap">
                    <div class="td-spinner-wrap"><div class="td-spinner"></div></div>
                </div>
            </div>

            <!-- Task type bars -->
            <div class="td-panel">
                <div class="td-panel-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><polyline points="3 6 4 7 6 5"/><polyline points="3 12 4 13 6 11"/><polyline points="3 18 4 19 6 17"/></svg>
                    Task Type Breakdown
                </div>
                <div id="myTypeBars" class="td-bar-list">
                    <div class="td-spinner-wrap"><div class="td-spinner"></div></div>
                </div>
            </div>
        </div>

        <div class="td-panel">
            <div class="td-panel-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13"/><path d="M8 12h13"/><path d="M8 18h13"/><path d="M3 6h.01"/><path d="M3 12h.01"/><path d="M3 18h.01"/></svg>
                My Task Details
            </div>
            <div id="myTaskTableWrap">
                <div class="td-spinner-wrap"><div class="td-spinner"></div></div>
            </div>
        </div>

        </section>

        @if (hasTeam)
        {
            <!-- ── TEAM TASKS ── -->
            <section class="td-tab-panel" id="panel-team" role="tabpanel" aria-labelledby="tab-team">
            <div class="td-section-title">Team Tasks</div>

            <div class="td-cards" id="teamCards">
                <div class="td-card">
                    <span class="td-card-icon">👥</span>
                    <div class="td-card-val" id="team-total">—</div>
                    <div class="td-card-lbl">Total</div>
                </div>
                <div class="td-card">
                    <span class="td-card-icon">⏳</span>
                    <div class="td-card-val" id="team-pending">—</div>
                    <div class="td-card-lbl">Pending</div>
                </div>
                <div class="td-card blue">
                    <span class="td-card-icon">🔄</span>
                    <div class="td-card-val" id="team-progress">—</div>
                    <div class="td-card-lbl">In Progress</div>
                </div>
                <div class="td-card green">
                    <span class="td-card-icon">✅</span>
                    <div class="td-card-val" id="team-done">—</div>
                    <div class="td-card-lbl">Completed</div>
                </div>
                <div class="td-card red">
                    <span class="td-card-icon">⏰</span>
                    <div class="td-card-val" id="team-overdue">—</div>
                    <div class="td-card-lbl">Overdue</div>
                </div>
            </div>

            <div class="td-mini-grid">
                <div class="td-panel">
                    <div class="td-panel-title">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 16l4-4 3 3 5-7"/></svg>
                        Team Status Mix
                    </div>
                    <div class="td-donut-wrap" id="teamDonutWrap">
                        <div class="td-spinner-wrap"><div class="td-spinner"></div></div>
                    </div>
                </div>
                <div class="td-panel">
                    <div class="td-panel-title">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>
                        Top Workload
                    </div>
                    <div id="teamWorkloadBars" class="td-bar-list">
                        <div class="td-spinner-wrap"><div class="td-spinner"></div></div>
                    </div>
                </div>
            </div>

            <!-- Team member breakdown -->
            <div class="td-panel">
                <div class="td-panel-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Team Member Breakdown
                </div>
                <div id="teamTableWrap">
                    <div class="td-spinner-wrap"><div class="td-spinner"></div></div>
                </div>
            </div>
            </section>
        }

    </div>
</div>

<div class="td-modal-overlay" id="memberTaskModal" onclick="closeMemberTaskModal(event)">
    <div class="td-modal" role="dialog" aria-modal="true" aria-labelledby="memberTaskTitle" onclick="event.stopPropagation()">
        <div class="td-modal-head">
            <div>
                <div class="td-modal-title" id="memberTaskTitle">Team Member Tasks</div>
                <div class="td-modal-sub" id="memberTaskSub">All assigned tasks</div>
            </div>
            <button type="button" class="td-modal-close" onclick="closeMemberTaskModal()" aria-label="Close">x</button>
        </div>
        <div class="td-modal-body" id="memberTaskBody">
            <div class="td-spinner-wrap"><div class="td-spinner"></div></div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    const _empId     = @employeeId;
    const _roleType  = @roleTypeId;
    const _hasTeam   = @hasTeam.ToString().ToLowerInvariant();
    const _apiTask   = '/api/task';

    let _donutChart = null;
    let _teamDonutChart = null;

    document.addEventListener('DOMContentLoaded', loadDashboard);

    function switchTaskTab(tab) {
        const isTeam = tab === 'team';
        document.getElementById('tab-my')?.classList.toggle('active', !isTeam);
        document.getElementById('tab-team')?.classList.toggle('active', isTeam);
        document.getElementById('panel-my')?.classList.toggle('active', !isTeam);
        document.getElementById('panel-team')?.classList.toggle('active', isTeam);
        document.getElementById('tab-my')?.setAttribute('aria-selected', String(!isTeam));
        document.getElementById('tab-team')?.setAttribute('aria-selected', String(isTeam));
    }

    async function loadDashboard() {
        try {
            const res  = await fetch(`${_apiTask}/GetDashboard`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ employeeId: _empId, roleTypeId: _roleType })
            });
            const json = await res.json();
            const data = json.data ?? json.Data ?? json;

            renderMySection(data.myTasks ?? data.MyTasks ?? {});
            loadMyTaskDetails();
            if (_hasTeam) {
                renderTeamSection(data.teamTasks ?? data.TeamTasks ?? {});
                renderTeamTable(data.teamMemberBreakdown ?? data.TeamMemberBreakdown ?? []);
            }
        } catch (e) {
            console.error('Dashboard load failed:', e);
        }
    }

    function renderMySection(d) {
        const total    = d.totalTasks    ?? d.TotalTasks    ?? 0;
        const pending  = d.pendingCount  ?? d.PendingCount  ?? 0;
        const progress = d.inProgressCount ?? d.InProgressCount ?? 0;
        const done     = d.completedCount ?? d.CompletedCount ?? 0;
        const overdue  = d.overdueCount  ?? d.OverdueCount  ?? 0;
        const self     = d.selfTaskCount ?? d.SelfTaskCount ?? 0;
        const assigned = d.assignedTaskCount ?? d.AssignedTaskCount ?? 0;

        setText('my-total',   total);
        setText('my-pending', pending);
        setText('my-progress',progress);
        setText('my-done',    done);
        setText('my-overdue', overdue);
        setText('my-sub', `Self: ${self}  ·  Assigned: ${assigned}`);

        // Donut chart
        renderDonut({ pending, progress, done, overdue });

        // Type bars
        renderTypeBars(self, assigned, total);
    }

    function renderDonut({ pending, progress, done, overdue }) {
        const wrap = document.getElementById('myDonutWrap');
        const total = pending + progress + done + overdue;
        if (total === 0) {
            wrap.innerHTML = '<div class="td-empty">No tasks yet</div>';
            return;
        }

        wrap.innerHTML = '<canvas id="tdDonut" width="150" height="150" class="td-donut-canvas"></canvas><div class="td-donut-legend" id="tdDonutLegend"></div>';

        const ctx = document.getElementById('tdDonut').getContext('2d');
        if (_donutChart) _donutChart.destroy();

        const colors  = ['#f59e0b', '#3b82f6', '#10b981', '#ef4444'];
        const labels  = ['Pending', 'In Progress', 'Completed', 'Overdue'];
        const values  = [pending, progress, done, overdue];

        _donutChart = new Chart(ctx, {
            type: 'doughnut',
            data: { labels, datasets: [{ data: values, backgroundColor: colors, borderWidth: 0 }] },
            options: {
                responsive: false,
                cutout: '62%',
                plugins: { legend: { display: false }, tooltip: { callbacks: {
                    label: ctx => ` ${ctx.label}: ${ctx.raw}`
                }}}
            }
        });

        document.getElementById('tdDonutLegend').innerHTML = labels.map((l, i) =>
            `<div class="td-legend-row">
                <span class="td-legend-dot" style="background:${colors[i]}"></span>
                <span>${l}</span>
                <span class="td-legend-count">${values[i]}</span>
            </div>`
        ).join('');
    }

    function renderTypeBars(self, assigned, total) {
        const el = document.getElementById('myTypeBars');
        if (total === 0) { el.innerHTML = '<div class="td-empty">No tasks yet</div>'; return; }

        const bars = [
            { label: 'Self Tasks',     val: self,     color: '#123f6d', pct: pct(self,     total) },
            { label: 'Assigned Tasks', val: assigned, color: '#2563eb', pct: pct(assigned, total) }
        ];

        el.innerHTML = bars.map(b =>
            `<div class="td-bar-row">
                <div class="td-bar-info">
                    <span class="td-bar-name">${b.label}</span>
                    <span class="td-bar-count">${b.val} <span style="font-weight:500;color:#94a3b8">(${b.pct}%)</span></span>
                </div>
                <div class="td-bar-track">
                    <div class="td-bar-fill" style="width:${b.pct}%;background:${b.color}"></div>
                </div>
            </div>`
        ).join('');
    }

    async function loadMyTaskDetails() {
        const wrap = document.getElementById('myTaskTableWrap');
        if (!wrap) return;
        try {
            const res = await fetch(`${_apiTask}/GetAllTasks`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    page: 1,
                    limit: 99999,
                    employeeId: _empId,
                    roleTypeId: _roleType,
                    viewMode: 'OWN',
                    sortBy: 'expected_end_date',
                    sortOrder: 'ASC'
                })
            });
            const json = await res.json();
            renderMyTaskTable(json.data ?? json.Data ?? []);
        } catch (e) {
            wrap.innerHTML = '<div class="td-empty">Unable to load task details</div>';
        }
    }

    function renderMyTaskTable(tasks) {
        const wrap = document.getElementById('myTaskTableWrap');
        if (!tasks.length) {
            wrap.innerHTML = '<div class="td-empty">No task details available</div>';
            return;
        }

        const rows = tasks.map(t => {
            const status = t.status ?? t.Status ?? '';
            const pctDone = t.percentComplete ?? t.PercentComplete ?? 0;
            const assignedTo = t.assignedTo ?? t.AssignedTo ?? '-';
            const assignedBy = t.assignedByName ?? t.AssignedByName ?? t.createdBy ?? t.CreatedBy ?? '-';
            return `<tr>
                <td>
                    <div class="td-task-name">${escHtml(t.taskName ?? t.TaskName ?? 'Untitled task')}</div>
                    <div class="td-muted">${escHtml(t.projectName ?? t.ProjectName ?? '')}${(t.moduleName ?? t.ModuleName) ? ' / ' + escHtml(t.moduleName ?? t.ModuleName) : ''}</div>
                </td>
                <td><span class="td-badge ${statusClass(status)}">${escHtml(formatStatus(status))}</span></td>
                <td>${escHtml(assignedTo)}</td>
                <td>${escHtml(assignedBy)}</td>
                <td>${formatDate(t.startDate ?? t.StartDate)}</td>
                <td>${formatDate(t.expectedEndDate ?? t.ExpectedEndDate)}</td>
                <td>${formatDate(t.completionDate ?? t.CompletionDate)}</td>
                <td>
                    <div style="display:flex;align-items:center;gap:8px">
                        <div class="td-bar-track" style="width:72px;height:6px">
                            <div class="td-bar-fill" style="width:${Math.max(0, Math.min(100, pctDone))}%;background:#10b981"></div>
                        </div>
                        <span style="font-size:12px;font-weight:800">${pctDone}%</span>
                    </div>
                </td>
            </tr>`;
        }).join('');

        wrap.innerHTML = `<table class="td-task-table">
            <thead>
                <tr>
                    <th>Task</th>
                    <th>Status</th>
                    <th>Assigned To</th>
                    <th>Assigned By</th>
                    <th>From</th>
                    <th>Till Date</th>
                    <th>Completed On</th>
                    <th>Progress</th>
                </tr>
            </thead>
            <tbody>${rows}</tbody>
        </table>`;
    }

    function renderTeamSection(d) {
        const pending = d.pendingCount ?? d.PendingCount ?? 0;
        const progress = d.inProgressCount ?? d.InProgressCount ?? 0;
        const done = d.completedCount ?? d.CompletedCount ?? 0;
        const overdue = d.overdueCount ?? d.OverdueCount ?? 0;
        setText('team-total',   d.totalTasks      ?? d.TotalTasks      ?? 0);
        setText('team-pending', pending);
        setText('team-progress',progress);
        setText('team-done',    done);
        setText('team-overdue', overdue);
        renderTeamDonut({ pending, progress, done, overdue });
    }

    function renderTeamTable(members) {
        const wrap = document.getElementById('teamTableWrap');
        if (!members.length) {
            wrap.innerHTML = '<div class="td-empty">No team data available</div>';
            renderTeamWorkload([]);
            return;
        }

        const rows = members.map(m => {
            const employeeId = m.employeeId ?? m.EmployeeId ?? 0;
            const name     = m.employeeName    ?? m.EmployeeName    ?? '—';
            const total    = m.totalTasks      ?? m.TotalTasks      ?? 0;
            const pending  = m.pendingCount    ?? m.PendingCount    ?? 0;
            const progress = m.inProgressCount ?? m.InProgressCount ?? 0;
            const done     = m.completedCount  ?? m.CompletedCount  ?? 0;
            const overdue  = m.overdueCount    ?? m.OverdueCount    ?? 0;
            const initials = name.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
            const compRate = total > 0 ? Math.round((done / total) * 100) : 0;

            return `<tr>
                <td>
                    <span class="td-avatar">${initials}</span>
                    <button type="button" class="td-member-link" onclick="openMemberTasks(${employeeId}, '${jsAttr(name)}')">${escHtml(name)}</button>
                </td>
                <td style="font-weight:800;color:#0f172a">${total}</td>
                <td><span class="td-badge td-badge-pending">${pending}</span></td>
                <td><span class="td-badge td-badge-progress">${progress}</span></td>
                <td><span class="td-badge td-badge-done">${done}</span></td>
                <td><span class="td-badge td-badge-overdue">${overdue}</span></td>
                <td>
                    <div style="display:flex;align-items:center;gap:8px">
                        <div class="td-bar-track" style="width:80px;height:6px">
                            <div class="td-bar-fill" style="width:${compRate}%;background:#10b981"></div>
                        </div>
                        <span style="font-size:12px;font-weight:700;color:#059669">${compRate}%</span>
                    </div>
                </td>
            </tr>`;
        }).join('');

        wrap.innerHTML = `
            <table class="td-team-table">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Total</th>
                        <th>Pending</th>
                        <th>In Progress</th>
                        <th>Completed</th>
                        <th>Overdue</th>
                        <th>Completion</th>
                    </tr>
                </thead>
                <tbody>${rows}</tbody>
            </table>`;
        renderTeamWorkload(members);
    }

    function renderTeamDonut({ pending, progress, done, overdue }) {
        const wrap = document.getElementById('teamDonutWrap');
        if (!wrap) return;
        const total = pending + progress + done + overdue;
        if (total === 0) {
            wrap.innerHTML = '<div class="td-empty">No team tasks yet</div>';
            return;
        }

        wrap.innerHTML = '<canvas id="teamDonut" width="150" height="150" class="td-donut-canvas"></canvas><div class="td-donut-legend" id="teamDonutLegend"></div>';
        const ctx = document.getElementById('teamDonut').getContext('2d');
        if (_teamDonutChart) _teamDonutChart.destroy();

        const colors = ['#f59e0b', '#3b82f6', '#10b981', '#ef4444'];
        const labels = ['Pending', 'In Progress', 'Completed', 'Overdue'];
        const values = [pending, progress, done, overdue];
        _teamDonutChart = new Chart(ctx, {
            type: 'doughnut',
            data: { labels, datasets: [{ data: values, backgroundColor: colors, borderWidth: 0 }] },
            options: {
                responsive: false,
                cutout: '62%',
                plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.raw}` } } }
            }
        });

        document.getElementById('teamDonutLegend').innerHTML = labels.map((l, i) =>
            `<div class="td-legend-row">
                <span class="td-legend-dot" style="background:${colors[i]}"></span>
                <span>${l}</span>
                <span class="td-legend-count">${values[i]}</span>
            </div>`
        ).join('');
    }

    function renderTeamWorkload(members) {
        const el = document.getElementById('teamWorkloadBars');
        if (!el) return;
        const rows = members
            .map(m => ({
                name: m.employeeName ?? m.EmployeeName ?? 'Team Member',
                total: m.totalTasks ?? m.TotalTasks ?? 0,
                done: m.completedCount ?? m.CompletedCount ?? 0
            }))
            .filter(m => m.total > 0)
            .sort((a, b) => b.total - a.total)
            .slice(0, 5);

        if (!rows.length) {
            el.innerHTML = '<div class="td-empty">No workload yet</div>';
            return;
        }

        const max = Math.max(...rows.map(r => r.total), 1);
        el.innerHTML = rows.map(r => {
            const width = Math.max(8, Math.round((r.total / max) * 100));
            const completion = r.total > 0 ? Math.round((r.done / r.total) * 100) : 0;
            return `<div class="td-bar-row">
                <div class="td-bar-info">
                    <span class="td-bar-name">${escHtml(r.name)}</span>
                    <span class="td-bar-count">${r.total} <span style="font-weight:500;color:#94a3b8">(${completion}% done)</span></span>
                </div>
                <div class="td-bar-track">
                    <div class="td-bar-fill" style="width:${width}%;background:#123f6d"></div>
                </div>
            </div>`;
        }).join('');
    }

    async function openMemberTasks(employeeId, employeeName) {
        if (!employeeId) return;
        document.getElementById('memberTaskTitle').textContent = employeeName || 'Team Member';
        document.getElementById('memberTaskSub').textContent = 'All assigned tasks with status and date range';
        document.getElementById('memberTaskBody').innerHTML = '<div class="td-spinner-wrap"><div class="td-spinner"></div></div>';
        document.getElementById('memberTaskModal').classList.add('open');

        try {
            const res = await fetch(`${_apiTask}/GetAllTasks`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    page: 1,
                    limit: 99999,
                    employeeId: _empId,
                    roleTypeId: _roleType,
                    viewMode: 'TEAM',
                    assignedToEmployeeId: employeeId,
                    sortBy: 'expected_end_date',
                    sortOrder: 'ASC'
                })
            });
            const json = await res.json();
            const tasks = json.data ?? json.Data ?? [];
            renderMemberTaskModal(tasks);
        } catch (e) {
            document.getElementById('memberTaskBody').innerHTML = '<div class="td-empty">Unable to load tasks</div>';
        }
    }

    function renderMemberTaskModal(tasks) {
        const body = document.getElementById('memberTaskBody');
        if (!tasks.length) {
            body.innerHTML = '<div class="td-empty">No tasks found for this team member</div>';
            return;
        }

        const rows = tasks.map(t => {
            const status = t.status ?? t.Status ?? '';
            const priority = t.priority ?? t.Priority ?? '';
            const pctDone = t.percentComplete ?? t.PercentComplete ?? 0;
            return `<tr>
                <td>
                    <div class="td-task-name">${escHtml(t.taskName ?? t.TaskName ?? 'Untitled task')}</div>
                    <div class="td-muted">${escHtml(t.projectName ?? t.ProjectName ?? '')}${(t.moduleName ?? t.ModuleName) ? ' / ' + escHtml(t.moduleName ?? t.ModuleName) : ''}</div>
                </td>
                <td><span class="td-badge ${statusClass(status)}">${escHtml(formatStatus(status))}</span></td>
                <td>${escHtml(priority || '-')}</td>
                <td>${formatDate(t.startDate ?? t.StartDate)}</td>
                <td>${formatDate(t.expectedEndDate ?? t.ExpectedEndDate)}</td>
                <td>${formatDate(t.completionDate ?? t.CompletionDate)}</td>
                <td>
                    <div style="display:flex;align-items:center;gap:8px">
                        <div class="td-bar-track" style="width:72px;height:6px">
                            <div class="td-bar-fill" style="width:${Math.max(0, Math.min(100, pctDone))}%;background:#10b981"></div>
                        </div>
                        <span style="font-size:12px;font-weight:800">${pctDone}%</span>
                    </div>
                </td>
            </tr>`;
        }).join('');

        body.innerHTML = `<table class="td-task-table">
            <thead>
                <tr>
                    <th>Task</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>From</th>
                    <th>Till Date</th>
                    <th>Completed On</th>
                    <th>Progress</th>
                </tr>
            </thead>
            <tbody>${rows}</tbody>
        </table>`;
    }

    function closeMemberTaskModal(event) {
        if (event && event.target !== document.getElementById('memberTaskModal')) return;
        document.getElementById('memberTaskModal').classList.remove('open');
    }

    function formatDate(value) {
        if (!value) return '-';
        const d = new Date(value);
        if (isNaN(d.getTime()) || d.getFullYear() < 1900) return '-';
        return d.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    function formatStatus(status) {
        return String(status || '-').replace(/_/g, ' ').toLowerCase().replace(/\b\w/g, c => c.toUpperCase());
    }

    function statusClass(status) {
        const s = String(status || '').toUpperCase();
        if (s.includes('COMPLETE')) return 'td-badge-done';
        if (s.includes('PROGRESS')) return 'td-badge-progress';
        if (s.includes('OVERDUE')) return 'td-badge-overdue';
        return 'td-badge-pending';
    }

    function escHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, ch => ({
            '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        }[ch]));
    }

    function jsAttr(value) {
        return String(value ?? '').replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/\r?\n/g, ' ');
    }

    function setText(id, val) {
        const el = document.getElementById(id);
        if (el) el.textContent = val;
    }

    function pct(val, total) {
        return total > 0 ? Math.round((val / total) * 100) : 0;
    }
</script>
