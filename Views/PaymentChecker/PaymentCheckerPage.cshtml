<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
  
    let _paymentCheckerCache = [];
    // -----------------------------------------------
    // LOAD DATA
    // -----------------------------------------------

    function loadData() {

    let fromDate = $("#fromDate").val();
    let toDate = $("#toDate").val();
    let accountName = $("#accountName").val().trim() || null;
    let _paymentCheckerCache = [];

    if (!fromDate || !toDate) {
    alert("Please select both dates");
    return;
    }

    if (fromDate > toDate) {
    alert("From Date cannot be greater than To Date");
    return;
    }

    $("#paymentCheckerTable").html(`
    <tr>
    <td colspan="12" class="empty-row">
    <i class="fa-solid fa-spinner fa-spin"></i> Loading...
    </td>
    </tr>`);

    resetCards();

    $.get("/PaymentChecker/GetPaidBillDetails", {

    fromDate: fromDate,
    toDate: toDate,
    accountName: accountName

    }, function (data) {

    renderTable(data || []);
    

    setTimeout(syncTopScroll, 300);

    }).fail(function () {

    $("#paymentCheckerTable").html(`
    <tr>
    <td colspan="12"
    class="empty-row"
    style="color:#EF4444">

    Error loading data

    </td>
    </tr>`);

    });

    }

    function safeText(value) {
    if (value === null || value === undefined || value === "") return "-";
    return $("<div>").text(value).html();
    }

    function safeAttr(value) {
    return safeText(value).replace(/"/g, "&quot;");
    }

    function safeJsString(value) {
    return JSON.stringify(value || "").replace(/&/g, "&amp;").replace(/"/g, "&quot;");
    }


    // -----------------------------------------------
    // RENDER TABLE
    // -----------------------------------------------

    function renderTable(data) {
    _paymentCheckerCache = data || [];

    if (!data || data.length === 0) {
    _paymentCheckerCache = data || [];

    $("#paymentCheckerTable").html(`
    <tr>
    <td colspan="12"
    class="empty-row">

    <i class="fa-solid fa-inbox" style="font-size:22px;display:block;margin-bottom:8px;color:#D1D5DB"></i>
    No Paid Invoices Found

    </td>
    </tr>`);

    updateCards([]);
    $("#recordBadge").text("");

    return;
    }

    updateCards(data);

    $("#recordBadge").text(data.length + " records");

    let html = "";
    let seenVch = new Set();

    data.forEach(item => {

    if (seenVch.has(item.vchNumber)) return;

    seenVch.add(item.vchNumber);

    let attachHtml = item.attachmentPath
    ? `<a href="#"
    onclick="openPdf(${safeJsString(item.attachmentPath)});return false;"
    class="attach-view">

    <i class="fa-solid fa-eye"></i> View

    </a>`
    : `<span class="muted-pill"><i class="fa-regular fa-file"></i>No File</span>`;

    html += `

    <tr id="row-${safeAttr(item.vchNumber)}">

    <td class="td-account" title="${safeAttr(item.accountName ?? '')}">
    <span class="cell-text">${safeText(item.accountName ?? "")}</span>
    </td>

    <td class="td-voucher"><span class="cell-text">${safeText(item.vchNumber ?? "")}</span></td>

    <td class="td-date"><span class="cell-text">${safeText(formatDate(item.voucherDate))}</span></td>

    <td class="td-amount"><span class="cell-text">&#8377;${safeText(item.billAmount ?? "")}</span></td>

    <td class="td-supplier" title="${safeAttr(item.supplierRef || "-")}"><span class="cell-text">${safeText(item.supplierRef || "-")}</span></td>

    <td class="td-date"><span class="cell-text">${safeText(formatDate(item.supplierRefDate))}</span></td>

    <td class="td-date"><span class="cell-text">${safeText(formatDate(item.dueDate))}</span></td>

    <td class="td-date"><span class="cell-text">${safeText(formatDate(item.paymentDate))}</span></td>

    <td class="td-attachment">${attachHtml}</td>
    <td class="td-status">
    <span class="status-badge sb-approved"><i class="fa-solid fa-check"></i> Approved</span>
    </td>
    <td class="td-status">
    <span class="status-badge sb-approved"><i class="fa-solid fa-circle-check"></i> Paid</span>
    </td>
   
    <td class="td-remark" title="${safeAttr(item.checkerRemark || "-")}"><span class="cell-text clamp-text">${safeText(item.checkerRemark || "-")}</span></td>

    </tr>`;
    });

    $("#paymentCheckerTable").html(html);

    }


    // -----------------------------------------------
    // KPI
    // -----------------------------------------------

    function updateCards(data) {

    if (!data || data.length === 0) {

    $("#cardTotalCount").text("0");
    $("#cardTotalAmount").text("0");
    $("#cardLatestDate").text("—");
    $("#cardUniqueAccounts").text("0");

    return;
    }

    let uniqueVouchers = [...new Set(
    data.map(x => x.vchNumber)
    )];

    let totalAmount = data.reduce((sum, item) => {

    return sum + (parseFloat(item.billAmount) || 0);

    }, 0);

    let uniqueAccounts = new Set(
    data.map(x => x.accountName)
    ).size;

    let paymentDates = data
    .filter(x => x.paymentDate)
    .map(x => new Date(x.paymentDate));

    let latestDate = paymentDates.length
    ? new Date(Math.max(...paymentDates))
    .toISOString()
    .split("T")[0]
    : "—";

    $("#cardTotalCount").text(
    uniqueVouchers.length
    );

    $("#cardTotalAmount").text(
    totalAmount.toLocaleString("en-IN", {
    maximumFractionDigits: 2
    })
    );

    $("#cardLatestDate").text(latestDate);

    $("#cardUniqueAccounts").text(uniqueAccounts);

    }


    function resetCards() {

    $("#cardTotalCount").text("—");
    $("#cardTotalAmount").text("—");
    $("#cardLatestDate").text("—");
    $("#cardUniqueAccounts").text("—");

    $("#recordBadge").text("");

    }





    // -----------------------------------------------
    // PDF
    // -----------------------------------------------

    function openPdf(path) {

    $("#pdfFrame").attr("src", path);

    $("#pdfContainer").css("display", "flex");

    }

    function closePdf() {

    $("#pdfContainer").hide();

    $("#pdfFrame").attr("src", "");

    }


    // -----------------------------------------------
    // ACCOUNT AUTOCOMPLETE
    // -----------------------------------------------

    $(document).ready(function () {

    $("#searchBtn").click(loadData);

    $("#accountName").on("keyup", function () {

    let term = $(this).val().trim();

    if (term.length < 2) {

    $("#suggestionBox").empty();

    return;
    }

    $.get("/Maker/GetAccountSuggestions", {

    term: term

    }, function (data) {

    let html = "";

    if (!data || data.length === 0) {

    html = `
    <div class="suggest-item">
    No result
    </div>`;

    } else {

    data.forEach(x => {

    html += `
    <div class="suggest-item">
    ${x}
    </div>`;
    });
    }

    $("#suggestionBox").html(html);

    });

    });

    $(document).on("mousedown", ".suggest-item", function (e) {

    e.preventDefault();

    $("#accountName").val($(this).text().trim());

    $("#suggestionBox").empty();

    });

    });


    // -----------------------------------------------
    // DATE FORMAT
    // -----------------------------------------------

    function formatDate(dateString) {

    if (!dateString || dateString === "-")
    return "-";

    let d = new Date(dateString);

    if (isNaN(d))
    return "-";

    return d.toISOString().split('T')[0];

    }


    // -----------------------------------------------
    // TOP SCROLL SYNC
    // -----------------------------------------------

    function syncTopScroll() {

    const tableWrap = document.getElementById("tableWrap");
    const topScroll = document.getElementById("topScroll");
    const topScrollInner = document.getElementById("topScrollInner");
    const table = document.getElementById("mainTable");

    if (!tableWrap || !topScroll || !table) return;

    topScrollInner.style.width = table.scrollWidth + "px";

    topScroll.addEventListener("scroll", () => {
    tableWrap.scrollLeft = topScroll.scrollLeft;
    });

    tableWrap.addEventListener("scroll", () => {
    topScroll.scrollLeft = tableWrap.scrollLeft;
    });

    }

    window.onload = syncTopScroll;
    function exportToExcel() {

    var seenVch = new Set();
    var data = (_paymentCheckerCache || []).filter(function(item) {
    if (seenVch.has(item.vchNumber)) return false;
    seenVch.add(item.vchNumber);
    return true;
    });

    if (!data.length) { alert("No data to export"); return; }

    var fromDate = $("#fromDate").val() || "all";
    var toDate   = $("#toDate").val()   || "";
    var filename = "payment-checker_" + fromDate + (toDate ? "_to_" + toDate : "") + ".csv";

    var rows = [];
    rows.push([
    "Account Name","Voucher No","Voucher Date","Bill Amount",
    "Supplier Ref","Ref Date","Due Date","Payment Date",
    "Checker Status","Payment Status","Checker Remark"
    ]);

    data.forEach(function(item) {
    rows.push([
    item.accountName   || "",
    item.vchNumber     || "",
    formatDate(item.voucherDate)      || "",
    item.billAmount    || "",
    item.supplierRef   || "",
    formatDate(item.supplierRefDate)  || "",
    formatDate(item.dueDate)          || "",
    formatDate(item.paymentDate)      || "",
    "Approved",
    "Paid",
    item.checkerRemark || ""
    ]);
    });

    var totalAmt = data.reduce(function(s,x){ return s + (parseFloat(x.billAmount)||0); }, 0);
    var accounts = new Set(data.map(function(x){ return x.accountName; })).size;

    rows.push([]);
    rows.push(["TOTALS","","","₹" + totalAmt.toLocaleString("en-IN"),"","","","","","",""]);
    rows.push(["Unique Accounts","" + accounts,"Total Invoices","" + data.length,"","","","","","",""]);

    downloadCSV(rows, filename);
    }

    /* ═══════════════════════════════════════
    SHARED CSV EXPORT UTILITY
    Add once per page — handles all escaping,
    BOM, and clean formatting.
    ═══════════════════════════════════════ */
    function downloadCSV(rows, filename) {
    var BOM = "\uFEFF"; // UTF-8 BOM — ensures Excel opens with correct encoding
    var csv = BOM + rows.map(function(row) {
    return row.map(function(cell) {
    var v = (cell === null || cell === undefined) ? "" : String(cell);
    // Normalise whitespace — remove line breaks, collapse spaces
    v = v.replace(/[\r\n\t]+/g, " ").replace(/\s{2,}/g, " ").trim();
    // Escape double-quotes
    v = v.replace(/"/g, '""');
    // Always quote every cell for safety
    return '"' + v + '"';
    }).join(",");
    }).join("\r\n");

    var blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    var url  = URL.createObjectURL(blob);
    var a    = document.createElement("a");
    a.href     = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    }
</script>
