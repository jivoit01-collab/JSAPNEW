

@{
    ViewData["Title"] = "Checker Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/bill-verification.css" />
<link rel="stylesheet" href="~/css/admin-premium.css" />

<!-- ═══════════════════════════════════
     NAVBAR
═══════════════════════════════════ -->
<nav class="premium-nav">
    <div class="light-wave"></div>
    <div class="blue-glow"></div>
    <!-- ARY TITLE -->
    <div class="ary-brand-header">
        <div class="ary-brand-name">
            Akal Rozgar Yojana
        </div>
    </div>
    <div class="nav-left-section">
        <div class="brand-logo-wrap">
            <img src="~/images/logo.png" class="brand-logo" />
        </div>
        <div class="brand-content">
            <div class="brand-title">Wellness</div>
            <div class="brand-subtitle">Healthy Oils • Super Juices • Smart Living</div>
        </div>
    </div>

    <div class="product-slider">
        <div class="product-track">
            <img src="@Url.Content("~/images/canola.jpg")" class="product-img" />
            <img src="@Url.Content("~/images/js3.png")" class="product-img" />
            <img src="@Url.Content("~/images/Pomace-2-1000x1000.png")" class="product-img" />
            <img src="@Url.Content("~/images/Desi-Ghee.jpg")" class="product-img" />
            <img src="@Url.Content("~/images/71ohxqRTikL._AC_UF894,1000_QL80_.jpg")" class="product-img" />
            <img src="@Url.Content("~/images/canola.jpg")" class="product-img" />
            <img src="@Url.Content("~/images/js3.png")" class="product-img" />
            <img src="@Url.Content("~/images/Pomace-2-1000x1000.png")" class="product-img" />
            <img src="@Url.Content("~/images/Desi-Ghee.jpg")" class="product-img" />
            <img src="@Url.Content("~/images/71ohxqRTikL._AC_UF894,1000_QL80_.jpg")" class="product-img" />
        </div>
    </div>

    <div class="module-box checker">
        <div class="module-dot"></div>
        <i class="fa-solid fa-user-check"></i>
        <span>Checker Dashboard</span>
    </div>
</nav>


<div class="body">
    <!-- KPI CARDS -->
    <div class="kpi-grid">

        <div class="kpi-card k-amber">
            <div class="kpi-val" id="pendingCount">0</div>
            <div class="kpi-label">Pending Approvals</div>
        </div>

        <div class="kpi-card k-green">
            <div class="kpi-val" id="approvedToday">0</div>
            <div class="kpi-label">Approved</div>
        </div>

        <div class="kpi-card k-blue">
            <div class="kpi-val" id="monthlyEntries">0</div>
            <div class="kpi-label">Total Entries</div>
        </div>

        <div class="kpi-card k-purple">
            <div class="kpi-val" id="rejectedToday">0</div>
            <div class="kpi-label">Rejected </div>
        </div>

    </div>

    <!-- PDF VIEWER -->
    <div id="pdfContainer" class="pdf-modal">
        <div class="pdf-box">
            <button onclick="closePdf()" class="pdf-close">×</button>
            <iframe id="pdfFrame"></iframe>
        </div>
    </div>

    <!-- ═══════════════════════════════════
         FILTER CARD
    ═══════════════════════════════════ -->
    <div class="filter-card">
        <div class="f-group">
            <span class="f-label">From Date</span>
            <input type="date" id="fromDate" class="f-input" />
        </div>
        <div class="f-group">
            <span class="f-label">To Date</span>
            <input type="date" id="toDate" class="f-input" />
        </div>
        <div class="f-group grow" style="position:relative">
            <span class="f-label">Account Name</span>
            <input type="text" id="accountName" class="f-input"
                   placeholder="Search account..." autocomplete="off" />
            <div id="suggestionBox" class="suggestion-box"></div>
        </div>
        <div class="f-group">
            <span class="f-label">Status</span>
            <select id="statusFilter" class="f-input">
                <option value="">All Status</option>
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Rejected">Rejected</option>
            </select>
        </div>
        <button class="btn btn-dark" id="searchBtn">
            <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
        <button class="btn btn-export" onclick="exportToExcel()" id="exportBtn" style="display:none">
            <i class="fa-solid fa-file-excel"></i> Export
        </button>
    </div>

    <!-- ═══════════════════════════════════
         TABLE CARD
    ═══════════════════════════════════ -->
    <div class="t-card checker-table-card">
        <div class="t-header">
            <span class="t-title">
                <i class="fa-solid fa-shield-check"></i> Bill Verification
            </span>
            <span class="t-count" id="checkerCount">0 records</span>
        </div>

        <div class="table-slide-hint">
            <i class="fa-solid fa-arrows-left-right"></i>
            Slide horizontally to inspect all columns
        </div>

        <!-- TOP SCROLLBAR -->
        <div class="top-scroll" id="topScroll">
            <div class="top-scroll-inner" id="topScrollInner"></div>
        </div>

        <div class="t-wrap" id="tableWrap">
            <table class="dt" id="checkerDt">
                <thead>
                    <tr>
                        <th>Account</th>
                        <th>Voucher No</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Supplier Ref</th>
                        <th>Due Date</th>
                        <th>Attachment</th>
                        <th>Maker Remark</th>
                        <th>Status</th>
                        <th>Checker Remark</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="checkerTable"></tbody>
            </table>
        </div>
    </div>

    <!-- SCROLL BUTTONS -->
    <div id="scroll-btns">
        <button class="scroll-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="Top">
            <i class="fa-solid fa-chevron-up"></i>
        </button>
        <button class="scroll-btn" onclick="window.scrollTo({top:document.body.scrollHeight,behavior:'smooth'})" title="Bottom">
            <i class="fa-solid fa-chevron-down"></i>
        </button>
    </div>

</div><!-- /.body -->
<!-- ═══════════════════════════════════
     CONFIRMATION MODAL
═══════════════════════════════════ -->
<div class="confirm-overlay" id="confirmOverlay">
    <div class="confirm-box" id="confirmBox">

        <div class="confirm-header">
            <div class="confirm-icon" id="confirmIcon">
                <i id="confirmIconSymbol" class="fa-solid fa-circle-check"></i>
            </div>
            <div>
                <div class="confirm-title" id="confirmTitle">Confirm Action</div>
                <div class="confirm-subtitle" id="confirmSubtitle">Please review before proceeding</div>
            </div>
        </div>

        <div class="confirm-body">
            <div class="confirm-warning" id="confirmWarning">
                <i id="confirmWarnIcon" class="fa-solid fa-triangle-exclamation"></i>
                <div id="confirmWarningText">Are you sure?</div>
            </div>
            <div class="confirm-meta" id="confirmMeta">
                <div class="confirm-meta-row">
                    <span>Voucher No</span>
                    <span id="meta-vch">—</span>
                </div>
                <div class="confirm-meta-row">
                    <span>Account Name</span>
                    <span id="meta-account">—</span>
                </div>
                <div class="confirm-meta-row">
                    <span>Amount</span>
                    <span id="meta-amount">—</span>
                </div>
                <div class="confirm-meta-row">
                    <span>Checker Remark</span>
                    <span id="meta-remark">—</span>
                </div>
            </div>
        </div>

        <div class="confirm-footer">
            <button class="confirm-cancel" id="confirmCancel">
                <i class="fa-solid fa-xmark"></i> Cancel
            </button>
            <button class="confirm-proceed" id="confirmProceed">
                <i class="fa-solid fa-check"></i> Confirm
            </button>
        </div>

    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>

    /* ═══════════════════════════════════════
    STATE
    ═══════════════════════════════════════ */
    let _pendingAction = null;   // function to call on confirm

    /* ═══════════════════════════════════════
    BOOT
    ═══════════════════════════════════════ */
    $(document).ready(function () {

    $("#searchBtn").on("click", loadData);

    /* autocomplete */
    $("#accountName").on("keyup", function () {
    const term = $(this).val().trim();
    if (term.length < 2) { $("#suggestionBox").empty().hide(); return; }
    $.get("/Checker/GetAccountSuggestions", { term }, function (data) {
    if (!data || !data.length) {
    $("#suggestionBox").html('<div class="suggest-item suggest-empty">No result</div>').show();
    return;
    }
    let html = "";
    data.forEach(x => { html += `<div class="suggest-item">${x}</div>`; });
    $("#suggestionBox").html(html).show();
    });
    });

    $(document).on("mousedown", ".suggest-item", function (e) {
    e.preventDefault();
    const v = $(this).text().trim();
    if (v !== "No result") $("#accountName").val(v);
    $("#suggestionBox").empty().hide();
    });

    $(document).on("click", function (e) {
    if (!$(e.target).closest("#accountName, #suggestionBox").length)
    $("#suggestionBox").empty().hide();
    });

    /* modal — cancel */
    $("#confirmCancel").on("click", closeConfirm);

    /* modal — confirm */
    $("#confirmProceed").on("click", function () {
    if (typeof _pendingAction === "function") {
    _pendingAction();
    }
    });

    /* ESC to close modal */
    $(document).on("keydown", function (e) {
    if (e.key === "Escape") closeConfirm();
    });

    /* click OUTSIDE confirm-box = do NOT close (safety) */

    initScrollSync();
    });

    /* ═══════════════════════════════════════
    LOAD DATA
    ═══════════════════════════════════════ */
    function loadData() {
    const fromDate    = $("#fromDate").val();
    const toDate      = $("#toDate").val();
    const accountName = $("#accountName").val().trim() || null;
    const status      = $("#statusFilter").val();

    $("#checkerTable").html(
    `<tr><td colspan="11" class="empty-row">
    <i class="fa-solid fa-spinner fa-spin" style="font-size:20px;color:#9CA3AF"></i>
    </td></tr>`
    );

    $.get("/Checker/GetBillDetails",
    { fromDate: fromDate || null, toDate: toDate || null, accountName, status },
    function (data) {
    renderTable(data || []);
    updateCheckerKPIs(data || []);
    }
    ).fail(function () {
    $("#exportBtn").hide();
    $("#checkerTable").html(
    `<tr><td colspan="11" class="empty-row" style="color:#EF4444">
    <i class="fa-solid fa-triangle-exclamation"></i> Error loading data.
    </td></tr>`
    );
    });
    }
    function updateCheckerKPIs(data) {

    if (!data || data.length === 0) {

    $("#pendingCount").text("0");

    $("#approvedToday").text("0");

    $("#monthlyEntries").text("0");

    $("#rejectedToday").text("0");

    return;
    }

    /* unique vouchers */

    const uniqueRows = [
    ...new Map(
    data.map(x => [x.vchNumber, x])
    ).values()
    ];

    /* pending */

    const pending =
    uniqueRows.filter(x =>
    (x.checkerStatus || "Pending")
    .toLowerCase() === "pending"
    ).length;

    /* approved */

    const approved =
    uniqueRows.filter(x =>
    (x.checkerStatus || "")
    .toLowerCase() === "approved"
    ).length;

    /* rejected */

    const rejected =
    uniqueRows.filter(x =>
    (x.checkerStatus || "")
    .toLowerCase() === "rejected"
    ).length;

    /* total */

    const total =
    uniqueRows.length;

    $("#pendingCount").text(pending);

    $("#approvedToday").text(approved);

    $("#monthlyEntries").text(total);

    $("#rejectedToday").text(rejected);

    }
    /* render table */
    function renderTable(data) {
  
  
    const seen = new Set();
    const rows = (data || []).filter(item => {
    if (seen.has(item.vchNumber)) return false;
    seen.add(item.vchNumber);
    return true;
    });

    $("#checkerCount").text(rows.length + " record" + (rows.length !== 1 ? "s" : ""));

    if (!rows.length) {
    $("#checkerTable").html(
    `<tr><td colspan="11" class="empty-row">
    <i class="fa-solid fa-inbox" style="font-size:22px;display:block;margin-bottom:8px;color:#D1D5DB"></i>
    No data found.
    </td></tr>`
    );
    syncTopScroll();
    return;
    }

    let html = "";

    rows.forEach(item => {

    /* hide entries without attachment */

    if (!item.attachmentPath) {
    return;
    }

    

    const cs = item.checkerStatus || "Pending";
    const statusBadge =
    cs === "Approved" ? `<span class="status-badge sb-approved"><i class="fa-solid fa-circle-check"></i> Approved</span>` :
    cs === "Rejected" ? `<span class="status-badge sb-rejected"><i class="fa-solid fa-circle-xmark"></i> Rejected</span>` :
    `<span class="status-badge sb-pending"><i class="fa-regular fa-clock"></i> Pending</span>`;

    const actionCell = cs === "Approved"
    ? `<span class="status-badge sb-approved"><i class="fa-solid fa-circle-check"></i> Done</span>`
    : cs === "Rejected"
    ? `<span class="status-badge sb-rejected"><i class="fa-solid fa-ban"></i> Rejected</span>`
    : `<div class="action-cell">
    <button class="btn-approve approveBtn"
    data-vch="${item.vchNumber}"
    data-account="${item.accountName ?? ''}"
    data-amount="${item.billAmount ?? ''}">
    <i class="fa-solid fa-circle-check"></i> Approve
    </button>
    <button class="btn-reject rejectBtn"
    data-vch="${item.vchNumber}"
    data-account="${item.accountName ?? ''}"
    data-amount="${item.billAmount ?? ''}">
    <i class="fa-solid fa-circle-xmark"></i> Reject
    </button>
    </div>`;

    const attachHtml = item.attachmentPath
    ? `<a class="attach-view" href="#" onclick="openPdf('${item.attachmentPath}');return false;">
    <i class="fa-solid fa-eye"></i> View
    </a>`
    : `<span style="color:#D1D5DB;font-size:12px">No File</span>`;

    html += `
    <tr id="row-${item.vchNumber}" onclick="highlightRow(this)">
    <td class="td-account">
    <a href="javascript:void(0)"
    onclick="loadDetails(${item.vchNumber},${item.serialNumber});event.stopPropagation();"
    style="color:#1D4ED8;font-weight:600;text-decoration:none">
    ${item.accountName ?? ""}
    <i class="fa-solid fa-chevron-down" style="font-size:10px;margin-left:4px;color:#9CA3AF"></i>
    </a>
    </td>
    <td class="td-voucher">${item.vchNumber ?? ""}</td>
    <td class="td-date">${formatDate(item.voucherDate)}</td>
    <td class="td-amount">&#8377;${item.billAmount ?? ""}</td>
    <td>${item.supplierRef || "-"}</td>
    <td class="td-date">${formatDate(item.dueDate)}</td>
    <td class="td-attach">${attachHtml}</td>
    <td class="td-remark">${item.makerRemark ?? "-"}</td>
    <td>${statusBadge}</td>
    <td>
    <input type="text"
    class="checker-remark-input checkerRemark"
    placeholder="Enter remark…"
    value="${item.checkerRemark ?? ""}"
    ${cs !== "Pending" ? 'readonly style="opacity:.6"' : ''} />
    </td>
    <td>${actionCell}</td>
    </tr>`;
    });

    $("#checkerTable").html(html);
    $("#exportBtn").show();
    if (window._syncTopScroll) window._syncTopScroll();
    }
   
   

    /* ═══════════════════════════════════════
    ROW HIGHLIGHT
    ═══════════════════════════════════════ */
    function highlightRow(tr) {
    document.querySelectorAll('.checker-table-card table.dt tbody tr.row-selected')
    .forEach(r => r.classList.remove('row-selected'));
    tr.classList.add('row-selected');
    }

    /* ═══════════════════════════════════════
    APPROVE — with confirmation modal
    ═══════════════════════════════════════ */
    $(document).on("click", ".approveBtn", function (e) {
    e.stopPropagation();
    const btn     = $(this);
    const vch     = btn.data("vch");
    const account = btn.data("account");
    const amount  = btn.data("amount");
    const remark  = btn.closest("tr").find(".checkerRemark").val() || "—";

    openConfirm({
    type     : "approve",
    title    : "Approve Bill",
    subtitle : "Confirm approval for this entry",
    warning  : "You are about to <strong>approve</strong> this bill. This will mark it as verified and move it forward in the payment workflow.",
    vch, account, amount, remark,
    onConfirm: function () {
    executeAction(vch, "Approved", remark, btn);
    }
    });
    });

    /* ═══════════════════════════════════════
    REJECT — with confirmation modal
    ═══════════════════════════════════════ */
    $(document).on("click", ".rejectBtn", function (e) {
    e.stopPropagation();
    const btn     = $(this);
    const vch     = btn.data("vch");
    const account = btn.data("account");
    const amount  = btn.data("amount");
    const remark  = btn.closest("tr").find(".checkerRemark").val() || "—";

    openConfirm({
    type     : "reject",
    title    : "Reject Bill",
    subtitle : "Confirm rejection for this entry",
    warning  : "You are about to <strong>reject</strong> this bill. This will return it to the maker and may impact the payment workflow.",
    vch, account, amount, remark,
    onConfirm: function () {
    executeAction(vch, "Rejected", remark, btn);
    }
    });
    });

    /* ═══════════════════════════════════════
    EXECUTE ACTION
    ═══════════════════════════════════════ */
    function executeAction(vch, status, remark, triggerBtn) {
    closeConfirm();

    /* disable both buttons on that row while processing */
    const row = triggerBtn.closest("tr");
    row.find(".btn-approve, .btn-reject")
    .prop("disabled", true)
    .html('<i class="fa-solid fa-spinner fa-spin"></i>');

    $.post("/Checker/UpdateCheckerStatus",
    { vchNumber: vch, status: status, remark: remark },
    function (res) {
    showToast(
    status === "Approved"
    ? "Bill approved successfully ✔"
    : "Bill rejected.",
    status === "Approved" ? "success" : "error"
    );
    loadData();
    }
    ).fail(function () {
    showToast("Action failed. Please try again.", "error");
    row.find(".btn-approve, .btn-reject").prop("disabled", false);
    loadData();
    });
    }

    /* ═══════════════════════════════════════
    CONFIRMATION MODAL HELPERS
    ═══════════════════════════════════════ */
    function openConfirm(opts) {
    const isApprove = opts.type === "approve";

    /* icon */
    const icon = document.getElementById("confirmIcon");
    icon.className = "confirm-icon " + opts.type;
    document.getElementById("confirmIconSymbol").className =
    isApprove ? "fa-solid fa-circle-check" : "fa-solid fa-circle-xmark";

    /* texts */
    document.getElementById("confirmTitle").textContent    = opts.title;
    document.getElementById("confirmSubtitle").textContent = opts.subtitle;

    const warn = document.getElementById("confirmWarning");
    warn.className = "confirm-warning " + opts.type;
    document.getElementById("confirmWarnIcon").className =
    isApprove ? "fa-solid fa-info-circle" : "fa-solid fa-triangle-exclamation";
    document.getElementById("confirmWarningText").innerHTML = opts.warning;

    /* meta */
    document.getElementById("meta-vch").textContent     = opts.vch;
    document.getElementById("meta-account").textContent = opts.account;
    document.getElementById("meta-amount").textContent  = "₹" + opts.amount;
    document.getElementById("meta-remark").textContent  = opts.remark;

    /* proceed button */
    const proceed = document.getElementById("confirmProceed");
    proceed.className = "confirm-proceed " + opts.type;
    proceed.innerHTML = isApprove
    ? '<i class="fa-solid fa-circle-check"></i> Approve'
    : '<i class="fa-solid fa-circle-xmark"></i> Reject';

    /* store callback */
    _pendingAction = opts.onConfirm;

    /* show */
    document.getElementById("confirmOverlay").classList.add("show");
    }

    function closeConfirm() {
    document.getElementById("confirmOverlay").classList.remove("show");
    _pendingAction = null;
    }

    function loadDetails(vchNumber, serialNumber) {

    const existing = document.getElementById("details-" + vchNumber);

    if (existing) {
    existing.remove();
    return;
    }

    document.querySelectorAll("[id^='details-']").forEach(el => el.remove());

    const row = document.getElementById("row-" + vchNumber);

    if (!row) return;

    row.insertAdjacentHTML("afterend", `
    <tr id="details-${vchNumber}" class="detail-row">
    <td colspan="11">

    <div class="detail-inner">
    <i class="fa-solid fa-spinner fa-spin"
    style="color:#9CA3AF"></i>
    Loading items...
    </div>

    </td>
    </tr>
    `);

    const ctrl = new AbortController();

    const timeout = setTimeout(() => {
    ctrl.abort();
    }, 15000);

    fetch("/Checker/GetInvoiceItems?serialNumber=" + serialNumber, {
    signal: ctrl.signal
    })

    .then(r => {
    if (!r.ok) throw new Error();
    return r.json();
    })

    .then(data => {

    clearTimeout(timeout);

    const rows = data.map(item => `

    <div class="detail-card">

    <div class="detail-top">

    <div class="detail-product">
    ${item.productName ?? "-"}
    </div>

    <div class="detail-amount">
    ₹${item.amount ?? 0}
    </div>

    </div>

    <div class="detail-grid">

    <div class="detail-item">
    <span>Serial</span>
    <strong>${item.serialNumber ?? "-"}</strong>
    </div>

    <div class="detail-item">
    <span>HSN/SAC</span>
    <strong>${item.hsnsacid ?? "-"}</strong>


    </div>

    <div class="detail-item">
    <span>Purchase Rate</span>
    <strong>₹${item.purchaseRate ?? 0}</strong>
    </div>

    <div class="detail-item">
    <span>Quantity</span>
    <strong>${item.quantity ?? 0}</strong>
    </div>

    <div class="detail-item">
    <span>Discount</span>
    <strong>${item.discountPercent ?? 0}%</strong>
    </div>

    <div class="detail-item">
    <span>Margin</span>
    <strong>${item.margin ?? 0}%</strong>
    </div>

    </div>

    </div>

    `).join("");

    const el = document.getElementById("details-" + vchNumber);

    if (el) {

    el.outerHTML = `
    <tr id="details-${vchNumber}" class="detail-row">
    <td colspan="11">

    <div class="detail-container">
    ${rows}
    </div>

    </td>
    </tr>
    `;
    }

    })

    .catch(err => {

    clearTimeout(timeout);

    const el = document.getElementById("details-" + vchNumber);

    if (el) {

    el.innerHTML = `
    <td colspan="11"
    class="empty-row"
    style="color:#EF4444">

    ${err.name === "AbortError"
    ? "Request timed out ⏱"
    : "Error loading items ❌"}

    </td>
    `;
    }

    });

    }

    /* ═══════════════════════════════════════
    PDF
    ═══════════════════════════════════════ */
    function openPdf(path) {
    document.getElementById("pdfFrame").src = path;
    document.getElementById("pdfContainer").style.display = "flex";
    }
    function closePdf() {
    document.getElementById("pdfContainer").style.display = "none";
    document.getElementById("pdfFrame").src = "";
    }

    /* ═══════════════════════════════════════
    FORMAT DATE
    ═══════════════════════════════════════ */
    function formatDate(ds) {
    if (!ds) return "";
    const d = new Date(ds);
    if (isNaN(d)) return ds;
    return d.toISOString().split("T")[0];
    }

    /* ═══════════════════════════════════════
    TOP SCROLL SYNC
    ═══════════════════════════════════════ */
    function initScrollSync() {
    const top  = document.getElementById("topScroll");
    const wrap = document.getElementById("tableWrap");
    if (!top || !wrap) return;

    let lockTop = false, lockWrap = false;

    top.addEventListener("scroll", function () {
    if (lockWrap) return;
    lockTop = true;
    wrap.scrollLeft = top.scrollLeft;
    lockTop = false;
    });
    wrap.addEventListener("scroll", function () {
    if (lockTop) return;
    lockWrap = true;
    top.scrollLeft = wrap.scrollLeft;
    lockWrap = false;
    });
    }

    function syncTopScroll() {
    requestAnimationFrame(function () {
    const table = document.getElementById("checkerDt");
    const inner = document.getElementById("topScrollInner");
    if (!table || !inner) return;
    inner.style.width = table.offsetWidth + "px";
    });
    }

    /* ═══════════════════════════════════════
    TOAST
    ═══════════════════════════════════════ */
    function showToast(msg, type) {
    const t = document.createElement("div");
    t.className   = "toast toast-" + type;
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => t.classList.add("toast-show"), 10);
    setTimeout(() => { t.classList.remove("toast-show"); setTimeout(() => t.remove(), 300); }, 3500);
    }

    /* ═══════════════════════════════════════
    SCROLL BUTTONS
    ═══════════════════════════════════════ */
    window.addEventListener("scroll", function () {
    document.getElementById("scroll-btns")
    .classList.toggle("visible", window.scrollY > 200);
    });
    /* ═══════════════════════════════════
    EXPORT TO EXCEL
    ═══════════════════════════════════ */
    function exportToExcel() {
    const rows = document.querySelectorAll("#makerBody tr");
    if (!rows.length) { showToast("No data to export", "error"); return; }

    const headers = [
    "Account Name","Voucher No","Voucher Date","Bill Amount",
    "Supplier Ref","Supplier Ref Date","Due Date","Maker Remark",
    "Checker Status","Total Qty","Total Value","Total Items",
    "Payment Status","Payment Date"
    ];

    // Build CSV
    let csv = headers.join(",") + "\n";

    rows.forEach(row => {
    const cells = row.querySelectorAll("td");
    if (!cells.length) return;

    // Map visible column indices (skip Attachment col index 7, Action col index 10)
    const skipCols = new Set([7, 10]);
    let rowData = [];

    cells.forEach((cell, i) => {
    if (skipCols.has(i)) return;
    // Get plain text, strip badges/buttons
    let val = cell.innerText.replace(/\n/g, " ").trim();
    // Escape commas and quotes
    val = '"' + val.replace(/"/g, '""') + '"';
    rowData.push(val);
    });

    csv += rowData.join(",") + "\n";
    });

    // Trigger download
    const fromDate = $("#fromDate").val() || "export";
    const toDate   = $("#toDate").val()   || "";
    const filename = `maker-entries_${fromDate}_${toDate}.csv`;

    const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement("a");
    a.href     = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);

    showToast("Exported successfully!", "success");
    }

</script>
